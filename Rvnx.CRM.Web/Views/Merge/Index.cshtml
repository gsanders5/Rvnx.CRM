@model Rvnx.CRM.Web.ViewModels.Merge.MergeContactViewModel

@{
    ViewData["Title"] = "Merge Contact";
}

<form id="merge-form" asp-action="Confirm" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PrimaryContactId" />

    <div class="crm-details-actions-strip">
        <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.PrimaryContactId" class="crm-btn-tertiary btn-sm">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Contact
        </a>
        <button type="submit" class="crm-btn-primary btn-sm">
            <i class="bi bi-diagram-3" aria-hidden="true"></i> Next: Preview Merge
        </button>
    </div>

    <section class="crm-edit-masthead crm-fade-in">
        <div class="crm-edit-masthead-photo-placeholder" aria-hidden="true"><i class="bi bi-diagram-3"></i></div>
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 6px;">Merge contacts</div>
            <h1 class="crm-edit-masthead-title">
                Pick a contact to merge into <em>@Model.PrimaryContact?.FullName</em>
            </h1>
        </div>
    </section>

    <div class="crm-page" style="max-width: 720px;">
        <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

        <div class="crm-card">
            <div class="crm-card-header">
                <h5 class="card-title mb-0"><i class="bi bi-people" aria-hidden="true"></i> Secondary Contact</h5>
            </div>
            <div class="crm-card-body">
                <p>Select another contact to merge into <strong>@Model.PrimaryContact?.FullName</strong>.</p>
                <p class="small" style="color: var(--crm-danger);">
                    <strong>Warning:</strong> The contact you select below (the secondary contact) will be
                    <strong>deleted</strong> after its data is migrated to @Model.PrimaryContact?.FullName.
                </p>

                <div class="crm-field-group">
                    <label asp-for="SecondaryContactId">Select a contact to merge into the primary</label>
                    <select asp-for="SecondaryContactId" id="SecondaryContactId" asp-items="ViewBag.SecondaryContacts" class="crm-input" required>
                        <option value="">-- Select Contact --</option>
                    </select>
                    <span asp-validation-for="SecondaryContactId" class="crm-field-error"></span>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            $('#SecondaryContactId').select2({ width: '100%' });
        });
    </script>
}
