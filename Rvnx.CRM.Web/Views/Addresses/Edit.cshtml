@model Rvnx.CRM.Core.DTOs.Contact.AddressFormDto
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Edit Address";
}

<form id="address-form" asp-action="Edit" data-edit-form>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ContactId" />

    @await Html.PartialAsync("_EditFormHeader", new EditFormHeaderModel
    {
        BackUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!,
        Icon = "bi-geo-alt",
        Eyebrow = "Editing address",
        Title = string.IsNullOrWhiteSpace(Model.AddressType) ? "Address" : Model.AddressType
    })

    @* ── Body ───────────────────────────────────────────────────────────── *@
    <div class="crm-edit-body">

        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            @* ── Address Details ───────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-geo-alt" aria-hidden="true"></i> Address</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-field-group">
                        <label asp-for="AddressType">Address Type *</label>
                        <select asp-for="AddressType" id="AddressType" class="crm-input"
                                data-select2 data-select2-tags data-select2-allow-clear
                                data-select2-placeholder="Select or type a custom type...">
                            <option value="">Select or type a custom type...</option>
                            @foreach (var type in Rvnx.CRM.Core.Constants.AddressTypes.All)
                            {
                                <option value="@type" selected="@(Model.AddressType == type)">@type</option>
                            }
                            @if (!string.IsNullOrEmpty(Model.AddressType) && !Rvnx.CRM.Core.Constants.AddressTypes.All.Contains(Model.AddressType))
                            {
                                <option value="@Model.AddressType" selected>@Model.AddressType</option>
                            }
                        </select>
                        <span asp-validation-for="AddressType" class="crm-field-error"></span>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Street</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Line1">Address Line 1 *</label>
                        <input asp-for="Line1" class="crm-input" id="Line1" autofocus />
                        <span asp-validation-for="Line1" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Line2">Address Line 2</label>
                        <input asp-for="Line2" class="crm-input" id="Line2" />
                        <span asp-validation-for="Line2" class="crm-field-error"></span>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Locality</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-form-card-grid" style="grid-template-columns: 2fr 1fr 1fr;">
                        <div class="crm-field-group">
                            <label asp-for="City">City</label>
                            <input asp-for="City" class="crm-input" id="City" />
                            <span asp-validation-for="City" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="State">State / Province</label>
                            <input asp-for="State" class="crm-input" id="State" />
                            <span asp-validation-for="State" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Zip">Zip / Postal Code</label>
                            <input asp-for="Zip" class="crm-input" id="Zip" />
                            <span asp-validation-for="Zip" class="crm-field-error"></span>
                        </div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Country">Country</label>
                        <input asp-for="Country" class="crm-input" id="Country" />
                        <span asp-validation-for="Country" class="crm-field-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
            {
                FormId = "address-form",
                CancelUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!
            })
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
