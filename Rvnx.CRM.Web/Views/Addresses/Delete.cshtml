@model Rvnx.CRM.Core.DTOs.Contact.AddressDto

@{
    ViewData["Title"] = "Delete Address";
}

<h1>Delete Address</h1>

<h3>Are you sure you want to delete this address?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">@Model.AddressType</dd>
        <dt class="col-sm-2">Address</dt>
        <dd class="col-sm-10">@Model.FormattedAddress</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id"/>
        <div class="d-grid gap-2 d-md-flex mt-4">
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-2"></i>Delete</button>
            <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary"><i class="bi bi-arrow-left me-2"></i>Cancel</a>
        </div>
    </form>
</div>
