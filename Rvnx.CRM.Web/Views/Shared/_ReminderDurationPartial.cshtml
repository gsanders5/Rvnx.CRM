@using Rvnx.CRM.Core.Interfaces
@model IRemindableDto

<style>
    /* Custom Input Styling - Timer Style */
    .duration-input {
        text-align: center;
        font-size: 2rem;
        font-weight: 700;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 0.5rem;
        color: #212529;
        background-color: #fff;
        transition: all 0.2s;
    }

    .duration-input:focus {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
    }

    /* Label underneath the input */
    .timer-label {
        display: block;
        text-align: center;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        margin-top: 0.5rem;
    }

    /* Hide Browser Default Spinners (Robust) */
    input[type=number]::-webkit-outer-spin-button,
    input[type=number]::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    input[type=number] {
        -moz-appearance: textfield; /* Firefox */
        appearance: textfield;
    }

    /* Highlight the inputs when they have values > 0 */
    .has-value {
        border-color: #0d6efd;
        background-color: #f0f7ff;
        color: #0d6efd;
    }

    .summary-box {
        background-color: #e7f1ff;
        color: #0c63e4;
        padding: 1rem;
        border-radius: 8px;
        font-size: 0.9rem;
        margin-top: 1rem;
        display: flex;
        align-items: center;
    }

    .reminder-section {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 1.5rem;
        margin-top: 1rem;
        border: 1px solid #dee2e6;
    }
</style>

<div class="form-check form-switch mb-3">
    <input class="form-check-input" type="checkbox" asp-for="RemindMe" id="RemindMe" onchange="toggleReminder()">
    <label class="form-check-label fw-bold" for="RemindMe">Set a Reminder</label>
</div>

<div id="reminderContainer" class="reminder-section" style="display:none;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 text-muted text-uppercase small fw-bold">Reminder Duration</h6>
        <!-- Quick Select Dropdown -->
        <div class="dropdown">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" id="quickSelect" data-bs-toggle="dropdown" aria-expanded="false">
                Quick Presets
            </button>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="quickSelect">
                <li><a class="dropdown-item" href="#" onclick="setDuration(1, 0, 0, 0); return false;">1 Year (Default)</a></li>
                <li><a class="dropdown-item" href="#" onclick="setDuration(0, 6, 0, 0); return false;">6 Months</a></li>
                <li><a class="dropdown-item" href="#" onclick="setDuration(0, 0, 30, 0); return false;">30 Days</a></li>
            </ul>
        </div>
    </div>

    <p class="small text-muted mb-3">
        Reminder will be triggered after this duration from the <strong>Event Date</strong>.
    </p>

    <!-- The Composite Input Grid -->
    <div class="row g-2">
        <!-- Years -->
        <div class="col-3">
            <input type="number" class="form-control duration-input" id="Duration_Years" min="0" value="0" oninput="updateSummary()" placeholder="0">
            <span class="timer-label">Years</span>
        </div>
        <!-- Months -->
        <div class="col-3">
            <input type="number" class="form-control duration-input" id="Duration_Months" min="0" value="0" oninput="updateSummary()" placeholder="0">
            <span class="timer-label">Months</span>
        </div>
        <!-- Days -->
        <div class="col-3">
            <input type="number" class="form-control duration-input" id="Duration_Days" min="0" value="0" oninput="updateSummary()" placeholder="0">
            <span class="timer-label">Days</span>
        </div>
        <!-- Hours -->
        <div class="col-3">
            <input type="number" class="form-control duration-input" id="Duration_Hours" min="0" value="0" oninput="updateSummary()" placeholder="0">
            <span class="timer-label">Hours</span>
        </div>
    </div>

    <!-- Client-side Summary Calculation -->
    <div class="summary-box">
        <i class="bi bi-bell me-3 fs-4"></i>
        <div>
            <strong>Reminder Date:</strong>
            <div id="estimatedDateText">Calculating...</div>
        </div>
    </div>
</div>

<!-- Hidden input to store the calculated TimeSpan string -->
<input type="hidden" asp-for="EventFrequency" id="EventFrequency" />

<script>
    function toggleReminder() {
        const isChecked = document.getElementById('RemindMe').checked;
        const container = document.getElementById('reminderContainer');
        container.style.display = isChecked ? 'block' : 'none';
    }

    function setDuration(y, m, d, h) {
        document.getElementById('Duration_Years').value = y;
        document.getElementById('Duration_Months').value = m;
        document.getElementById('Duration_Days').value = d;
        document.getElementById('Duration_Hours').value = h;
        updateSummary();
    }

    function updateSummary() {
        let eventDateVal = "";
        const dueDateEl = document.getElementById('DueDate');
        const dateEl = document.getElementById('Date');

        if (dueDateEl) eventDateVal = dueDateEl.value;
        else if (dateEl) eventDateVal = dateEl.value;

        if (!eventDateVal) {
            document.getElementById('estimatedDateText').innerText = "Please select an Event Date first.";
            return;
        }

        const years = parseInt(document.getElementById('Duration_Years').value) || 0;
        const months = parseInt(document.getElementById('Duration_Months').value) || 0;
        const days = parseInt(document.getElementById('Duration_Days').value) || 0;
        const hours = parseInt(document.getElementById('Duration_Hours').value) || 0;

        const inputs = ['Duration_Years', 'Duration_Months', 'Duration_Days', 'Duration_Hours'];
        inputs.forEach(id => {
            const el = document.getElementById(id);
            if(parseInt(el.value) > 0) el.classList.add('has-value');
            else el.classList.remove('has-value');
        });

        const baseDate = new Date(eventDateVal + 'T00:00:00');
        const future = new Date(baseDate);

        future.setFullYear(future.getFullYear() + years);
        future.setMonth(future.getMonth() + months);
        future.setDate(future.getDate() + days);
        future.setHours(future.getHours() + hours);

        const options = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' };
        document.getElementById('estimatedDateText').innerText = future.toLocaleDateString("en-US", options);
    }

    function prepareFrequency() {
        const years = parseInt(document.getElementById('Duration_Years').value) || 0;
        const months = parseInt(document.getElementById('Duration_Months').value) || 0;
        const days = parseInt(document.getElementById('Duration_Days').value) || 0;
        const hours = parseInt(document.getElementById('Duration_Hours').value) || 0;

        // Simplified conversion: 1 year = 365 days, 1 month = 30 days
        let totalDays = (years * 365) + (months * 30) + days;

        // Format: d.hh:mm:ss
        const timeSpanString = `${totalDays}.${hours.toString().padStart(2, '0')}:00:00`;
        document.getElementById('EventFrequency').value = timeSpanString;
    }

    // Initialize from existing EventFrequency if present (for Edit/Error scenarios)
    function initDuration() {
        const freq = document.getElementById('EventFrequency').value;
        if (freq) {
            // Parse rudimentary d.hh:mm:ss
            const parts = freq.split('.');
            let days = 0;
            let timePart = "";

            if (parts.length === 2) {
                days = parseInt(parts[0]);
                timePart = parts[1];
            } else if (parts.length === 1 && freq.includes(':')) {
                timePart = parts[0];
            } else {
                 days = parseInt(freq);
            }

            let hours = 0;
            if (timePart) {
                const timeParts = timePart.split(':');
                if (timeParts.length > 0) hours = parseInt(timeParts[0]);
            }

            // Reverse engineer to Years/Months/Days
            const years = Math.floor(days / 365);
            days %= 365;
            const months = Math.floor(days / 30);
            days %= 30;

            document.getElementById('Duration_Years').value = years;
            document.getElementById('Duration_Months').value = months;
            document.getElementById('Duration_Days').value = days;
            document.getElementById('Duration_Hours').value = hours;
        } else {
             // Default to 1 year if empty and RemindMe is checked?
             if (!freq && document.getElementById('RemindMe').checked) {
                 setDuration(1, 0, 0, 0);
             }
        }
        toggleReminder();
        updateSummary();
    }

    // Run on load
    document.addEventListener('DOMContentLoaded', initDuration);
</script>
