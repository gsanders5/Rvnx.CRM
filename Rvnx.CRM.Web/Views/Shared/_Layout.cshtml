@using Microsoft.Extensions.Configuration
@using Rvnx.CRM.Core.DTOs.Contact
@using Rvnx.CRM.Core.Interfaces
@inject IConfiguration Configuration
@inject ICurrentUserService CurrentUserService
@inject IFavoriteService FavoriteService

@{
    var routeController = (ViewContext.RouteData.Values["controller"] as string ?? "Home").ToLowerInvariant();
    string ActiveClass(params string[] controllers) =>
        controllers.Any(c => string.Equals(c, routeController, StringComparison.OrdinalIgnoreCase))
            ? "crm-sidebar-nav-item active"
            : "crm-sidebar-nav-item";

    bool authEnabled = Configuration.GetValue<bool>("Authentication:Enabled");
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;

    List<FavoriteSidebarItemDto> pinnedPeople = new();
    if (authEnabled && isAuthenticated)
    {
        try
        {
            pinnedPeople = await FavoriteService.GetFavoriteSidebarItemsAsync();
        }
        catch
        {
            pinnedPeople = new List<FavoriteSidebarItemDto>();
        }
    }

    string userDisplay = isAuthenticated ? (User.Identity!.Name ?? "Account") : "Guest";
    string userInitials = userDisplay.Length > 0 ? char.ToUpperInvariant(userDisplay[0]).ToString() : "?";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Rvnx CRM</title>
    <script type="importmap"></script>
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" integrity="sha384-3B6NwesSXE7YJlcLI9RpRqGf2p/EgVH8BgoKTaUrmKNDkHPStTQ3EyoYjCGXaOTS" crossorigin="anonymous" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Newsreader:ital,wght@0,400;0,500;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <!-- MDB -->
    <link href="https://cdn.jsdelivr.net/npm/mdb-ui-kit@9.3.0/css/mdb.min.css" rel="stylesheet" integrity="sha384-GpFoyPQNL9Cd/Zc0GujAdo/6oVI34lnXg+7E8+rIhRo1kgxbujqXU1TlKwdc79mI" crossorigin="anonymous" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- EasyMDE CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde@2.20.0/dist/easymde.min.css" integrity="sha384-3AvV7152TgYAMYdGZPqG9BpmSH2ZW6ewTDL0QV5PyNkl19KMI+yLMdJz183N8A2d" crossorigin="anonymous">
    <!-- DataTables CSS -->
    <link href="https://cdn.datatables.net/v/bs5/dt-2.3.7/b-3.2.6/b-colvis-3.2.6/r-3.0.8/sc-2.4.3/datatables.min.css" rel="stylesheet" integrity="sha384-nwKdXO0ejYwD095h00qsKcBWhogVC6HsJnWjWQSLhKe/vnckKhdcnxzXUZ9ZzJQe" crossorigin="anonymous">
    <!-- Select2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" integrity="sha384-OXVF05DQEe311p6ohU11NwlnX08FzMCsyoXzGOaL+83dKAb3qS17yZJxESl8YrJQ" crossorigin="anonymous" />
    <link rel="preload" href="~/logo.svg" as="image" type="image/svg+xml" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Rvnx.CRM.Web.styles.css" asp-append-version="true" />
    <script>
        // Apply theme immediately to avoid flash
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-mdb-theme', savedTheme);
    </script>
</head>
<body>
    <a href="#main-content" class="visually-hidden-focusable position-absolute top-0 start-0 p-3 z-3 bg-primary text-white text-decoration-none rounded-bottom-end">Skip to main content</a>

    <div class="crm-shell" id="crm-shell">
        <aside class="crm-sidebar" aria-label="Primary navigation">
            <a class="crm-sidebar-brand" asp-controller="Home" asp-action="Index" aria-label="Rvnx CRM Home">
                <img src="~/logo.svg" alt="Rvnx CRM" class="brand-logo" />
            </a>

            <div class="crm-eyebrow" style="padding: 0 8px 8px;">Workspace</div>
            <a class="@ActiveClass("Home")" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house" aria-hidden="true"></i> Home
            </a>
            <a class="@ActiveClass("Contacts")" asp-controller="Contacts" asp-action="Index">
                <i class="bi bi-people" aria-hidden="true"></i> People
            </a>
            <a class="@ActiveClass("Calendar")" asp-controller="Calendar" asp-action="Index">
                <i class="bi bi-calendar3" aria-hidden="true"></i> Calendar
            </a>
            <a class="@ActiveClass("Labels")" asp-controller="Labels" asp-action="Index">
                <i class="bi bi-tag" aria-hidden="true"></i> Labels
            </a>
            <a class="@ActiveClass("GroupSettings")" asp-controller="GroupSettings" asp-action="Index">
                <i class="bi bi-sliders" aria-hidden="true"></i> Group Settings
            </a>

            @if (authEnabled && isAuthenticated)
            {
                <div style="height: 18px;"></div>
                <div class="crm-eyebrow" style="padding: 0 8px 8px;">Pinned people</div>
                <div id="crm-pinned-people" data-pinned-people>
                    @await Html.PartialAsync("_PinnedPeople", pinnedPeople)
                </div>
            }

            <div class="crm-sidebar-footer">
                @if (authEnabled && isAuthenticated)
                {
                    <a class="crm-sidebar-footer-avatar" asp-controller="Contacts" asp-action="Self" title="Your profile" aria-label="Your profile" style="text-decoration: none;">
                        @userInitials
                    </a>
                    <div style="flex: 1; min-width: 0; line-height: 1.2;">
                        <div class="crm-sidebar-footer-name text-truncate">@userDisplay</div>
                        <div class="crm-sidebar-footer-meta text-truncate">Signed in</div>
                    </div>
                    <a class="crm-icon-btn" asp-controller="UserSettings" asp-action="Index" title="Settings" aria-label="User settings">
                        <i class="bi bi-gear" aria-hidden="true"></i>
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                        <button type="submit" class="crm-icon-btn" title="Sign out" aria-label="Sign out">
                            <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                        </button>
                    </form>
                }
                else if (authEnabled)
                {
                    <a class="crm-btn-secondary btn-sm" asp-controller="Account" asp-action="Login" style="flex: 1; justify-content: center;">
                        <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i> Sign in
                    </a>
                }
                else
                {
                    <div class="crm-sidebar-footer-avatar" aria-hidden="true">RC</div>
                    <div style="flex: 1; min-width: 0; line-height: 1.2;">
                        <div class="crm-sidebar-footer-name">Local workspace</div>
                        <div class="crm-sidebar-footer-meta">Auth disabled</div>
                    </div>
                }
            </div>
        </aside>

        <div class="crm-sidebar-backdrop" id="crm-sidebar-backdrop" aria-hidden="true"></div>

        <div class="crm-shell-main">
            <header class="crm-topbar" role="banner">
                <button class="crm-sidebar-toggle" id="crm-sidebar-toggle" type="button" aria-label="Open navigation">
                    <i class="bi bi-list" aria-hidden="true"></i>
                </button>
                <div style="flex: 1;"></div>
                <div class="crm-topbar-actions">
                    <button class="crm-icon-btn" id="theme-toggle" type="button" title="Toggle theme" aria-label="Toggle theme">
                        <i class="bi bi-moon-stars-fill" id="theme-icon" aria-hidden="true"></i>
                    </button>
                </div>
            </header>
            <main id="main-content" role="main" tabindex="-1">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" integrity="sha384-1H217gwSVyLSIfaLxHbE7dRb3v4mYCKbpQvzx0cegeju1MVsGrX5xXxAvs/HgeFs" crossorigin="anonymous"></script>
    <!-- MDB -->
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/mdb-ui-kit@9.3.0/js/mdb.umd.min.js" integrity="sha384-wm149nUGAcjSR+VI0SefSbxQhUP3rVwkj4hZieXuXH8w6nibLuWruYYHb8tukbXT" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked@18.0.0/lib/marked.umd.min.js" integrity="sha384-0O19Nsv60FBctDE/IjBtjlSEis4wwUj0Lw1fOc4dfgV/sG2e6M/yMdr7S3egyQ0Y" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/3.0.10/purify.min.js" integrity="sha384-TTNm92HjcHEfjmPmYtFfh24/RLLyFwn7A5XcNX3lw/iCSv0eHXxPI9H9wth3vFOd" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const toggleButton = document.getElementById('theme-toggle');
            const themeIcon = document.getElementById('theme-icon');

            function updateIcon(theme) {
                if (!themeIcon) return;
                if (theme === 'dark') {
                    themeIcon.classList.remove('bi-moon-stars-fill');
                    themeIcon.classList.add('bi-sun-fill');
                } else {
                    themeIcon.classList.remove('bi-sun-fill');
                    themeIcon.classList.add('bi-moon-stars-fill');
                }
            }

            const currentTheme = document.documentElement.getAttribute('data-mdb-theme');
            updateIcon(currentTheme);

            if (toggleButton) {
                toggleButton.addEventListener('click', () => {
                    const currentTheme = document.documentElement.getAttribute('data-mdb-theme');
                    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                    document.documentElement.setAttribute('data-mdb-theme', newTheme);
                    localStorage.setItem('theme', newTheme);
                    updateIcon(newTheme);
                });
            }

            // Mobile sidebar toggle
            const shell = document.getElementById('crm-shell');
            const sidebarToggle = document.getElementById('crm-sidebar-toggle');
            const backdrop = document.getElementById('crm-sidebar-backdrop');
            if (shell && sidebarToggle) {
                sidebarToggle.addEventListener('click', () => {
                    shell.classList.toggle('crm-sidebar-open');
                });
            }
            if (backdrop) {
                backdrop.addEventListener('click', () => {
                    shell.classList.remove('crm-sidebar-open');
                });
            }
        });
    </script>
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/v/bs5/dt-2.3.7/b-3.2.6/b-colvis-3.2.6/r-3.0.8/sc-2.4.3/datatables.min.js" integrity="sha384-6eOoVFZRSk41/xcylba5o06WN5CikrMZCEII2Op2g/d+igf0esL5JAvotvzLC1q1" crossorigin="anonymous"></script>
    <!-- Select2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js" integrity="sha384-d3UHjPdzJkZuk5H3qKYMLRyWLAQBJbby2yr2Q58hXXtAGF8RSNO9jpLDlKKPv5v3" crossorigin="anonymous"></script>
    <!-- EasyMDE JS -->
    <script src="https://cdn.jsdelivr.net/npm/easymde@2.20.0/dist/easymde.min.js" integrity="sha384-YDXeUfPZ4SP6vJpnF+ZMmf4B1bax6yd4Q/aNbkvLidRD843hPG5RE67M0IYT4LOq" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @await Html.PartialAsync("_ConfirmModal")
</body>
</html>
