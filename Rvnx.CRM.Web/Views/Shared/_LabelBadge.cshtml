@using Rvnx.CRM.Core.Extensions
@model Rvnx.CRM.Core.DTOs.Contact.LabelDto

@{
    var bgColor = string.IsNullOrWhiteSpace(Model.Color) ? "#e9ecef" : Model.Color;
    var textColor = ColorContrastHelper.GetContrastTextColor(bgColor);
}
<span class="badge" style="background-color: @bgColor; color: @textColor; border: 1px solid var(--crm-border-subtle);">
    <i class="bi bi-tag-fill me-1" style="opacity: 0.7;"></i>@Model.Name
</span>
