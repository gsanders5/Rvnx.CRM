@model Rvnx.CRM.Core.DTOs.Dates.CreateSignificantDateRequest
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Create Important Date";
}

<form id="significantdate-form" asp-action="Create" data-edit-form>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ContactId" />

    @await Html.PartialAsync("_EditFormHeader", new EditFormHeaderModel
    {
        BackUrl = Url.Action("Index", new { contactId = Model.ContactId })!,
        BackText = "Back",
        SaveText = "Create",
        SaveIcon = "bi-plus-lg",
        Icon = "bi-calendar-event",
        Eyebrow = "Adding important date",
        Title = "New Important Date"
    })

    @* ── Body ───────────────────────────────────────────────────────────── *@
    <div class="crm-edit-body">

        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            @* ── Event ─────────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-calendar-heart" aria-hidden="true"></i> Event</h5>
                </div>
                <div class="crm-card-body">

                    <div class="crm-field-group">
                        <label asp-for="Title">Title</label>
                        <input asp-for="Title" class="crm-input" id="Title" autofocus />
                        <span asp-validation-for="Title" class="crm-field-error"></span>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Date</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    @await Html.PartialAsync("_EventDateField", Model.EventDate)

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Recurrence</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="RecurrenceType">Recurrence Type</label>
                        <select asp-for="RecurrenceType" class="crm-input" id="RecurrenceType">
                            <option value="0">None (One-time)</option>
                            <option value="1">Annual</option>
                            <option value="2">Monthly</option>
                            <option value="3">Custom Interval</option>
                        </select>
                    </div>

                    <div class="crm-field-group" id="customIntervalDiv" style="display: none;">
                        <label asp-for="CustomIntervalDays">Custom Interval (Days)</label>
                        <input asp-for="CustomIntervalDays" class="crm-input" type="number" id="CustomIntervalDays" />
                        <span asp-validation-for="CustomIntervalDays" class="crm-field-error"></span>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Description</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description" class="crm-input" style="height: 100px" id="Description"></textarea>
                        <span asp-validation-for="Description" class="crm-field-error"></span>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Reminders</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <p class="crm-field-help" style="margin-top: 0; margin-bottom: 12px;">Select when you want to be reminded before the event occurs.</p>

                    <div class="crm-check-chip-row">
                        @{
                            var defaultOffsets = new[] { 30, 7, 0 };
                        }
                        @foreach (var days in defaultOffsets)
                        {
                            <label class="crm-check-chip" for="offset_@days">
                                <input type="checkbox" name="ReminderOffsetDays" value="@days" id="offset_@days"
                                       @(Model.ReminderOffsetDays.Contains(days) ? "checked" : "")>
                                <span class="crm-check-chip-label">
                                    @(days == 0 ? "On day of event" : $"{days} days before")
                                </span>
                            </label>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
            {
                FormId = "significantdate-form",
                CancelUrl = Url.Action("Index", new { contactId = Model.ContactId })!,
                CancelIcon = "bi-x-lg",
                SaveText = "Create",
                SaveIcon = "bi-plus-lg"
            })
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var $recurrenceSelect = $('#RecurrenceType');
            var customIntervalDiv = document.getElementById('customIntervalDiv');

            $recurrenceSelect.select2({ width: '100%' });

            function toggleCustomInterval() {
                if ($recurrenceSelect.val() === '3') { // 3 is Custom
                    customIntervalDiv.style.display = 'block';
                } else {
                    customIntervalDiv.style.display = 'none';
                }
            }

            $recurrenceSelect.on('change', toggleCustomInterval);
            toggleCustomInterval(); // Initial check
        });
    </script>
}
