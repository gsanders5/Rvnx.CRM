@model Rvnx.CRM.Core.DTOs.Dates.CreateSignificantDateRequest

@{
    ViewData["Title"] = "Create Important Date";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EntityId"/>
            <input type="hidden" asp-for="EntityType"/>

            <div class="crm-form-card">
                <div class="crm-form-card-header">
                    <h4><i class="bi bi-calendar-heart" aria-hidden="true"></i> Create Important Date</h4>
                </div>

                <div class="crm-form-card-body">

                    <div class="form-floating mb-3">
                        <input asp-for="Title" class="form-control form-control-lg" id="Title" placeholder=" " autofocus/>
                        <label asp-for="Title">Title</label>
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="EventDate" class="form-control" type="date" id="EventDate" placeholder=" "/>
                        <label asp-for="EventDate">Event Date</label>
                        <span asp-validation-for="EventDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check form-switch">
                        <input type="checkbox" class="form-check-input" id="YearUnknownField" />
                        <label class="form-check-label" for="YearUnknownField">Year Unknown</label>
                    </div>

                    <div class="mb-4">
                        <label asp-for="RecurrenceType" class="form-label">Recurrence Type</label>
                        <select asp-for="RecurrenceType" class="form-select" id="RecurrenceType">
                            <option value="0">None (One-time)</option>
                            <option value="1">Annual</option>
                            <option value="2">Monthly</option>
                            <option value="3">Custom Interval</option>
                        </select>
                    </div>

                    <div class="form-floating mb-4" id="customIntervalDiv" style="display: none;">
                        <input asp-for="CustomIntervalDays" class="form-control" type="number" id="CustomIntervalDays" placeholder=" "/>
                        <label asp-for="CustomIntervalDays">Custom Interval (Days)</label>
                        <span asp-validation-for="CustomIntervalDays" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <textarea asp-for="Description" class="form-control" style="height: 100px" id="Description" placeholder=" "></textarea>
                        <label asp-for="Description">Description</label>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <hr class="my-4">

                    <h5>Reminders</h5>
                    <p class="text-muted small mb-3">Select when you want to be reminded before the event occurs.</p>

                    <div class="mb-3">
                        @{
                            var defaultOffsets = new[] { 30, 7, 0 };
                        }
                        @foreach (var days in defaultOffsets)
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" name="ReminderOffsetDays" value="@days" id="offset_@days"
                                       @(Model.ReminderOffsetDays.Contains(days) ? "checked" : "")>
                                <label class="form-check-label" for="offset_@days">
                                    @(days == 0 ? "On day of event" : $"{days} days before")
                                </label>
                            </div>
                        }
                    </div>

                    <div class="d-grid gap-2 d-md-flex mt-4">
                        <button type="submit" class="crm-btn-primary"><i class="bi bi-plus-lg" aria-hidden="true"></i> Create</button>
                        <a asp-action="Index" asp-route-contactId="@Model.EntityId" class="crm-btn-tertiary"><i class="bi bi-x-lg" aria-hidden="true"></i> Cancel</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var $recurrenceSelect = $('#RecurrenceType');
            var customIntervalDiv = document.getElementById('customIntervalDiv');

            $recurrenceSelect.select2({ width: '100%' });

            function toggleCustomInterval() {
                if ($recurrenceSelect.val() === '3') { // 3 is Custom
                    customIntervalDiv.style.display = 'block';
                } else {
                    customIntervalDiv.style.display = 'none';
                }
            }

            $recurrenceSelect.on('change', toggleCustomInterval);
            toggleCustomInterval(); // Initial check

            var eventDateField = document.getElementById('EventDate');
            var yearUnknownField = document.getElementById('YearUnknownField');

            function toggleYearUnknown() {
                if (yearUnknownField.checked) {
                    if (eventDateField.value) {
                        const parts = eventDateField.value.split('-');
                        if (parts.length === 3) {
                            eventDateField.value = '0001-' + parts[1] + '-' + parts[2];
                        }
                    }
                } else {
                    if (eventDateField.value) {
                        const parts = eventDateField.value.split('-');
                        if (parts.length === 3 && parts[0] === '0001') {
                            const currentYear = new Date().getFullYear();
                            eventDateField.value = currentYear + '-' + parts[1] + '-' + parts[2];
                        }
                    }
                }
            }

            if (yearUnknownField) {
                yearUnknownField.addEventListener('change', toggleYearUnknown);
                toggleYearUnknown();
            }
        });
    </script>
}
