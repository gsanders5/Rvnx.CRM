@model DateOnly
@using System.Globalization
@{
    // Year 0001 is the "year unknown" sentinel — e.g. a birthday whose year nobody knows.
    bool yearUnknown = Model.Year == 1;
    string fullValue = yearUnknown ? string.Empty : Model.ToString("yyyy-MM-dd");
}

<div class="crm-field-group" data-event-date>
    <label for="event-date-full">Event Date</label>

    @* Canonical value posted to the server — yyyy-MM-dd, year 0001 means the year is unknown.
       The visible picker and the month/day selects below are name-less, so only this posts. *@
    <input type="hidden" name="EventDate" value="@Model.ToString("yyyy-MM-dd")" data-event-date-value />

    <input type="date" id="event-date-full" class="crm-input" value="@fullValue"
           data-event-date-full hidden="@yearUnknown" />

    <div class="crm-event-date-md" data-event-date-md hidden="@(!yearUnknown)">
        <select class="crm-input" aria-label="Month" data-event-date-month>
            <option value="">Month</option>
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m.ToString("D2")" selected="@(yearUnknown && Model.Month == m)">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
            }
        </select>
        <select class="crm-input" aria-label="Day" data-event-date-day>
            <option value="">Day</option>
            @for (int d = 1; d <= 31; d++)
            {
                <option value="@d.ToString("D2")" selected="@(yearUnknown && Model.Day == d)">@d</option>
            }
        </select>
    </div>

    <span class="crm-field-error" data-valmsg-for="EventDate" data-valmsg-replace="true">@(ViewData.ModelState["EventDate"]?.Errors.FirstOrDefault()?.ErrorMessage)</span>

    <label class="crm-year-toggle">
        <span class="crm-toggle">
            <input type="checkbox" data-event-date-yearunknown aria-label="Year unknown" checked="@yearUnknown" />
            <span class="crm-toggle-track"></span>
            <span class="crm-toggle-knob"></span>
        </span>
        <span>Year unknown</span>
    </label>
</div>
