@model Rvnx.CRM.Core.DTOs.Dates.SignificantDateDto

@{
    ViewData["Title"] = "Edit Important Date";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <form asp-action="Edit" onsubmit="prepareFrequency()">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id"/>
            <input type="hidden" asp-for="EntityId"/>
            <input type="hidden" asp-for="EntityType"/>

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-body-tertiary border-bottom p-3 rounded-top-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Important Date</h4>
                </div>

                <div class="card-body p-4">

                    <div class="form-floating mb-3">
                        <input asp-for="Title" class="form-control form-control-lg" id="Title" placeholder=" "/>
                        <label asp-for="Title">Title</label>
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Date" class="form-control" type="date" onchange="updateSummary()" id="Date" placeholder=" "/>
                        <label asp-for="Date">Date</label>
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <textarea asp-for="Description" class="form-control" style="height: 100px" id="Description" placeholder=" "></textarea>
                        <label asp-for="Description">Description</label>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <hr class="my-4">

                    <!-- Reminder Duration Partial -->
                    <partial name="_ReminderDurationPartial" model="Model"/>

                    <div class="d-grid gap-2 mt-4">
                        <input type="submit" value="Save" class="btn btn-primary btn-lg"/>
                        <a asp-controller="@(Model.EntityType == Rvnx.CRM.Core.Constants.EntityTypes.Person ? "Contacts" : "Home")" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary">Back</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
