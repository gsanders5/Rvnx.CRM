@model Rvnx.CRM.Core.DTOs.Dates.UpdateSignificantDateRequest

@{
    ViewData["Title"] = "Edit Important Date";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id"/>
            <input type="hidden" asp-for="EntityId"/>
            <input type="hidden" asp-for="EntityType"/>

            <div class="crm-form-card">
                <div class="crm-form-card-header">
                    <h4><i class="bi bi-pencil-square" aria-hidden="true"></i> Edit Important Date</h4>
                </div>

                <div class="crm-form-card-body">

                    <div class="form-floating mb-3">
                        <input asp-for="Title" class="form-control form-control-lg" id="Title" placeholder=" "/>
                        <label asp-for="Title">Title</label>
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="EventDate" class="form-control" type="date" id="EventDate" placeholder=" "/>
                        <label asp-for="EventDate">Event Date</label>
                        <span asp-validation-for="EventDate" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check form-switch">
                        <input type="checkbox" class="form-check-input" id="YearUnknownField" @(Model.EventDate.Year == 1 ? "checked" : "") />
                        <label class="form-check-label" for="YearUnknownField">Year Unknown</label>
                    </div>

                    <div class="mb-4">
                        <label asp-for="RecurrenceType" class="form-label">Recurrence Type</label>
                        <select asp-for="RecurrenceType" class="form-select" id="RecurrenceType">
                            <option value="0">None (One-time)</option>
                            <option value="1">Annual</option>
                            <option value="2">Monthly</option>
                            <option value="3">Custom Interval</option>
                        </select>
                    </div>

                    <div class="form-floating mb-4" id="customIntervalDiv" style="display: none;">
                        <input asp-for="CustomIntervalDays" class="form-control" type="number" id="CustomIntervalDays" placeholder=" "/>
                        <label asp-for="CustomIntervalDays">Custom Interval (Days)</label>
                        <span asp-validation-for="CustomIntervalDays" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <textarea asp-for="Description" class="form-control" style="height: 100px" id="Description" placeholder=" "></textarea>
                        <label asp-for="Description">Description</label>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" role="switch" id="IsActive" name="IsActive" value="true" @(Model.IsActive ? "checked" : "")>
                        <label class="form-check-label" for="IsActive">Active</label>
                        <input type="hidden" name="IsActive" value="false"/>
                    </div>

                    <div class="d-grid gap-2 d-md-flex mt-4">
                        <button type="submit" class="crm-btn-primary"><i class="bi bi-save" aria-hidden="true"></i> Save</button>
                        <a asp-action="Index" asp-route-contactId="@Model.EntityId" class="crm-btn-tertiary"><i class="bi bi-x-lg" aria-hidden="true"></i> Cancel</a>
                    </div>
                </div>
            </div>
        </form>

        <div class="crm-card mt-4">
            <div class="crm-card-body">
                <h5>Reminder Offsets</h5>
                <p class="text-muted small">Manage when you are notified before the event.</p>

                <form asp-action="AddOffset" method="post" class="d-flex align-items-center mb-3">
                    <input type="hidden" name="significantDateId" value="@Model.Id"/>
                    <input type="hidden" name="contactId" value="@Model.EntityId"/>
                    <div class="input-group">
                        <input type="number" name="daysBeforeEvent" class="form-control" placeholder="Days before" required min="0"/>
                        <button type="submit" class="crm-btn-secondary">Add</button>
                    </div>
                </form>

                <ul class="list-group">
                    @{
                        var offsets = ViewBag.Offsets as IEnumerable<Rvnx.CRM.Core.DTOs.Dates.ReminderOffsetDto>;
                    }
                    @if (offsets != null)
                    {
                        foreach (var offset in offsets)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @(offset.DaysBeforeEvent == 0 ? "Day of event" : $"{offset.DaysBeforeEvent} days before")
                                <form asp-action="DeleteOffset" method="post" style="display:inline;">
                                    <input type="hidden" name="offsetId" value="@offset.Id"/>
                                    <input type="hidden" name="significantDateId" value="@Model.Id"/>
                                    <input type="hidden" name="contactId" value="@Model.EntityId"/>
                                    <button type="submit" class="crm-icon-btn icon-danger" title="Delete offset" aria-label="Delete reminder offset">
                                        <i class="bi bi-x-lg" aria-hidden="true"></i>
                                    </button>
                                </form>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var $recurrenceSelect = $('#RecurrenceType');
            var customIntervalDiv = document.getElementById('customIntervalDiv');

            $recurrenceSelect.select2({ width: '100%' });

            function toggleCustomInterval() {
                if ($recurrenceSelect.val() === '3') { // 3 is Custom
                    customIntervalDiv.style.display = 'block';
                } else {
                    customIntervalDiv.style.display = 'none';
                }
            }

            $recurrenceSelect.on('change', toggleCustomInterval);
            toggleCustomInterval(); // Initial check

            var eventDateField = document.getElementById('EventDate');
            var yearUnknownField = document.getElementById('YearUnknownField');

            function toggleYearUnknown() {
                if (yearUnknownField.checked) {
                    if (eventDateField.value) {
                        const parts = eventDateField.value.split('-');
                        if (parts.length === 3) {
                            eventDateField.value = '0001-' + parts[1] + '-' + parts[2];
                        }
                    }
                } else {
                    if (eventDateField.value) {
                        const parts = eventDateField.value.split('-');
                        if (parts.length === 3 && parts[0] === '0001') {
                            const currentYear = new Date().getFullYear();
                            eventDateField.value = currentYear + '-' + parts[1] + '-' + parts[2];
                        }
                    }
                }
            }

            if (yearUnknownField) {
                yearUnknownField.addEventListener('change', toggleYearUnknown);
                toggleYearUnknown();
            }
        });
    </script>
}
