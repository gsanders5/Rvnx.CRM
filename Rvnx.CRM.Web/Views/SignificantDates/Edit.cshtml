@model Rvnx.CRM.Core.DTOs.Dates.UpdateSignificantDateRequest
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Edit Important Date";
}

@* ── Action strip ────────────────────────────────────────────────────── *@
<div class="crm-details-actions-strip">
    <a asp-action="Index" asp-route-contactId="@Model.ContactId" class="crm-btn-tertiary btn-sm">
        <i class="bi bi-arrow-left" aria-hidden="true"></i> Back
    </a>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <span class="crm-eyebrow crm-unsaved-indicator" id="unsaved-indicator" hidden>
            <i class="bi bi-circle-fill" aria-hidden="true" style="font-size: 6px; vertical-align: middle; margin-right: 4px;"></i>
            Unsaved
        </span>
        <button type="submit" class="crm-btn-primary btn-sm" form="significantdate-form">
            <i class="bi bi-save" aria-hidden="true"></i> Save
        </button>
    </div>
</div>

@* ── Editorial masthead ─────────────────────────────────────────────── *@
<section class="crm-edit-masthead crm-fade-in">
    <div class="crm-edit-masthead-photo-placeholder" aria-hidden="true">
        <i class="bi bi-calendar-event"></i>
    </div>
    <div>
        <div class="crm-eyebrow" style="margin-bottom: 6px;">Editing important date</div>
        <h1 class="crm-edit-masthead-title">
            @if (!string.IsNullOrWhiteSpace(Model.Title))
            {
                @Model.Title
            }
            else
            {
                <text>Important Date</text>
            }
        </h1>
    </div>
</section>

@* ── Body ───────────────────────────────────────────────────────────── *@
<div class="crm-edit-body">

    <div class="crm-edit-col-main">
        @* The main edit form. AddOffset/DeleteOffset forms must NOT nest inside it,
           so they live in a separate <form> below — connected via HTML5 form="…" attrs
           on the side-column Save button so it still submits this form. *@
        <form id="significantdate-form" asp-action="Edit" data-edit-form>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ContactId" />

            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            @* ── Event ─────────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-pencil-square" aria-hidden="true"></i> Event</h5>
                </div>
                <div class="crm-card-body">

                    <div class="crm-field-group">
                        <label asp-for="Title">Title</label>
                        <input asp-for="Title" class="crm-input" id="Title" />
                        <span asp-validation-for="Title" class="crm-field-error"></span>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Date</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    @await Html.PartialAsync("_EventDateField", Model.EventDate)

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Recurrence</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="RecurrenceType">Recurrence Type</label>
                        <select asp-for="RecurrenceType" class="crm-input" id="RecurrenceType" data-select2>
                            <option value="0">None (One-time)</option>
                            <option value="1">Annual</option>
                            <option value="2">Monthly</option>
                            <option value="3">Custom Interval</option>
                        </select>
                    </div>

                    <div class="crm-field-group" id="customIntervalDiv" style="display: none;">
                        <label asp-for="CustomIntervalDays">Custom Interval (Days)</label>
                        <input asp-for="CustomIntervalDays" class="crm-input" type="number" id="CustomIntervalDays" />
                        <span asp-validation-for="CustomIntervalDays" class="crm-field-error"></span>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Description</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description" class="crm-input" style="height: 100px" id="Description"></textarea>
                        <span asp-validation-for="Description" class="crm-field-error"></span>
                    </div>

                    <div class="crm-toggle-row">
                        <div>
                            <div class="crm-toggle-row-label">Active</div>
                            <div class="crm-toggle-row-desc">Inactive dates are hidden from reminders.</div>
                        </div>
                        <label class="crm-toggle">
                            <input type="checkbox" role="switch" id="IsActive" name="IsActive" value="true" aria-label="Active" @(Model.IsActive ? "checked" : "")>
                            <span class="crm-toggle-track"></span>
                            <span class="crm-toggle-knob"></span>
                        </label>
                    </div>
                    <input type="hidden" name="IsActive" value="false" />
                </div>
            </div>
        </form>

        @* ── Reminders (separate forms — must live outside #significantdate-form) ── *@
        <div class="crm-card">
            <div class="crm-card-header">
                <h5 class="card-title mb-0"><i class="bi bi-bell" aria-hidden="true"></i> Reminder Offsets</h5>
            </div>
            <div class="crm-card-body">
                <p class="crm-field-help" style="margin-top: 0; margin-bottom: 14px;">Manage when you are notified before the event.</p>

                <form asp-action="AddOffset" method="post" class="d-flex align-items-end gap-2" style="margin-bottom: 16px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="significantDateId" value="@Model.Id" />
                    <div class="crm-field-group" style="flex: 1; min-width: 0;">
                        <label for="daysBeforeEvent">Days before event</label>
                        <input type="number" id="daysBeforeEvent" name="daysBeforeEvent" class="crm-input" placeholder="e.g. 7" required min="0" />
                    </div>
                    <button type="submit" class="crm-btn-secondary btn-sm">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i> Add
                    </button>
                </form>

                @{
                    var offsets = ViewBag.Offsets as IEnumerable<Rvnx.CRM.Core.DTOs.Dates.ReminderOffsetDto>;
                }
                @if (offsets != null && offsets.Any())
                {
                    <dl class="crm-deflist">
                        @foreach (var offset in offsets)
                        {
                            <div class="crm-deflist-row" style="grid-template-columns: 1fr auto; padding: 8px 0;">
                                <dd style="margin: 0; font-size: 13px;">
                                    @(offset.DaysBeforeEvent == 0 ? "Day of event" : $"{offset.DaysBeforeEvent} days before")
                                </dd>
                                <form asp-action="DeleteOffset" method="post" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="offsetId" value="@offset.Id" />
                                    <input type="hidden" name="significantDateId" value="@Model.Id" />
                                    <button type="submit" class="crm-icon-btn icon-danger" title="Delete offset" aria-label="Delete reminder offset">
                                        <i class="bi bi-x-lg" aria-hidden="true"></i>
                                    </button>
                                </form>
                            </div>
                        }
                    </dl>
                }
                else
                {
                    <div class="crm-empty py-2">
                        <i class="bi bi-bell-slash" aria-hidden="true"></i>
                        <span>No reminders configured.</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="crm-edit-col-side">
        @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
        {
            FormId = "significantdate-form",
            CancelUrl = Url.Action("Index", new { contactId = Model.ContactId })!,
            CancelIcon = "bi-x-lg"
        })
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var $recurrenceSelect = $('#RecurrenceType');
            var customIntervalDiv = document.getElementById('customIntervalDiv');

            function toggleCustomInterval() {
                if ($recurrenceSelect.val() === '3') { // 3 is Custom
                    customIntervalDiv.style.display = 'block';
                } else {
                    customIntervalDiv.style.display = 'none';
                }
            }

            $recurrenceSelect.on('change', toggleCustomInterval);
            toggleCustomInterval(); // Initial check
        });
    </script>
}
