@model Rvnx.CRM.Core.DTOs.Common.SignificantDateDto

@{
    ViewData["Title"] = "Edit Important Date";
}

<h1>Edit Important Date</h1>

<h4>Important Date</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="EntityId" />
            <input type="hidden" asp-for="EntityType" />

            <div class="form-group">
                <label asp-for="Title" class="control-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Date" class="control-label"></label>
                <input asp-for="Date" class="form-control" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-check mb-3 mt-3">
                <input class="form-check-input" type="checkbox" asp-for="RemindMe" />
                <label class="form-check-label" asp-for="RemindMe"></label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EventFrequency" class="control-label"></label>
                <input asp-for="EventFrequency" class="form-control" type="text" placeholder="d.hh:mm:ss" />
                <span asp-validation-for="EventFrequency" class="text-danger"></span>
                <div class="form-text">TimeSpan format: d.hh:mm:ss (e.g., 365.00:00:00 for one year)</div>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-controller="@(Model.EntityType == Rvnx.CRM.Core.Constants.EntityTypes.Person ? "Contacts" : "Home")" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
