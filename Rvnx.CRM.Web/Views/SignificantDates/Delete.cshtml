@model Rvnx.CRM.Core.DTOs.Dates.SignificantDateDto

@{
    ViewData["Title"] = "Delete Important Date";
}

<h1>Delete Important Date</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Important Date</h4>
    <hr/>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.EventDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EventDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id"/>
        <input type="hidden" name="contactId" value="@Model.EntityId" />
        <input type="submit" value="Delete" class="btn btn-danger"/> |
        <a asp-action="Index" asp-route-contactId="@Model.EntityId" class="btn btn-secondary">Back</a>
    </form>
</div>
