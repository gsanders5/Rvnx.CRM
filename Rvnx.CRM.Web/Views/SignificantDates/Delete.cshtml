@model Rvnx.CRM.Core.DTOs.Dates.SignificantDateDto

@{
    ViewData["Title"] = "Delete Important Date";
}

<h1>Delete Important Date</h1>

<div class="crm-delete-card mt-3">
    <h3>Are you sure you want to delete this?</h3>
    <dl class="row mb-0">
        <dt class="col-sm-2" style="color: var(--crm-text-secondary);">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class="col-sm-2" style="color: var(--crm-text-secondary);">
            @Html.DisplayNameFor(model => model.EventDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.EventDate)
        </dd>
        <dt class="col-sm-2" style="color: var(--crm-text-secondary);">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
    </dl>

    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="Id"/>
        <input type="hidden" name="contactId" value="@Model.EntityId" />
        <div class="d-grid gap-2 d-md-flex">
            <button type="submit" class="crm-btn-danger"><i class="bi bi-trash"></i> Delete</button>
            <a asp-action="Index" asp-route-contactId="@Model.EntityId" class="crm-btn-tertiary"><i class="bi bi-arrow-left"></i> Back</a>
        </div>
    </form>
</div>
