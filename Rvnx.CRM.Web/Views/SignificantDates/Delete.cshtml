@model Rvnx.CRM.Core.DTOs.Dates.SignificantDateDto

@{
    ViewData["Title"] = "Delete Important Date";
}

<div class="crm-details-actions-strip">
    <a asp-action="Index" asp-route-contactId="@Model.ContactId" class="crm-btn-tertiary btn-sm">
        <i class="bi bi-arrow-left" aria-hidden="true"></i> Cancel
    </a>
</div>

<section class="crm-edit-masthead crm-fade-in">
    <div class="crm-edit-masthead-photo-placeholder is-danger" aria-hidden="true">
        <i class="bi bi-trash"></i>
    </div>
    <div>
        <div class="crm-eyebrow is-danger" style="margin-bottom: 6px;">Confirm delete</div>
        <h1 class="crm-edit-masthead-title">
            Delete @(string.IsNullOrWhiteSpace(Model.Title) ? "important date" : Model.Title)?
        </h1>
    </div>
</section>

<div class="crm-page">
    <div class="crm-card crm-delete-card" style="max-width: 720px;">
        <div class="crm-card-body">
            <p class="crm-subtle" style="margin-bottom: 16px;">
                This will permanently delete this important date. This action cannot be undone.
            </p>

            <dl class="crm-deflist">
                <div class="crm-deflist-row">
                    <dt>@Html.DisplayNameFor(model => model.Title)</dt>
                    <dd>@Html.DisplayFor(model => model.Title)</dd>
                </div>
                <div class="crm-deflist-row">
                    <dt>@Html.DisplayNameFor(model => model.EventDate)</dt>
                    <dd>@Html.DisplayFor(model => model.EventDate)</dd>
                </div>
                <div class="crm-deflist-row">
                    <dt>@Html.DisplayNameFor(model => model.Description)</dt>
                    <dd>@Html.DisplayFor(model => model.Description)</dd>
                </div>
            </dl>

            <form asp-action="Delete" method="post" class="d-flex gap-2" style="margin-top: 18px; flex-wrap: wrap;">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input type="hidden" name="contactId" value="@Model.ContactId" />
                <button type="submit" class="crm-btn-danger">
                    <i class="bi bi-trash" aria-hidden="true"></i> Delete
                </button>
                <a asp-action="Index" asp-route-contactId="@Model.ContactId" class="crm-btn-tertiary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>
