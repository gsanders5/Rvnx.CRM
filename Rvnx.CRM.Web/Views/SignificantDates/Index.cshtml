@model IEnumerable<Rvnx.CRM.Core.DTOs.Dates.SignificantDateDto>

@{
    ViewData["Title"] = "Significant Dates";
    Guid contactId = ViewBag.ContactId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-calendar-event me-2"></i>Significant Dates</h2>
    <a asp-action="Create" asp-route-contactId="@contactId" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Add New Date
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 my-5">
        <i class="bi bi-calendar-event display-1 text-muted opacity-25 mb-3"></i>
        <h3 class="h4 text-secondary mt-3">No Significant Dates</h3>
        <p class="text-muted mb-4">No significant dates found for this contact.</p>
        <a asp-action="Create" asp-route-contactId="@contactId" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-plus-lg me-2"></i>Add New Date
        </a>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Date</th>
                            <th>Recurrence</th>
                            <th>Next Occurrence</th>
                            <th>Reminders</th>
                            <th>Status</th>
                            <th class="text-end" style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-medium">@item.Title</td>
                                <td class="align-middle">@item.EventDate.ToShortDateString()</td>
                                <td class="align-middle">
                                    @if (item.RecurrenceType == Rvnx.CRM.Core.Enumerations.RecurrenceType.Custom)
                                    {
                                        <span>Custom (@item.CustomIntervalDays days)</span>
                                    }
                                    else
                                    {
                                        <span>@item.RecurrenceType</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @if (item.NextOccurrence.HasValue)
                                    {
                                        @item.NextOccurrence.Value.ToShortDateString()
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @{
                                        var activeOffsets = item.ReminderOffsets.Where(o => o.IsActive).ToList();
                                    }
                                    @if (activeOffsets.Any())
                                    {
                                        <span class="badge bg-info">@activeOffsets.Count active</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">None</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="align-middle text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Edit" aria-label="Edit @item.Title">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete" aria-label="Delete @item.Title">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="mt-4">
    <a asp-controller="Contacts" asp-action="Details" asp-route-id="@contactId" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Contact
    </a>
</div>
