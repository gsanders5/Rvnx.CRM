@model IEnumerable<Rvnx.CRM.Core.DTOs.Dates.SignificantDateDto>

@{
    ViewData["Title"] = "Significant Dates";
    Guid contactId = ViewBag.ContactId;
}

<div class="crm-page">
    <div class="crm-masthead crm-fade-in">
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 8px;">Important dates</div>
            <h1 class="crm-masthead-title">
                Significant Dates <em>(@Model.Count())</em>
            </h1>
        </div>
        <div class="crm-masthead-actions">
            <a asp-action="Create" asp-route-contactId="@contactId" class="crm-btn-primary btn-sm">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add Date
            </a>
            <a asp-controller="Contacts" asp-action="Details" asp-route-id="@contactId" class="crm-btn-tertiary btn-sm">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Contact
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="crm-card crm-fade-in crm-delay-1" style="padding: 0; overflow: hidden;">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr style="background: var(--crm-surface-secondary);">
                            <th class="crm-eyebrow">Title</th>
                            <th class="crm-eyebrow">Date</th>
                            <th class="crm-eyebrow">Recurrence</th>
                            <th class="crm-eyebrow">Next Occurrence</th>
                            <th class="crm-eyebrow">Reminders</th>
                            <th class="crm-eyebrow">Status</th>
                            <th class="crm-eyebrow text-end" style="width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle fw-medium">@item.Title</td>
                                <td class="align-middle">@item.EventDate.ToEventDateDisplay()</td>
                                <td class="align-middle">
                                    @if (item.RecurrenceType == Rvnx.CRM.Core.Enumerations.RecurrenceType.Custom)
                                    {
                                        <span>Custom (@item.CustomIntervalDays days)</span>
                                    }
                                    else
                                    {
                                        <span>@item.RecurrenceType</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @if (item.NextOccurrence.HasValue)
                                    {
                                        @item.NextOccurrence.Value.ToShortDateString()
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @{
                                        var activeOffsets = item.ReminderOffsets.Where(o => o.IsActive).ToList();
                                    }
                                    @if (activeOffsets.Any())
                                    {
                                        <span class="crm-badge crm-badge-info">@activeOffsets.Count active</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">None</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @if (item.IsActive)
                                    {
                                        <span class="crm-badge crm-badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="crm-badge crm-badge-muted">Inactive</span>
                                    }
                                </td>
                                <td class="align-middle text-end">
                                    <div class="crm-icon-actions">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @item.Title">
                                            <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                        </a>
                                        <button type="button" class="crm-icon-btn icon-danger"
                                                data-confirm-action="@Url.Action("Delete", "SignificantDates", new { id = item.Id, contactId = ViewBag.ContactId })"
                                                data-confirm-title="Delete Important Date"
                                                data-confirm-body="Are you sure you want to delete &quot;@item.Title&quot;?"
                                                data-confirm-remove="tr"
                                                title="Delete" aria-label="Delete @item.Title">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="crm-card crm-fade-in crm-delay-1 text-center" style="padding: 80px 22px;">
            <i class="bi bi-calendar-event display-1 opacity-25 mb-3" style="color: var(--crm-text-tertiary);" aria-hidden="true"></i>
            <h3 class="h4 mt-3" style="color: var(--crm-text-secondary);">No Significant Dates</h3>
            <p class="mb-4" style="color: var(--crm-text-tertiary);">No significant dates found for this contact.</p>
            <a asp-action="Create" asp-route-contactId="@contactId" class="crm-btn-primary">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add New Date
            </a>
        </div>
    }
</div>
