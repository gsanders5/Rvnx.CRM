@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Contact.RelationshipFormViewModel

@{
    ViewData["Title"] = "Edit Relationship";
}

<h1>Edit Relationship for @Model.EntityName</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" id="edit-relationship-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id"/>
            <input type="hidden" asp-for="EntityId"/>
            <input type="hidden" asp-for="EntityType"/>
            <input type="hidden" asp-for="EntityName"/>
            <input type="hidden" asp-for="RelationshipTypeId"/>

            <!-- Hidden input to store the final selection -->
            <input type="hidden" asp-for="SelectedRelationshipType" id="SelectedRelationshipType" />

            <!-- Step 1: Type Selection -->
            <div class="mb-4">
                <label class="form-label fw-bold">Step 1: Choose Relationship Type</label>
                <div class="d-flex flex-wrap gap-2" id="type-selection-container">
                    @foreach (var group in Model.RelationshipTypes.GroupBy(t => t.Category))
                    {
                        <div class="w-100 mt-2 mb-1 text-muted small text-uppercase fw-bold">@group.Key</div>
                        @foreach (var type in group)
                        {
                            <button type="button"
                                    class="btn btn-outline-secondary relationship-type-btn"
                                    data-id="@type.Id"
                                    data-is-symmetric="@type.IsSymmetric.ToString().ToLower()"
                                    data-name="@type.Name"
                                    data-opposite-name="@type.OppositeName">
                                @(type.IsSymmetric ? type.Name : $"{type.Name} / {type.OppositeName}")
                            </button>
                        }
                    }
                </div>
                <span asp-validation-for="SelectedRelationshipType" class="text-danger"></span>
            </div>

            <!-- Step 2: Role Selection (Initially Hidden) -->
            <div class="mb-4" id="role-selection-container" style="display: none;">
                <label class="form-label fw-bold">Step 2: @Model.EntityName is the...</label>
                <div class="btn-group w-100" role="group">
                    <button type="button" class="btn btn-outline-primary role-btn" data-role="Fwd" id="role-fwd-btn">Parent</button>
                    <button type="button" class="btn btn-outline-primary role-btn" data-role="Rev" id="role-rev-btn">Child</button>
                </div>
            </div>

            <div class="form-floating mb-3">
                <select asp-for="RelatedEntityId" class="form-select" asp-items="@(new SelectList(Model.RelatedEntityOptions, "Value", "Text"))">
                    <option value="">-- Select Related Entity --</option>
                </select>
                <label asp-for="RelatedEntityId">Related Entity</label>
                <span asp-validation-for="RelatedEntityId" class="text-danger"></span>
            </div>

            <div class="alert alert-info" id="relationshipPreview" style="display: none;">
                <!-- Preview text will be injected here -->
            </div>

            <div class="form-floating mb-3">
                <input asp-for="StartDate" class="form-control" type="date" id="StartDate" placeholder=" "/>
                <label asp-for="StartDate">StartDate</label>
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="EndDate" class="form-control" type="date" id="EndDate" placeholder=" "/>
                <label asp-for="EndDate">EndDate</label>
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" style="height: 100px" id="Description" placeholder=" "></textarea>
                <label asp-for="Description">Description</label>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2 d-md-flex mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Save</button>
                @if (Model.IsEntityPartial || Model.IsRelatedEntityPartial)
                {
                    <button type="button" class="btn btn-info" data-mdb-modal-init data-mdb-target="#promoteModal">
                        <i class="bi bi-arrow-up-circle me-2"></i>Promote to contact
                    </button>
                }
                @if (Model.EntityType == EntityTypes.Person)
                {
                    <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary">Cancel</a>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                }
            </div>
        </form>
    </div>
</div>

@if (Model.IsEntityPartial || Model.IsRelatedEntityPartial)
{
    <!-- Promote Modal -->
    <div class="modal fade" id="promoteModal" tabindex="-1" aria-labelledby="promoteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="promoteModalLabel">Promote Partial Contact</h5>
                    <button type="button" class="btn-close" data-mdb-ripple-init data-mdb-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to promote this partial contact to a full contact record?</p>
                    <p class="text-muted small">Promoting will make them appear in the main contact directory and allow you to add notes, facts, and other details.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-mdb-ripple-init data-mdb-dismiss="modal">Cancel</button>
                    <form asp-controller="Relationships" asp-action="Promote" asp-route-contactId="@(Model.IsRelatedEntityPartial ? Model.RelatedEntityId : Model.EntityId)" method="post" class="d-inline">
                        <button type="submit" class="btn btn-primary" data-mdb-ripple-init>Yes, Promote</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const entityName = @Html.Raw(Json.Serialize(Model.EntityName));

            // Elements
            const container = document.getElementById('type-selection-container');
            const roleContainer = document.getElementById('role-selection-container');
            const hiddenInput = document.getElementById('SelectedRelationshipType');
            const fwdBtn = document.getElementById('role-fwd-btn');
            const revBtn = document.getElementById('role-rev-btn');
            const preview = document.getElementById('relationshipPreview');
            const relatedInput = document.getElementById('RelatedEntityId');

            let state = {
                typeId: null,
                isSymmetric: false,
                name: '',
                oppositeName: '',
                role: null
            };

            function handleTypeClick(btn) {
                // Update State
                state.typeId = btn.dataset.id;
                state.isSymmetric = btn.dataset.isSymmetric === 'true';
                state.name = btn.dataset.name;
                state.oppositeName = btn.dataset.oppositeName;
                state.role = null;

                // Update UI (Active Class)
                container.querySelectorAll('button').forEach(b => {
                    b.classList.remove('active', 'btn-secondary');
                    b.classList.add('btn-outline-secondary');
                });

                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('active', 'btn-secondary');

                if (state.isSymmetric) {
                    roleContainer.style.display = 'none';
                    state.role = 'Fwd';
                    updateHiddenInput();
                    updatePreview();
                } else {
                    roleContainer.style.display = 'block';
                    fwdBtn.textContent = state.name;
                    revBtn.textContent = state.oppositeName;

                    // Reset Role Buttons
                    fwdBtn.classList.remove('active', 'btn-primary');
                    fwdBtn.classList.add('btn-outline-primary');
                    revBtn.classList.remove('active', 'btn-primary');
                    revBtn.classList.add('btn-outline-primary');

                    hiddenInput.value = '';
                    preview.style.display = 'none';
                }
            }

            function handleRoleClick(role) {
                state.role = role;

                if (role === 'Fwd') {
                    fwdBtn.classList.add('active', 'btn-primary');
                    fwdBtn.classList.remove('btn-outline-primary');
                    revBtn.classList.remove('active', 'btn-primary');
                    revBtn.classList.add('btn-outline-primary');
                } else {
                    revBtn.classList.add('active', 'btn-primary');
                    revBtn.classList.remove('btn-outline-primary');
                    fwdBtn.classList.remove('active', 'btn-primary');
                    fwdBtn.classList.add('btn-outline-primary');
                }

                updateHiddenInput();
                updatePreview();
            }

            function updateHiddenInput() {
                if (state.typeId && state.role) {
                    hiddenInput.value = `${state.typeId}_${state.role}`;
                } else {
                    hiddenInput.value = '';
                }
            }

            function updatePreview() {
                if (!state.typeId || !state.role || !relatedInput.value) {
                    preview.style.display = 'none';
                    return;
                }

                const relatedName = relatedInput.options[relatedInput.selectedIndex].text;

                let relationText = '';
                if (state.isSymmetric) {
                    relationText = state.name;
                } else {
                    relationText = state.role === 'Fwd' ? state.name : state.oppositeName;
                }

                preview.style.display = 'block';
                preview.textContent = '';

                const s1 = document.createElement('strong');
                s1.textContent = entityName;
                preview.appendChild(s1);

                preview.appendChild(document.createTextNode(` is ${relationText} of `));

                const s2 = document.createElement('strong');
                s2.textContent = relatedName;
                preview.appendChild(s2);

                preview.appendChild(document.createTextNode('.'));
            }

            // Initialization logic
            function init() {
                // Event Listeners
                container.querySelectorAll('button').forEach(btn => {
                    btn.addEventListener('click', () => handleTypeClick(btn));
                });

                fwdBtn.addEventListener('click', () => handleRoleClick('Fwd'));
                revBtn.addEventListener('click', () => handleRoleClick('Rev'));
                relatedInput.addEventListener('change', updatePreview);

                // Pre-populate if value exists
                if (hiddenInput.value) {
                    const parts = hiddenInput.value.split('_');
                    if (parts.length === 2) {
                        const typeId = parts[0];
                        const role = parts[1];

                        // Find Type Button
                        const typeBtn = container.querySelector(`button[data-id="${typeId}"]`);
                        if (typeBtn) {
                            // Click it (sets state)
                            typeBtn.click(); // This will trigger handleTypeClick

                            // If Asymmetric, click Role
                            if (roleContainer.style.display !== 'none') {
                                if (role === 'Fwd') fwdBtn.click();
                                else revBtn.click();
                            }
                        }
                    }
                }
            }

            init();
        });
    </script>
}
