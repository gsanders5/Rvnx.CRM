@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Contact.RelationshipFormViewModel

@{
    ViewData["Title"] = "Add Relationship";
}

<h1>Add Relationship for @Model.EntityName</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="crm-alert crm-alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="row">
    <div class="col-md-8">
        <ul class="nav nav-pills mb-4" id="relationshipTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="existing-tab" data-mdb-pill-init data-mdb-target="#existing" type="button" role="tab" aria-controls="existing" aria-selected="true"><i class="bi bi-link" aria-hidden="true"></i> Link Existing Contact</button>
            </li>
            @if (Model.EntityType == EntityTypes.Person)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="new-tab" data-mdb-pill-init data-mdb-target="#new" type="button" role="tab" aria-controls="new" aria-selected="false"><i class="bi bi-person-plus" aria-hidden="true"></i> Create New Partial Contact</button>
                </li>
            }
        </ul>

        <div class="tab-content" id="relationshipTabContent">
            <div class="tab-pane fade show active" id="existing" role="tabpanel" aria-labelledby="existing-tab">
                <form asp-action="Create" id="create-relationship-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="EntityId"/>
                    <input type="hidden" asp-for="EntityType"/>
                    <input type="hidden" asp-for="EntityName"/>

                    <!-- Hidden input to store the final selection -->
                    <input type="hidden" asp-for="SelectedRelationshipType" id="SelectedRelationshipType"/>

                    <!-- Step 1: Type Selection -->
                    <div class="mb-4">
                        <label class="form-label fw-bold">Step 1: Choose Relationship Type</label>

                        <!-- Summary (Initially Hidden) -->
                        <div id="type-selection-summary" class="crm-card mb-2" style="display: none;">
                            <div class="crm-card-body p-2 d-flex justify-content-between align-items-center">
                                <span class="fw-bold" style="color: var(--crm-brand);" id="selected-type-text"></span>
                                <button type="button" class="crm-btn-tertiary btn-sm" id="change-type-btn" aria-label="Change relationship type">
                                    <i class="bi bi-pencil me-1" aria-hidden="true"></i> Change
                                </button>
                            </div>
                        </div>

                        <!-- Collapsible Container -->
                        <div class="collapse show" id="typeSelectionCollapse">
                            <div class="d-flex flex-wrap gap-2" id="type-selection-container">
                                @foreach (var group in Model.RelationshipTypes.GroupBy(t => t.Category))
                                {
                                    <div class="w-100 mt-2 mb-1 text-muted small text-uppercase fw-bold">@group.Key</div>
                                    @foreach (var type in group)
                                    {
                                        <button type="button"
                                                class="crm-btn-secondary relationship-type-btn"
                                                data-id="@type.Id"
                                                data-is-symmetric="@type.IsSymmetric.ToString().ToLower()"
                                                data-name="@type.Name"
                                                data-opposite-name="@type.OppositeName">
                                            @(type.IsSymmetric ? type.Name : $"{type.Name} / {type.OppositeName}")
                                        </button>
                                    }
                                }
                            </div>
                        </div>

                        <!-- Hidden toggle button for programmatic control -->
                        <button class="d-none" type="button" id="typeCollapseToggle" data-mdb-collapse-init data-mdb-target="#typeSelectionCollapse"></button>

                        <span asp-validation-for="SelectedRelationshipType" class="text-danger"></span>
                    </div>

                    <!-- Step 2: Role Selection (Initially Hidden) -->
                    <div class="mb-4" id="role-selection-container" style="display: none;">
                        <label class="form-label fw-bold">Step 2: @Model.EntityName is the...</label>
                        <div class="btn-group w-100" role="group">
                            <button type="button" class="crm-btn-secondary role-btn" data-role="Fwd" id="role-fwd-btn">Parent</button>
                            <button type="button" class="crm-btn-secondary role-btn" data-role="Rev" id="role-rev-btn">Child</button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RelatedEntityId" class="form-label">Related Entity</label>
                        <select asp-for="RelatedEntityId" class="form-select" asp-items="@(new SelectList(Model.RelatedEntityOptions, "Value", "Text"))">
                            <option value="">-- Select Related Entity --</option>
                        </select>
                        <span asp-validation-for="RelatedEntityId" class="text-danger"></span>
                    </div>

                    <div class="crm-alert crm-alert-info" id="relationshipPreview" style="display: none;">
                        <!-- Preview text will be injected here -->
                    </div>

                    <div id="suggestions-container" class="mb-4" style="display: none;">
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="StartDate" class="form-control" type="date" id="StartDate" placeholder=" "/>
                        <label asp-for="StartDate">StartDate</label>
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="EndDate" class="form-control" type="date" id="EndDate" placeholder=" "/>
                        <label asp-for="EndDate">EndDate</label>
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <textarea asp-for="Description" class="form-control" style="height: 100px" id="Description" placeholder=" "></textarea>
                        <label asp-for="Description">Description</label>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2 d-md-flex mt-4">
                        <button type="submit" class="crm-btn-primary"><i class="bi bi-save" aria-hidden="true"></i> Save Relationship</button>
                        @if (Model.EntityType == EntityTypes.Person)
                        {
                            <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="crm-btn-tertiary"><i class="bi bi-x-lg" aria-hidden="true"></i> Cancel</a>
                        }
                        else
                        {
                            <a asp-controller="Home" asp-action="Index" class="crm-btn-tertiary"><i class="bi bi-x-lg" aria-hidden="true"></i> Cancel</a>
                        }
                    </div>
                </form>
            </div>

            @if (Model.EntityType == EntityTypes.Person)
            {
                <div class="tab-pane fade" id="new" role="tabpanel" aria-labelledby="new-tab">
                    <form asp-action="CreatePartial" id="create-partial-form">
                        <input type="hidden" name="entityId" value="@Model.EntityId"/>
                        <input type="hidden" name="entityType" value="@Model.EntityType"/>

                        <!-- Hidden input to store the final selection -->
                        <input type="hidden" name="SelectedRelationshipType" id="SelectedRelationshipTypePartial" required/>

                        <!-- Step 1: Type Selection (Partial) -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">Step 1: Choose Relationship Type</label>

                            <!-- Summary (Initially Hidden) -->
                            <div id="type-selection-summary-partial" class="crm-card mb-2" style="display: none;">
                                <div class="crm-card-body p-2 d-flex justify-content-between align-items-center">
                                    <span class="fw-bold" style="color: var(--crm-brand);" id="selected-type-text-partial"></span>
                                    <button type="button" class="crm-btn-tertiary btn-sm" id="change-type-btn-partial" aria-label="Change partial relationship type">
                                            <i class="bi bi-pencil me-1" aria-hidden="true"></i> Change
                                    </button>
                                </div>
                            </div>

                            <!-- Collapsible Container -->
                            <div class="collapse show" id="typeSelectionCollapsePartial">
                                <div class="d-flex flex-wrap gap-2" id="type-selection-container-partial">
                                    @foreach (var group in Model.RelationshipTypes.GroupBy(t => t.Category))
                                    {
                                        <div class="w-100 mt-2 mb-1 text-muted small text-uppercase fw-bold">@group.Key</div>
                                        @foreach (var type in group)
                                        {
                                            <button type="button"
                                                    class="crm-btn-secondary relationship-type-btn-partial"
                                                    data-id="@type.Id"
                                                    data-is-symmetric="@type.IsSymmetric.ToString().ToLower()"
                                                    data-name="@type.Name"
                                                    data-opposite-name="@type.OppositeName">
                                                @(type.IsSymmetric ? type.Name : $"{type.Name} / {type.OppositeName}")
                                            </button>
                                        }
                                    }
                                </div>
                            </div>

                            <!-- Hidden toggle button -->
                            <button class="d-none" type="button" id="typeCollapseTogglePartial" data-mdb-collapse-init data-mdb-target="#typeSelectionCollapsePartial"></button>
                        </div>

                        <!-- Step 2: Role Selection (Partial - Initially Hidden) -->
                        <div class="mb-4" id="role-selection-container-partial" style="display: none;">
                            <label class="form-label fw-bold">Step 2: @Model.EntityName is the...</label>
                            <div class="btn-group w-100" role="group">
                                <button type="button" class="crm-btn-secondary role-btn-partial" data-role="Fwd" id="role-fwd-btn-partial">Parent</button>
                                <button type="button" class="crm-btn-secondary role-btn-partial" data-role="Rev" id="role-rev-btn-partial">Child</button>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-floating mb-3">
                                <input id="PartialContactFirstName" name="PartialContactFirstName" type="text" class="form-control" placeholder=" " required/>
                                <label for="PartialContactFirstName" class="ms-2">First Name (Required)</label>
                            </div>
                            <div class="col-md-6 form-floating mb-3">
                                <input id="PartialContactLastName" name="PartialContactLastName" type="text" class="form-control" placeholder=" "/>
                                <label for="PartialContactLastName" class="ms-2">Last Name</label>
                            </div>
                        </div>

                        <div class="crm-alert crm-alert-info" id="relationshipPreviewPartial" style="display: none;">
                            <!-- Preview text will be injected here -->
                        </div>

                        <div id="suggestions-container-partial" class="mb-4" style="display: none;">
                        </div>

                        <div class="form-floating mb-3">
                            <input id="Birthday" name="Birthday" type="date" class="form-control" placeholder=" "/>
                            <label for="Birthday">Birthday</label>
                            <div class="form-text mt-1 text-muted"><i class="bi bi-info-circle" aria-hidden="true"></i> Entering a birthday will automatically add a yearly reminder for this person.</div>
                        </div>

                        <div class="form-floating mb-3">
                            <textarea id="DescriptionPartial" name="Description" class="form-control" style="height: 100px" placeholder=" "></textarea>
                            <label for="DescriptionPartial">Details about this relationship</label>
                        </div>

                        <div class="d-grid gap-2 d-md-flex mt-4">
                            <button type="submit" class="crm-btn-primary"><i class="bi bi-save" aria-hidden="true"></i> Save Partial Contact</button>
                            <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="crm-btn-tertiary"><i class="bi bi-x-lg" aria-hidden="true"></i> Cancel</a>
                        </div>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $(document).ready(function() {
            $('#RelatedEntityId').select2({ width: '100%' });
        });

        document.addEventListener('DOMContentLoaded', function() {
            class RelationshipSelector {
                constructor(config) {
                    this.container = document.getElementById(config.containerId);
                    this.roleContainer = document.getElementById(config.roleContainerId);
                    this.hiddenInput = document.getElementById(config.hiddenInputId);
                    this.fwdBtn = document.getElementById(config.fwdBtnId);
                    this.revBtn = document.getElementById(config.revBtnId);
                    this.preview = document.getElementById(config.previewId);
                    this.suggestionsContainer = document.getElementById(config.suggestionsContainerId);
                    this.relatedInput = document.getElementById(config.relatedInputId); // Select or Text Input
                    this.relatedInput2 = document.getElementById(config.relatedInputId2); // Optional second input (lastname)

                    this.summaryContainer = document.getElementById(config.summaryId);
                    this.summaryText = document.getElementById(config.summaryTextId);
                    this.changeBtn = document.getElementById(config.changeBtnId);
                    this.toggleBtn = document.getElementById(config.toggleBtnId);
                    this.collapseEl = document.getElementById(config.collapseId);

                    this.entityName = config.entityName;
                    this.isPartialForm = config.isPartialForm || false;

                    this.state = {
                        typeId: null,
                        isSymmetric: false,
                        name: '',
                        oppositeName: '',
                        role: null // 'Fwd' or 'Rev'
                    };

                    this.init();
                }

                init() {
                    if (!this.container) return; // Guard clause

                    const typeBtns = this.container.querySelectorAll('button');
                    typeBtns.forEach(btn => {
                        btn.addEventListener('click', () => this.handleTypeClick(btn));
                    });

                    if (this.fwdBtn) this.fwdBtn.addEventListener('click', () => this.handleRoleClick('Fwd'));
                    if (this.revBtn) this.revBtn.addEventListener('click', () => this.handleRoleClick('Rev'));

                    if (this.changeBtn) this.changeBtn.addEventListener('click', () => this.handleChangeClick());

                    if (this.relatedInput) {
                        this.relatedInput.addEventListener(this.isPartialForm ? 'input' : 'change', () => this.updatePreview());
                        if (!this.isPartialForm) {
                            // Select2 triggers a custom 'change' event when a selection is made
                            $(this.relatedInput).on('change', () => this.updatePreview());
                        }
                    }
                    if (this.relatedInput2) {
                        this.relatedInput2.addEventListener('input', () => this.updatePreview());
                    }

                    if (this.hiddenInput && this.hiddenInput.value) {
                         const parts = this.hiddenInput.value.split('_');
                         if (parts.length === 2) {
                             const typeId = parts[0];
                             const role = parts[1];

                             const typeBtn = this.container.querySelector(`button[data-id="${typeId}"]`);
                             if (typeBtn) {
                                 this.handleTypeClick(typeBtn);
                                 if (!this.state.isSymmetric) {
                                     this.handleRoleClick(role);
                                 }
                             }
                         }
                    }
                }

                handleTypeClick(btn) {
                    this.state.typeId = btn.dataset.id;
                    this.state.isSymmetric = btn.dataset.isSymmetric === 'true';
                    this.state.name = btn.dataset.name;
                    this.state.oppositeName = btn.dataset.oppositeName;
                    this.state.role = null; // Reset role on type change

                    this.container.querySelectorAll('button').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');

                    const typeLabel = this.state.isSymmetric ? this.state.name : `${this.state.name} / ${this.state.oppositeName}`;
                    this.summaryText.textContent = typeLabel;
                    this.summaryContainer.style.display = 'block'; // Show summary

                    if (this.collapseEl.classList.contains('show')) {
                        this.toggleBtn.click();
                    }

                    if (this.state.isSymmetric) {
                        this.roleContainer.style.display = 'none';
                        this.state.role = 'Fwd'; // Symmetric defaults to Fwd
                        this.updateHiddenInput();
                        this.updatePreview();
                    } else {
                        this.roleContainer.style.display = 'block';
                        this.fwdBtn.textContent = this.state.name;
                        this.revBtn.textContent = this.state.oppositeName;

                        this.fwdBtn.classList.remove('active');
                        this.revBtn.classList.remove('active');

                        this.hiddenInput.value = ''; // Clear selection until role picked
                        this.preview.style.display = 'none';
                    }
                }

                handleChangeClick() {
                    this.summaryContainer.style.display = 'none';
                    if (!this.collapseEl.classList.contains('show')) {
                        this.toggleBtn.click();
                    }
                }

                handleRoleClick(role) {
                    this.state.role = role;

                    if (role === 'Fwd') {
                        this.fwdBtn.classList.add('active');
                        this.revBtn.classList.remove('active');
                    } else {
                        this.revBtn.classList.add('active');
                        this.fwdBtn.classList.remove('active');
                    }

                    this.updateHiddenInput();
                    this.updatePreview();
                }

                updateHiddenInput() {
                    if (this.state.typeId && this.state.role) {
                        this.hiddenInput.value = `${this.state.typeId}_${this.state.role}`;
                    } else {
                        this.hiddenInput.value = '';
                    }
                }

                updatePreview() {
                    if (!this.state.typeId || !this.state.role) {
                        this.preview.style.display = 'none';
                        return;
                    }

                    let relatedName = '';
                    if (this.isPartialForm) {
                        const first = this.relatedInput.value;
                        const last = this.relatedInput2 ? this.relatedInput2.value : '';
                        if (!first) {
                            this.preview.style.display = 'none';
                            return;
                        }
                        relatedName = (first + ' ' + last).trim();
                    } else {
                        if (!this.relatedInput.value) {
                             this.preview.style.display = 'none';
                             return;
                        }
                        relatedName = this.relatedInput.options[this.relatedInput.selectedIndex].text;
                    }

                    let relationText = '';
                    if (this.state.isSymmetric) {
                        relationText = this.state.name;
                    } else {
                        relationText = this.state.role === 'Fwd' ? this.state.name : this.state.oppositeName;
                    }

                    this.preview.style.display = 'block';
                    this.preview.textContent = '';

                    const s1 = document.createElement('strong');
                    s1.textContent = this.entityName;
                    this.preview.appendChild(s1);

                    this.preview.appendChild(document.createTextNode(` is ${relationText} of `));

                    const s2 = document.createElement('strong');
                    s2.textContent = relatedName;
                    this.preview.appendChild(s2);

                    this.preview.appendChild(document.createTextNode('.'));

                    this.fetchSuggestions(relatedName);
                }

                async fetchSuggestions(relatedName) {
                    if (!this.suggestionsContainer) return;

                    const entityId = '@Model.EntityId';
                    let url = `/Relationships/GetSuggestions?entityId=${entityId}&relationshipType=${this.hiddenInput.value}`;

                    if (this.isPartialForm) {
                        url += `&partialContactName=${encodeURIComponent(relatedName)}`;
                    } else {
                        const relatedId = this.relatedInput.value;
                        if (!relatedId) {
                            this.suggestionsContainer.style.display = 'none';
                            return;
                        }
                        url += `&relatedEntityId=${relatedId}`;
                    }

                    try {
                        const response = await fetch(url);
                        if (!response.ok) throw new Error('Network response was not ok');
                        const data = await response.json();

                        this.suggestionsContainer.innerHTML = '';

                        if (data && data.length > 0) {
                            const card = document.createElement('div');
                            card.className = 'card bg-primary-subtle border-primary border-opacity-25 mb-3 shadow-none';

                            const cardBody = document.createElement('div');
                            cardBody.className = 'card-body p-3';

                            const header = document.createElement('h6');
                            header.className = 'card-title text-primary d-flex align-items-center mb-2';
                            header.innerHTML = '<i class="bi bi-magic me-2 fs-5" aria-hidden="true"></i> Suggested Connections';
                            cardBody.appendChild(header);

                            const desc = document.createElement('p');
                            desc.className = 'small text-muted mb-3';
                            desc.textContent = 'Based on the relationship network, we found some other connections you might want to establish:';
                            cardBody.appendChild(desc);

                            const listGroup = document.createElement('div');
                            listGroup.className = 'list-group list-group-flush border-top border-primary border-opacity-10';

                            data.forEach((sugg, index) => {
                                const listItem = document.createElement('div');
                                listItem.className = 'list-group-item bg-transparent px-0 py-2 border-primary border-opacity-10';

                                const switchDiv = document.createElement('div');
                                switchDiv.className = 'form-check form-switch d-flex align-items-center mb-0';

                                const input = document.createElement('input');
                                input.className = 'form-check-input fs-5 me-3';
                                input.type = 'checkbox';
                                input.role = 'switch';
                                input.name = 'SuggestedRelationships';
                                input.value = sugg.payload;
                                // Sanitize the payload for ID use
                                const safeId = sugg.payload.replace(/[^a-zA-Z0-9]/g, '_');
                                input.id = `sugg_${safeId}_${index}`;

                                const label = document.createElement('label');
                                label.className = 'form-check-label pt-1';
                                label.htmlFor = input.id;

                                label.appendChild(document.createTextNode('Set '));
                                const strong1 = document.createElement('strong');
                                strong1.textContent = sugg.sourceName;
                                label.appendChild(strong1);

                                label.appendChild(document.createTextNode(' as '));
                                const strong2 = document.createElement('strong');
                                strong2.textContent = sugg.relationshipName;
                                label.appendChild(strong2);

                                label.appendChild(document.createTextNode(' of '));
                                const strong3 = document.createElement('strong');
                                strong3.textContent = sugg.targetName;
                                label.appendChild(strong3);

                                switchDiv.appendChild(input);
                                switchDiv.appendChild(label);
                                listItem.appendChild(switchDiv);
                                listGroup.appendChild(listItem);
                            });

                            cardBody.appendChild(listGroup);
                            card.appendChild(cardBody);
                            this.suggestionsContainer.appendChild(card);

                            this.suggestionsContainer.style.display = 'block';
                        } else {
                            this.suggestionsContainer.style.display = 'none';
                        }
                    } catch (error) {
                        console.error('Error fetching suggestions:', error);
                        this.suggestionsContainer.style.display = 'none';
                    }
                }
            }

            const entityName = @Json.Serialize(Model.EntityName);

            new RelationshipSelector({
                containerId: 'type-selection-container',
                roleContainerId: 'role-selection-container',
                hiddenInputId: 'SelectedRelationshipType',
                fwdBtnId: 'role-fwd-btn',
                revBtnId: 'role-rev-btn',
                previewId: 'relationshipPreview',
                suggestionsContainerId: 'suggestions-container',
                relatedInputId: 'RelatedEntityId',

                collapseId: 'typeSelectionCollapse',
                summaryId: 'type-selection-summary',
                summaryTextId: 'selected-type-text',
                changeBtnId: 'change-type-btn',
                toggleBtnId: 'typeCollapseToggle',

                entityName: entityName,
                isPartialForm: false
            });

            if (document.getElementById('type-selection-container-partial')) {
                new RelationshipSelector({
                    containerId: 'type-selection-container-partial',
                    roleContainerId: 'role-selection-container-partial',
                    hiddenInputId: 'SelectedRelationshipTypePartial',
                    fwdBtnId: 'role-fwd-btn-partial',
                    revBtnId: 'role-rev-btn-partial',
                    previewId: 'relationshipPreviewPartial',
                    suggestionsContainerId: 'suggestions-container-partial',
                    relatedInputId: 'PartialContactFirstName',
                    relatedInputId2: 'PartialContactLastName',

                    collapseId: 'typeSelectionCollapsePartial',
                    summaryId: 'type-selection-summary-partial',
                    summaryTextId: 'selected-type-text-partial',
                    changeBtnId: 'change-type-btn-partial',
                    toggleBtnId: 'typeCollapseTogglePartial',

                    entityName: entityName,
                    isPartialForm: true
                });
            }
        });
    </script>
}
