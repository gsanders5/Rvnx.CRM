@model Rvnx.CRM.Core.Models.Contact.Relationship

@{
    ViewData["Title"] = "Delete Relationship";
}

<h1>Delete Relationship</h1>

<h3>Are you sure you want to delete this relationship?</h3>
<div>
    <h4>Relationship</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Person
        </dt>
        <dd class = "col-sm-10">
            @Model.Person?.FullName
        </dd>
        <dt class = "col-sm-2">
            Related Person
        </dt>
        <dd class = "col-sm-10">
            @Model.RelatedPerson?.FullName
        </dd>
        <dt class = "col-sm-2">
            Type
        </dt>
        <dd class = "col-sm-10">
            @Model.RelationshipType?.Name
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.PersonId">Cancel</a>
    </form>
</div>
