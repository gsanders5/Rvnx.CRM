@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Contact.RelationshipDeleteViewModel

@{
    ViewData["Title"] = "Delete Relationship";
}

<h1>Delete Relationship</h1>

<h3>Are you sure you want to delete this relationship?</h3>
<div>
    <h4>Relationship</h4>
    <hr/>
    <dl class="row">
        <dt class="col-sm-2">
            Related Entity
        </dt>
        <dd class="col-sm-10">
            @Model.RelatedEntityName
        </dd>
        <dt class="col-sm-2">
            Relationship Type
        </dt>
        <dd class="col-sm-10">
            @Model.RelationshipTypeName
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id"/>
        <input type="submit" value="Delete" class="btn btn-danger"/> |
        @if (Model.EntityType == EntityTypes.Person)
        {
            <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId">Cancel</a>
        }
        else
        {
            <a asp-controller="Home" asp-action="Index">Cancel</a>
        }
    </form>
</div>
