@model Rvnx.CRM.Core.DTOs.Contact.ContactTaskFormDto
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Add Task";
}

<form id="task-form" asp-action="Create" data-edit-form>
    @Html.AntiForgeryToken()
    <input asp-for="ContactId" type="hidden" />

    @await Html.PartialAsync("_EditFormHeader", new EditFormHeaderModel
    {
        BackUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!,
        Icon = "bi-check2-square",
        Eyebrow = "Adding task",
        Title = "New task"
    })

    <div class="crm-edit-body">
        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-check2-square" aria-hidden="true"></i> Details</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-field-group">
                        <label asp-for="Title">Title *</label>
                        <input asp-for="Title" class="crm-input" id="Title" autofocus />
                        <span asp-validation-for="Title" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="DueDate">Due Date *</label>
                        <input asp-for="DueDate" type="date" class="crm-input" id="DueDate" required />
                        <span asp-validation-for="DueDate" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description" class="crm-input" id="Description" placeholder="Notes about this task..."></textarea>
                        <span asp-validation-for="Description" class="crm-field-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
            {
                FormId = "task-form",
                CancelUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!
            })
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @{ await Html.RenderPartialAsync("_EasyMDEScripts"); }
}
