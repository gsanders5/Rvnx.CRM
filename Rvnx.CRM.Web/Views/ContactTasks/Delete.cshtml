@model Rvnx.CRM.Core.DTOs.Contact.ContactTaskDto

@{
    ViewData["Title"] = "Delete Task";
}

<h1>Delete Task</h1>

<h3>Are you sure you want to delete this task?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>
        <dt class="col-sm-2">Due Date</dt>
        <dd class="col-sm-10">@Model.DueDate.ToString("MMMM d, yyyy")</dd>
        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@(Model.IsCompleted ? "Completed" : "Pending")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id"/>
        <div class="d-grid gap-2 d-md-flex mt-4">
            <button type="submit" class="crm-btn-danger"><i class="bi bi-trash"></i>Delete</button>
            <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="crm-btn-tertiary"><i class="bi bi-arrow-left"></i>Cancel</a>
        </div>
    </form>
</div>
