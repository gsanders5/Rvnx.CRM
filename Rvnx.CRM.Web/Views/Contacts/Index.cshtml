@model Rvnx.CRM.Core.DTOs.Contact.ContactIndexViewModel

@{
    ViewData["Title"] = "Contacts";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-3">
    <h1>Contacts</h1>
    <div class="d-flex flex-wrap gap-2 mt-3 mt-md-0">
        @if (Context.Request.Query["showHidden"] == "True")
        {
            <a asp-action="Index" asp-route-showHidden="False" class="btn btn-outline-secondary">Hide Hidden</a>
        }
        else
        {
            <a asp-action="Index" asp-route-showHidden="True" class="btn btn-outline-secondary">View Hidden</a>
        }
        <a asp-action="Import" class="btn btn-outline-primary"><i class="fa-solid fa-file-import"></i> Import VCF</a>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Create New</a>
    </div>
</div>

@if (Model.SuccessMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Contacts.Any())
{
    <div class="table-responsive">
        <table id="contacts-table" class="table table-striped table-hover align-middle" style="width: 100%;">
            <thead>
                <tr>
                    <th scope="col" class="col-photo">Photo</th>
                    <th scope="col">Name</th>
                    <th scope="col">Company</th>
                    <th scope="col">Job Title</th>
                    <th scope="col" class="default-hidden">Created</th>
                    <th scope="col" class="default-hidden">Pronouns</th>
                    <th scope="col" class="default-hidden">Gender</th>
                    <th scope="col" class="default-hidden">Religion</th>
                    <th scope="col" class="default-hidden">Last Changed</th>
                    <th scope="col" class="no-sort col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Contacts)
            {
                <tr>
                    <td data-order="@(item.ProfileImageId.HasValue ? 1 : 0)">
                        <div class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            @if (item.ProfileImageId.HasValue)
                            {
                                <img src="@Url.Action("View", "Attachments", new { id = item.ProfileImageId })" class="rounded-circle" width="40" height="40" alt="@item.FullName" style="object-fit: cover;" loading="lazy" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                    <i class="bi bi-person-fill" aria-hidden="true"></i>
                                </div>
                            }
                        </div>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none">
                            @item.FullName
                        </a>
                        @if (item.IsHidden)
                        {
                            <span class="badge bg-secondary ms-2" title="Hidden">
                                <i class="bi bi-eye-slash"></i>
                            </span>
                        }
                        @if (item.Labels != null && item.Labels.Any())
                        {
                            <div class="mt-1 d-flex gap-1 flex-wrap">
                                @foreach (var label in item.Labels)
                                {
                                    @await Html.PartialAsync("_LabelBadge", label)
                                }
                            </div>
                        }
                    </td>
                    <td>@item.Company</td>
                    <td>@item.JobTitle</td>
                    <td>@item.CreatedDate.ToShortDateString()</td>
                    <td>@item.Pronouns</td>
                    <td>@item.Gender</td>
                    <td>@item.Religion</td>
                    <td>@item.LastChangedDate.ToShortDateString()</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Edit" aria-label="Edit @item.FullName">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Details" aria-label="Details for @item.FullName">
                                <i class="bi bi-info-circle"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete" aria-label="Delete @item.FullName">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5 my-5">
        <i class="bi bi-person-rolodex display-1 text-muted opacity-25 mb-3"></i>
        <h3 class="h4 text-secondary mt-3">No contacts found</h3>
        <p class="text-muted mb-4">
            @(Context.Request.Query["showHidden"] == "True"
                ? "There are no hidden contacts at the moment."
                : "Get started by adding your first contact to the system.")
        </p>
        <a asp-action="Create" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-plus-lg me-2"></i>Create Contact
        </a>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#contacts-table').DataTable({
                paging: true,
                pageLength: 25,
                order: [[1, 'asc']],
                info: false,
                ordering: true,
                searching: true,
                searchDelay: 300,
                autoWidth: false,
                layout: {
                    topStart: 'pageLength',
                    topEnd: {
                        search: { placeholder: 'Search contacts...' },
                        buttons: [
                            {
                                extend: 'colvis',
                                text: '<i class="bi bi-layout-three-columns"></i>',
                                titleAttr: 'Choose columns'
                            }
                        ]
                    }
                },
                columnDefs: [
                    { orderable: false, targets: 'no-sort' },
                    { visible: false, targets: 'default-hidden' },
                    { width: '60px', targets: 'col-photo' },
                    { width: '120px', targets: 'col-actions' }
                ],
                language: {
                    search: ''
                }
            });
        });
    </script>
}
