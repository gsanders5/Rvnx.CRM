@model IEnumerable<Rvnx.CRM.Core.DTOs.Contact.ContactDto>

@{
    ViewData["Title"] = "Contacts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Contacts</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Create New</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th style="width: 60px;">Photo</th>
                <th>Name</th>
                <th>Company</th>
                <th>Job Title</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ProfileImageBase64))
                        {
                            <img src="data:@item.ProfileImageContentType;base64,@item.ProfileImageBase64" class="rounded-circle" width="40" height="40" alt="@item.FullName" style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-person-fill"></i>
                            </div>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none">
                            @item.FullName
                        </a>
                    </td>
                    <td>@item.Company</td>
                    <td>@item.JobTitle</td>
                    <td>@item.CreatedDate.ToShortDateString()</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary" title="Edit"><i class="bi bi-pencil-square"></i></a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Details"><i class="bi bi-info-circle"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No contacts found. Click "Create New" to add one.
    </div>
}
