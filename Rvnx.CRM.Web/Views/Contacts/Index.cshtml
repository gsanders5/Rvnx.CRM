@model Rvnx.CRM.Web.ViewModels.Contact.ContactIndexViewModel

@{
    ViewData["Title"] = "Contacts";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-3">
    <h1>Contacts</h1>
    <div class="d-flex flex-wrap gap-2 mt-3 mt-md-0">
        @if (Context.Request.Query["showHidden"] == "True")
        {
            <a asp-action="Index" asp-route-showHidden="False" class="crm-btn-tertiary btn-sm">Hide Hidden</a>
        }
        else
        {
            <a asp-action="Index" asp-route-showHidden="True" class="crm-btn-tertiary btn-sm">View Hidden</a>
        }
        <a asp-action="Import" class="crm-btn-secondary btn-sm"><i class="fa-solid fa-file-import" aria-hidden="true"></i> Import VCF</a>
        <a asp-action="Create" class="crm-btn-primary btn-sm"><i class="bi bi-plus-lg" aria-hidden="true"></i> Create New</a>
    </div>
</div>

@Html.AntiForgeryToken()

@if (Model.SuccessMessage != null)
{
    <div class="alert alert-dismissible fade show" role="alert" style="background-color: rgba(45, 198, 83, 0.1); color: var(--crm-success); border: 1px solid rgba(45, 198, 83, 0.2); border-radius: var(--crm-radius-sm);">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Contacts.Any())
{
        <table id="contacts-table" class="table table-striped table-hover align-middle" style="width: 100%; visibility: hidden;">
            <thead>
            <tr>
                <th scope="col" class="col-photo">Photo</th>
                <th scope="col">Name</th>
                <th scope="col">Company</th>
                <th scope="col">Job Title</th>
                <th scope="col" class="default-hidden">Maiden Name</th>
                <th scope="col" class="default-hidden">Created</th>
                <th scope="col" class="default-hidden">Pronouns</th>
                <th scope="col" class="default-hidden">Gender</th>
                <th scope="col" class="default-hidden">Religion</th>
                <th scope="col" class="default-hidden">Last Changed</th>
                <th scope="col" class="default-hidden">Last Changed By</th>
                <th scope="col" class="default-hidden">Birthday</th>
                <th scope="col" class="no-sort col-actions">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Contacts)
            {
                <tr>
                    <td data-order="@(item.ProfileImageId.HasValue ? 1 : 0)">
                        <a asp-action="Details" asp-route-id="@item.Id" class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            @if (item.ProfileImageId.HasValue)
                            {
                                <img src="@Url.Action("Thumbnail", "Attachments", new { id = item.ProfileImageId, maxWidth = 80, maxHeight = 80 })" class="crm-avatar" width="40" height="40" alt="@item.FullName" loading="lazy" />
                            }
                            else
                            {
                                <div class="crm-avatar-placeholder">
                                    <i class="bi bi-person-fill" aria-hidden="true"></i>
                                </div>
                            }
                        </a>
                    </td>
                    <td data-order="@(item.IsFavorite ? "0" : "1") @item.FullName">
                        <a asp-action="Details" asp-route-id="@item.Id" class="fw-semibold text-decoration-none" style="color: var(--crm-text-primary);">
                            @item.FullName
                        </a>
                        @if (item.IsHidden)
                        {
                            <span class="crm-badge crm-badge-muted ms-2" title="Hidden">
                                <i class="bi bi-eye-slash" aria-hidden="true"></i>
                            </span>
                        }
                        @if (item.Labels != null && item.Labels.Any())
                        {
                            <div class="mt-1 d-flex gap-1 flex-wrap">
                                @foreach (var label in item.Labels)
                                {
                                    @await Html.PartialAsync("_LabelBadge", label)
                                }
                            </div>
                        }
                    </td>
                    <td>@item.Company</td>
                    <td>@item.JobTitle</td>
                    <td>@item.MaidenName</td>
                    <td>@item.CreatedDate.ToShortDateString()</td>
                    <td>@item.Pronouns</td>
                    <td>@item.Gender</td>
                    <td>@item.Religion</td>
                    <td>@item.LastChangedDate.ToShortDateString()</td>
                    <td>@item.LastChangedBy</td>
                    <td data-order="@(item.Birthday.HasValue ? item.Birthday.Value.ToString("yyyy-MM-dd") : "")">
                        @(item.Birthday.HasValue ? item.Birthday.Value.ToShortDateString() : "—")
                    </td>
                    <td>
                        <div class="crm-icon-actions">
                            <button type="button"
                                    class="crm-icon-btn btn-favorite"
                                    style="color: @(item.IsFavorite ? "var(--crm-warning)" : "var(--crm-text-tertiary)");"
                                    title="@(item.IsFavorite ? "Remove from favorites" : "Add to favorites")"
                                    aria-label="@(item.IsFavorite ? "Remove" : "Add") @item.FullName @(item.IsFavorite ? "from" : "to") favorites"
                                    data-contact-id="@item.Id"
                                    data-contact-name="@item.FullName"
                                    data-is-favorite="@item.IsFavorite.ToString().ToLower()">
                                <i class="bi @(item.IsFavorite ? "bi-star-fill" : "bi-star")" aria-hidden="true"></i>
                            </button>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @item.FullName">
                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="crm-icon-btn" style="color: var(--crm-info);" title="Details" aria-label="Details for @item.FullName">
                                <i class="bi bi-info-circle" aria-hidden="true"></i>
                            </a>
                            <button type="button"
                                    class="crm-icon-btn icon-danger"
                                    title="Delete"
                                    aria-label="Delete @item.FullName"
                                    data-confirm-action="@Url.Action("Delete", new { id = item.Id })"
                                    data-confirm-title="Delete Contact"
                                    data-confirm-body="Are you sure you want to delete @item.FullName? This cannot be undone."
                                    data-confirm-btn-label="Delete"
                                    data-confirm-btn-icon="bi-trash"
                                    data-confirm-table="#contacts-table">
                                <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
}
else
{
    <div class="text-center py-5 my-5">
        <i class="bi bi-person-rolodex display-1 opacity-25 mb-3" style="color: var(--crm-text-tertiary);" aria-hidden="true"></i>
        <h3 class="h4 mt-3" style="color: var(--crm-text-secondary);">No contacts found</h3>
        <p class="mb-4" style="color: var(--crm-text-tertiary);">
            @(Context.Request.Query["showHidden"] == "True"
                ? "There are no hidden contacts at the moment."
                : "Get started by adding your first contact to the system.")
        </p>
        <a asp-action="Create" class="crm-btn-primary" style="padding: 0.5rem 1.25rem;">
            <i class="bi bi-plus-lg me-2" aria-hidden="true"></i>Create Contact
        </a>
    </div>
}

@section Scripts {
    <script>
        var table;

        $(document).ready(function () {
            var antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();

            $(document).on('click', '.btn-favorite', function () {
                var btn = $(this);
                var contactId = btn.data('contact-id');
                var contactName = btn.data('contact-name');

                $.ajax({
                    url: '/Favorites/Toggle',
                    type: 'POST',
                    data: { contactId: contactId, __RequestVerificationToken: antiForgeryToken },
                    success: function (result) {
                        var isFavorite = result.isFavorite;

                        btn.css('color', isFavorite ? 'var(--crm-warning)' : 'var(--crm-text-tertiary)');
                        btn.data('is-favorite', isFavorite);
                        btn.find('i').toggleClass('bi-star-fill', isFavorite);
                        btn.find('i').toggleClass('bi-star', !isFavorite);
                        btn.attr('title', isFavorite ? 'Remove from favorites' : 'Add to favorites');
                        btn.attr('aria-label', (isFavorite ? 'Remove ' : 'Add ') + contactName + (isFavorite ? ' from favorites' : ' to favorites'));

                        var row = btn.closest('tr');
                        var nameCell = row.find('td:eq(1)');
                        nameCell.attr('data-order', (isFavorite ? '0 ' : '1 ') + contactName);

                        table.row(row).invalidate('dom').draw(false);
                    }
                });
            });

            table = $('#contacts-table').DataTable({
                paging: true,
                pageLength: 25,
                order: [[1, 'asc']],
                info: false,
                ordering: true,
                searching: true,
                searchDelay: 300,
                autoWidth: false,
                responsive: {
                    details: {
                        renderer: function (api, rowIdx, columns) {
                            var rows = $.map(columns, function (col) {
                                if (!col.hidden) return '';
                                if (col.columnIndex === 0) return '';
                                var isEmpty = !String(col.data ?? '').replace(/<[^>]*>/g, '').trim();
                                var value = isEmpty
                                    ? '<span class="crm-dtr-child-empty">—</span>'
                                    : col.data;
                                return '<tr data-dt-row="' + col.rowIndex + '" data-dt-column="' + col.columnIndex + '">' +
                                       '<td class="crm-dtr-child-label">' + col.title + '</td>' +
                                       '<td class="crm-dtr-child-value">' + value + '</td>' +
                                       '</tr>';
                            }).join('');
                            return rows ? $('<table class="mb-0" style="width: auto;"/>').append(rows) : false;
                        }
                    }
                },
                layout: {
                    topStart: null,
                    topEnd: {
                        search: { placeholder: 'Search contacts...' },
                        buttons: [
                            {
                                extend: 'colvis',
                                text: '<i class="bi bi-layout-three-columns" aria-hidden="true"></i>',
                                titleAttr: 'Choose columns',
                                className: 'd-none d-md-inline-flex'
                            }
                        ]
                    },
                    bottomStart: 'pageLength',
                    bottomEnd: 'paging'
                },
                columnDefs: [
                    { orderable: false, targets: 'no-sort' },
                    { visible: false, searchable: false, targets: 'default-hidden' },
                    { width: '60px', targets: 'col-photo' },
                    { width: '155px', targets: 'col-actions' },
                    { responsivePriority: 1, targets: 1 },
                    { responsivePriority: 2, targets: 12 },
                    { responsivePriority: 3, targets: 0 },
                    { responsivePriority: 4, targets: 2 },
                    { responsivePriority: 5, targets: 3 }
                ],
                language: {
                    search: '',
                    lengthMenu: '_MENU_ per page'
                },
                initComplete: function () {
                    $('#contacts-table').css('visibility', 'visible');
                }
            });

            table.on('column-visibility', function (e, settings, colIdx, state) {
                settings.aoColumns[colIdx].bSearchable = state;
                table.rows().invalidate('data').draw(false);
            });

            var resizeTimer;
            $(window).on('resize', function () {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(function () {
                    table.responsive.recalc();
                }, 150);
            });
        });

    </script>
}
