@model Rvnx.CRM.Core.DTOs.Contact.ContactIndexViewModel

@{
    ViewData["Title"] = "Contacts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Contacts</h1>
    <div>
        @if (Context.Request.Query["showHidden"] == "True")
        {
            <a asp-action="Index" asp-route-showHidden="False" class="btn btn-outline-secondary me-2">Hide Hidden</a>
        }
        else
        {
            <a asp-action="Index" asp-route-showHidden="True" class="btn btn-outline-secondary me-2">View Hidden</a>
        }
        <a asp-action="Import" class="btn btn-outline-primary me-2"><i class="fa-solid fa-file-import"></i> Import VCF</a>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Create New</a>
    </div>
</div>

@if (Model.SuccessMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Contacts.Any())
{
    <div class="table-responsive">
        <table id="contacts-table" class="table table-striped table-hover align-middle" style="width: 100%;">
            <thead>
                <tr>
                    <th scope="col" class="col-photo">Photo</th>
                    <th scope="col">Name</th>
                    <th scope="col">Company</th>
                    <th scope="col">Job Title</th>
                    <th scope="col" class="default-hidden">Created</th>
                    <th scope="col" class="default-hidden">Pronouns</th>
                    <th scope="col" class="default-hidden">Gender</th>
                    <th scope="col" class="default-hidden">Religion</th>
                    <th scope="col" class="default-hidden">Last Changed</th>
                    <th scope="col" class="no-sort col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5 my-5">
        <i class="bi bi-person-rolodex display-1 text-muted opacity-25 mb-3"></i>
        <h3 class="h4 text-secondary mt-3">No contacts found</h3>
        <p class="text-muted mb-4">
            @(Context.Request.Query["showHidden"] == "True"
                ? "There are no hidden contacts at the moment."
                : "Get started by adding your first contact to the system.")
        </p>
        <a asp-action="Create" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-plus-lg me-2"></i>Create Contact
        </a>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#contacts-table').DataTable({
                ajax: {
                    url: '@Url.Action("DataTable", "Contacts")',
                    type: 'GET',
                    data: function (d) {
                        d.showHidden = '@(Context.Request.Query["showHidden"] == "True")';
                    }
                },
                processing: true,
                serverSide: true,
                paging: true,
                pageLength: 25,
                order: [[1, 'asc']],
                info: false,
                ordering: true,
                searching: true,
                searchDelay: 300,
                autoWidth: false,
                columns: [
                    { data: 'photoHtml', orderable: false, searchable: false },
                    { data: 'nameHtml' },
                    { data: 'company' },
                    { data: 'jobTitle' },
                    { data: 'createdDate', render: function(data) { return data ? new Date(data).toLocaleDateString() : ''; } },
                    { data: 'pronouns' },
                    { data: 'gender' },
                    { data: 'religion' },
                    { data: 'lastChangedDate', render: function(data) { return data ? new Date(data).toLocaleDateString() : ''; } },
                    { data: 'actionsHtml', orderable: false, searchable: false }
                ],
                layout: {
                    topStart: 'pageLength',
                    topEnd: {
                        search: { placeholder: 'Search contacts...' },
                        buttons: [
                            {
                                extend: 'colvis',
                                text: '<i class="bi bi-layout-three-columns"></i>',
                                titleAttr: 'Choose columns'
                            }
                        ]
                    }
                },
                columnDefs: [
                    { orderable: false, targets: 'no-sort' },
                    { visible: false, targets: 'default-hidden' },
                    { width: '60px', targets: 'col-photo' },
                    { width: '120px', targets: 'col-actions' }
                ],
                language: {
                    search: ''
                }
            });
        });
    </script>
}
