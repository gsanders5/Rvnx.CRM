@model Rvnx.CRM.Web.ViewModels.Contact.ContactIndexViewModel

@{
    ViewData["Title"] = "Contacts";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-3">
    <h1>Contacts</h1>
    <div class="d-flex flex-wrap gap-2 mt-3 mt-md-0">
        @if (Context.Request.Query["showHidden"] == "True")
        {
            <a asp-action="Index" asp-route-showHidden="False" class="crm-btn-tertiary btn-sm" title="Hide hidden and deceased contacts">Hide Hidden / Deceased</a>
        }
        else
        {
            <a asp-action="Index" asp-route-showHidden="True" class="crm-btn-tertiary btn-sm" title="Show hidden and deceased contacts">View Hidden / Deceased</a>
        }
        <div class="dropdown">
            <button class="crm-btn-secondary btn-sm dropdown-toggle" type="button" data-mdb-dropdown-init data-mdb-toggle="dropdown" aria-expanded="false">
                <i class="fa-solid fa-file-csv" aria-hidden="true"></i> Import / Export
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" asp-action="Import"><i class="fa-solid fa-file-import me-2" aria-hidden="true"></i>Import VCF</a></li>
                <li><a class="dropdown-item" asp-action="ExportCsv"><i class="fa-solid fa-file-export me-2" aria-hidden="true"></i>Export CSV</a></li>
                <li><a class="dropdown-item" asp-action="ExportAllVCard"><i class="fa-solid fa-file-zipper me-2" aria-hidden="true"></i>Export All VCF (Zip)</a></li>
            </ul>
        </div>
        <a asp-action="Create" class="crm-btn-primary btn-sm"><i class="bi bi-plus-lg" aria-hidden="true"></i> Create New</a>
    </div>
</div>

@Html.AntiForgeryToken()

<div id="bulk-flash" class="alert alert-dismissible fade show d-none" role="alert" aria-live="polite"></div>

@if (Model.SuccessMessage != null)
{
    <div class="alert alert-dismissible fade show" role="alert" style="background-color: rgba(45, 198, 83, 0.1); color: var(--crm-success); border: 1px solid rgba(45, 198, 83, 0.2); border-radius: var(--crm-radius-sm);">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Contacts.Any())
{
    <div id="bulk-toolbar" class="bulk-toolbar" role="toolbar" aria-label="Bulk actions">
        <span class="bulk-toolbar-count"><span id="bulk-toolbar-count">0</span> selected</span>
        <div class="bulk-toolbar-group">
            <button type="button" id="bulk-hide" class="crm-btn-tertiary btn-sm" title="Hide selected">
                <i class="bi bi-eye-slash" aria-hidden="true"></i> Hide
            </button>
            <button type="button" id="bulk-unhide" class="crm-btn-tertiary btn-sm" title="Unhide selected">
                <i class="bi bi-eye" aria-hidden="true"></i> Unhide
            </button>
        </div>
        <div class="dropdown">
            <button class="crm-btn-tertiary btn-sm dropdown-toggle" type="button" data-mdb-dropdown-init data-mdb-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-tag" aria-hidden="true"></i> Label
            </button>
            <ul class="dropdown-menu">
                @if (Model.AllLabels.Count == 0)
                {
                    <li><span class="dropdown-item-text text-muted">No labels available</span></li>
                }
                else
                {
                    <li><h6 class="dropdown-header">Add label</h6></li>
                    @foreach (var label in Model.AllLabels)
                    {
                        <li>
                            <button type="button" class="dropdown-item bulk-add-label" data-label-id="@label.Id" data-label-name="@label.Name">
                                <i class="bi bi-plus-circle me-2" aria-hidden="true"></i>@label.Name
                            </button>
                        </li>
                    }
                    <li><hr class="dropdown-divider" /></li>
                    <li><h6 class="dropdown-header">Remove label</h6></li>
                    @foreach (var label in Model.AllLabels)
                    {
                        <li>
                            <button type="button" class="dropdown-item bulk-remove-label" data-label-id="@label.Id" data-label-name="@label.Name">
                                <i class="bi bi-dash-circle me-2" aria-hidden="true"></i>@label.Name
                            </button>
                        </li>
                    }
                }
            </ul>
        </div>
        <div class="dropdown">
            <button class="crm-btn-tertiary btn-sm dropdown-toggle" type="button" data-mdb-dropdown-init data-mdb-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-download" aria-hidden="true"></i> Export
            </button>
            <ul class="dropdown-menu">
                <li>
                    <button type="button" class="dropdown-item" id="bulk-export-csv">
                        <i class="fa-solid fa-file-csv me-2" aria-hidden="true"></i>Export Selected as CSV
                    </button>
                </li>
                <li>
                    <button type="button" class="dropdown-item" id="bulk-export-vcard">
                        <i class="fa-solid fa-file-zipper me-2" aria-hidden="true"></i>Export Selected as vCard Zip
                    </button>
                </li>
            </ul>
        </div>
        <button type="button" id="bulk-delete" class="crm-btn-danger btn-sm" title="Delete selected">
            <i class="bi bi-trash" aria-hidden="true"></i> Delete
        </button>
        <button type="button" id="bulk-clear" class="crm-btn-tertiary btn-sm" title="Clear selection">
            <i class="bi bi-x-circle" aria-hidden="true"></i> Clear
        </button>
    </div>

    <form id="bulk-export-form" method="post" class="d-none">
        @Html.AntiForgeryToken()
    </form>

    <div class="modal fade" id="bulk-delete-modal" tabindex="-1" aria-labelledby="bulkDeleteLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="bulkDeleteLabel">Delete contacts</h5>
                    <button type="button" class="btn-close" data-mdb-ripple-init data-mdb-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="bulk-delete-body">Delete contacts?</div>
                <div class="modal-footer">
                    <button type="button" class="crm-btn-tertiary" data-mdb-ripple-init data-mdb-dismiss="modal">Cancel</button>
                    <button type="button" id="bulk-delete-confirm" class="crm-btn-danger" data-mdb-ripple-init>
                        <i class="bi bi-trash" aria-hidden="true"></i> Delete
                    </button>
                </div>
            </div>
        </div>
    </div>

        <table id="contacts-table" class="table table-striped table-hover align-middle" style="width: 100%; visibility: hidden;">
            <thead>
            <tr>
                <th scope="col" class="select-col no-sort">
                    <input type="checkbox" id="select-all" class="form-check-input" aria-label="Select all contacts" />
                </th>
                <th scope="col" class="col-photo">Photo</th>
                <th scope="col">Name</th>
                <th scope="col">Company</th>
                <th scope="col">Job Title</th>
                <th scope="col" class="default-hidden">Maiden Name</th>
                <th scope="col" class="default-hidden">Created</th>
                <th scope="col" class="default-hidden">Pronouns</th>
                <th scope="col" class="default-hidden">Gender</th>
                <th scope="col" class="default-hidden">Religion</th>
                <th scope="col" class="default-hidden">Last Changed</th>
                <th scope="col" class="default-hidden">Last Changed By</th>
                <th scope="col" class="default-hidden">Birthday</th>
                <th scope="col" class="no-sort col-actions">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Contacts)
            {
                <tr data-contact-id="@item.Id">
                    <td class="select-col">
                        <input type="checkbox" class="form-check-input row-select" value="@item.Id" aria-label="Select @item.FullName" />
                    </td>
                    <td data-order="@(item.ProfileImageId.HasValue ? 1 : 0)">
                        <a asp-action="Details" asp-route-id="@item.Id" class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            @if (item.ProfileImageId.HasValue)
                            {
                                <img src="@Url.Action("Thumbnail", "Attachments", new { id = item.ProfileImageId, maxWidth = 80, maxHeight = 80 })" class="crm-avatar" width="40" height="40" alt="@item.FullName" loading="lazy" />
                            }
                            else
                            {
                                <div class="crm-avatar-placeholder">
                                    <i class="bi bi-person-fill" aria-hidden="true"></i>
                                </div>
                            }
                        </a>
                    </td>
                    <td data-order="@(item.IsFavorite ? "0" : "1") @item.FullName">
                        <a asp-action="Details" asp-route-id="@item.Id" class="fw-semibold text-decoration-none" style="color: var(--crm-text-primary);">
                            @item.FullName
                        </a>
                        @if (item.IsHidden)
                        {
                            <span class="crm-badge crm-badge-muted ms-2" title="Hidden">
                                <i class="bi bi-eye-slash" aria-hidden="true"></i>
                            </span>
                        }
                        @if (item.IsDeceased)
                        {
                            <span class="crm-badge crm-badge-muted ms-2" title="Deceased@(item.DateOfDeath.HasValue ? " (" + item.DateOfDeath.Value.ToShortDateString() + ")" : "")">
                                <i class="fa-solid fa-book-skull" aria-hidden="true"></i>
                            </span>
                        }
                        @if (item.Labels != null && item.Labels.Any())
                        {
                            <div class="mt-1 d-flex gap-1 flex-wrap">
                                @foreach (var label in item.Labels)
                                {
                                    @await Html.PartialAsync("_LabelBadge", label)
                                }
                            </div>
                        }
                    </td>
                    <td>@item.Company</td>
                    <td>@item.JobTitle</td>
                    <td>@item.MaidenName</td>
                    <td>@item.CreatedDate.ToShortDateString()</td>
                    <td>@item.Pronouns</td>
                    <td>@item.Gender</td>
                    <td>@item.Religion</td>
                    <td>@item.LastChangedDate.ToShortDateString()</td>
                    <td>@item.LastChangedBy</td>
                    <td data-order="@(item.Birthday.HasValue ? item.Birthday.Value.ToString("yyyy-MM-dd") : "")">
                        @(item.Birthday.HasValue ? item.Birthday.Value.ToShortDateString() : "—")
                    </td>
                    <td>
                        <div class="crm-icon-actions">
                            <button type="button"
                                    class="crm-icon-btn btn-favorite"
                                    style="color: @(item.IsFavorite ? "var(--crm-warning)" : "var(--crm-text-tertiary)");"
                                    title="@(item.IsFavorite ? "Remove from favorites" : "Add to favorites")"
                                    aria-label="@(item.IsFavorite ? "Remove" : "Add") @item.FullName @(item.IsFavorite ? "from" : "to") favorites"
                                    data-contact-id="@item.Id"
                                    data-contact-name="@item.FullName"
                                    data-is-favorite="@item.IsFavorite.ToString().ToLower()">
                                <i class="bi @(item.IsFavorite ? "bi-star-fill" : "bi-star")" aria-hidden="true"></i>
                            </button>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @item.FullName">
                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="crm-icon-btn" style="color: var(--crm-info);" title="Details" aria-label="Details for @item.FullName">
                                <i class="bi bi-info-circle" aria-hidden="true"></i>
                            </a>
                            <button type="button"
                                    class="crm-icon-btn icon-danger"
                                    title="Delete"
                                    aria-label="Delete @item.FullName"
                                    data-confirm-action="@Url.Action("Delete", new { id = item.Id })"
                                    data-confirm-title="Delete Contact"
                                    data-confirm-body="Are you sure you want to delete @item.FullName? This cannot be undone."
                                    data-confirm-btn-label="Delete"
                                    data-confirm-btn-icon="bi-trash"
                                    data-confirm-table="#contacts-table">
                                <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
}
else
{
    <div class="text-center py-5 my-5">
        <i class="bi bi-person-rolodex display-1 opacity-25 mb-3" style="color: var(--crm-text-tertiary);" aria-hidden="true"></i>
        <h3 class="h4 mt-3" style="color: var(--crm-text-secondary);">No contacts found</h3>
        <p class="mb-4" style="color: var(--crm-text-tertiary);">
            @(Context.Request.Query["showHidden"] == "True"
                ? "There are no contacts at the moment."
                : "Get started by adding your first contact to the system.")
        </p>
        <a asp-action="Create" class="crm-btn-primary" style="padding: 0.5rem 1.25rem;">
            <i class="bi bi-plus-lg me-2" aria-hidden="true"></i>Create Contact
        </a>
    </div>
}

@section Scripts {
    <script>
        var table;

        $(document).ready(function () {
            var antiForgeryToken = $('input[name="__RequestVerificationToken"]').val();
            var selectedIds = new Set();

            $(document).on('click', '.btn-favorite', function () {
                var btn = $(this);
                var contactId = btn.data('contact-id');
                var contactName = btn.data('contact-name');

                $.ajax({
                    url: '/Favorites/Toggle',
                    type: 'POST',
                    data: { contactId: contactId, __RequestVerificationToken: antiForgeryToken },
                    success: function (result) {
                        var isFavorite = result.isFavorite;

                        btn.css('color', isFavorite ? 'var(--crm-warning)' : 'var(--crm-text-tertiary)');
                        btn.data('is-favorite', isFavorite);
                        btn.find('i').toggleClass('bi-star-fill', isFavorite);
                        btn.find('i').toggleClass('bi-star', !isFavorite);
                        btn.attr('title', isFavorite ? 'Remove from favorites' : 'Add to favorites');
                        btn.attr('aria-label', (isFavorite ? 'Remove ' : 'Add ') + contactName + (isFavorite ? ' from favorites' : ' to favorites'));

                        var row = btn.closest('tr');
                        var nameCell = row.find('td:eq(2)');
                        nameCell.attr('data-order', (isFavorite ? '0 ' : '1 ') + contactName);

                        table.row(row).invalidate('dom').draw(false);
                    }
                });
            });

            table = $('#contacts-table').DataTable({
                paging: true,
                pageLength: 25,
                order: [[2, 'asc']],
                info: false,
                ordering: true,
                searching: true,
                searchDelay: 300,
                autoWidth: false,
                responsive: {
                    details: {
                        renderer: function (api, rowIdx, columns) {
                            var rows = $.map(columns, function (col) {
                                if (!col.hidden) return '';
                                if (col.columnIndex === 0 || col.columnIndex === 1) return '';
                                var isEmpty = !String(col.data ?? '').replace(/<[^>]*>/g, '').trim();
                                var value = isEmpty
                                    ? '<span class="crm-dtr-child-empty">—</span>'
                                    : col.data;
                                return '<tr data-dt-row="' + col.rowIndex + '" data-dt-column="' + col.columnIndex + '">' +
                                       '<td class="crm-dtr-child-label">' + col.title + '</td>' +
                                       '<td class="crm-dtr-child-value">' + value + '</td>' +
                                       '</tr>';
                            }).join('');
                            return rows ? $('<table class="mb-0" style="width: auto;"/>').append(rows) : false;
                        }
                    }
                },
                layout: {
                    topStart: null,
                    topEnd: {
                        search: { placeholder: 'Search contacts...' },
                        buttons: [
                            {
                                extend: 'colvis',
                                text: '<i class="bi bi-layout-three-columns" aria-hidden="true"></i>',
                                titleAttr: 'Choose columns',
                                className: 'd-none d-md-inline-flex',
                                columns: ':not(.select-col)'
                            }
                        ]
                    },
                    bottomStart: 'pageLength',
                    bottomEnd: 'paging'
                },
                columnDefs: [
                    { orderable: false, searchable: false, targets: 'select-col' },
                    { orderable: false, targets: 'no-sort' },
                    { visible: false, searchable: false, targets: 'default-hidden' },
                    { width: '34px', targets: 'select-col' },
                    { width: '60px', targets: 'col-photo' },
                    { width: '155px', targets: 'col-actions' },
                    { responsivePriority: 0, targets: 0 },
                    { responsivePriority: 1, targets: 2 },
                    { responsivePriority: 2, targets: 13 },
                    { responsivePriority: 3, targets: 1 },
                    { responsivePriority: 4, targets: 3 },
                    { responsivePriority: 5, targets: 4 }
                ],
                language: {
                    search: '',
                    lengthMenu: '_MENU_ per page'
                },
                initComplete: function () {
                    $('#contacts-table').css('visibility', 'visible');
                }
            });

            table.on('column-visibility', function (e, settings, colIdx, state) {
                settings.aoColumns[colIdx].bSearchable = state;
                table.rows().invalidate('data').draw(false);
            });

            // Re-apply selection state to the rows currently rendered by DataTables (it remounts rows
            // on page-change/search). Without this, navigating to page 2 and back would lose the visual
            // checkmark even though selectedIds still tracks the row.
            table.on('draw.dt', function () {
                $('#contacts-table tbody input.row-select').each(function () {
                    this.checked = selectedIds.has(this.value);
                });
                refreshSelectAllState();
            });

            $(document).on('change', 'input.row-select', function () {
                if (this.checked) {
                    selectedIds.add(this.value);
                } else {
                    selectedIds.delete(this.value);
                }
                updateToolbar();
                refreshSelectAllState();
            });

            $(document).on('change', '#select-all', function () {
                var checked = this.checked;
                table.rows({ search: 'applied' }).every(function () {
                    var $row = $(this.node());
                    var $cb = $row.find('input.row-select');
                    var id = $cb.val();
                    if (!id) return;
                    if (checked) {
                        selectedIds.add(id);
                    } else {
                        selectedIds.delete(id);
                    }
                    $cb.prop('checked', checked);
                });
                updateToolbar();
            });

            $('#bulk-clear').on('click', clearSelection);

            $('#bulk-hide').on('click', function () {
                bulkPost('/Contacts/BulkSetHidden', { hidden: true }, 'Hide selected');
            });
            $('#bulk-unhide').on('click', function () {
                bulkPost('/Contacts/BulkSetHidden', { hidden: false }, 'Unhide selected');
            });

            $(document).on('click', '.bulk-add-label', function () {
                var labelId = $(this).data('label-id');
                bulkPost('/Contacts/BulkAssignLabel', { labelId: labelId }, 'Apply label');
            });
            $(document).on('click', '.bulk-remove-label', function () {
                var labelId = $(this).data('label-id');
                bulkPost('/Contacts/BulkRemoveLabel', { labelId: labelId }, 'Remove label');
            });

            $('#bulk-export-csv').on('click', function () {
                submitExport('/Contacts/ExportSelectedCsv');
            });
            $('#bulk-export-vcard').on('click', function () {
                submitExport('/Contacts/ExportSelectedVCard');
            });

            $('#bulk-delete').on('click', function () {
                if (selectedIds.size === 0) return;
                $('#bulk-delete-body').text('Delete ' + selectedIds.size + ' contact' + (selectedIds.size === 1 ? '' : 's') + '? This cannot be undone.');
                var confirmBtn = document.getElementById('bulk-delete-confirm');
                confirmBtn.disabled = false;
                confirmBtn.innerHTML = '<i class="bi bi-trash" aria-hidden="true"></i> Delete';
                mdb.Modal.getOrCreateInstance(document.getElementById('bulk-delete-modal')).show();
            });

            $('#bulk-delete-confirm').on('click', function () {
                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span> Deleting…');

                var ids = Array.from(selectedIds);
                postBulk('/Contacts/BulkDelete', ids, {})
                    .done(function (result) {
                        ids.forEach(function (id) {
                            var row = $('#contacts-table tbody tr[data-contact-id="' + id + '"]');
                            if (row.length) {
                                table.row(row).remove();
                            }
                        });
                        table.draw(false);
                        clearSelection();
                        flash(buildResultMessage(result, 'deleted'), 'success');
                    })
                    .fail(function (xhr) {
                        flash(extractError(xhr) || 'Bulk delete failed.', 'danger');
                    })
                    .always(function () {
                        mdb.Modal.getOrCreateInstance(document.getElementById('bulk-delete-modal')).hide();
                    });
            });

            function bulkPost(url, extras, label) {
                if (selectedIds.size === 0) return;
                var ids = Array.from(selectedIds);
                postBulk(url, ids, extras)
                    .done(function () {
                        // Reload to refresh contact rows (label badges, hidden state) — the index is server-rendered.
                        window.location.reload();
                    })
                    .fail(function (xhr) {
                        flash(extractError(xhr) || (label + ' failed.'), 'danger');
                    });
            }

            function postBulk(url, ids, extras) {
                var params = new URLSearchParams();
                ids.forEach(function (id) { params.append('ids', id); });
                Object.keys(extras || {}).forEach(function (k) { params.append(k, extras[k]); });
                params.append('__RequestVerificationToken', antiForgeryToken);
                return $.ajax({
                    url: url,
                    type: 'POST',
                    data: params.toString(),
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });
            }

            function submitExport(url) {
                if (selectedIds.size === 0) return;
                var form = document.getElementById('bulk-export-form');
                form.action = url;
                $(form).find('input[name="ids"]').remove();
                selectedIds.forEach(function (id) {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'ids';
                    input.value = id;
                    form.appendChild(input);
                });
                form.submit();
            }

            function clearSelection() {
                selectedIds.clear();
                $('#contacts-table tbody input.row-select').prop('checked', false);
                $('#select-all').prop('checked', false);
                updateToolbar();
            }

            function updateToolbar() {
                var size = selectedIds.size;
                var toolbar = document.getElementById('bulk-toolbar');
                if (!toolbar) return;
                document.getElementById('bulk-toolbar-count').textContent = size;
                toolbar.classList.toggle('is-active', size > 0);
            }

            function refreshSelectAllState() {
                var $cbs = $('#contacts-table tbody input.row-select');
                if ($cbs.length === 0) {
                    $('#select-all').prop('checked', false).prop('indeterminate', false);
                    return;
                }
                var checked = $cbs.filter(':checked').length;
                var sa = document.getElementById('select-all');
                if (!sa) return;
                sa.checked = checked === $cbs.length;
                sa.indeterminate = checked > 0 && checked < $cbs.length;
            }

            function buildResultMessage(result, verb) {
                if (!result) return verb.charAt(0).toUpperCase() + verb.slice(1) + '.';
                var parts = [result.successful + ' ' + verb];
                if (result.skipped > 0) parts.push(result.skipped + ' skipped');
                return parts.join(', ') + '.';
            }

            function extractError(xhr) {
                if (!xhr) return null;
                if (xhr.responseJSON && xhr.responseJSON.errors && xhr.responseJSON.errors.length) {
                    return xhr.responseJSON.errors.join(' ');
                }
                if (typeof xhr.responseText === 'string' && xhr.responseText.length && xhr.responseText.length < 300) {
                    return xhr.responseText;
                }
                return null;
            }

            function flash(message, kind) {
                var alert = document.getElementById('bulk-flash');
                if (!alert) return;
                alert.classList.remove('d-none', 'alert-success', 'alert-danger');
                alert.classList.add(kind === 'danger' ? 'alert-danger' : 'alert-success');
                alert.textContent = message;
                setTimeout(function () { alert.classList.add('d-none'); }, 4000);
            }

            var resizeTimer;
            $(window).on('resize', function () {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(function () {
                    table.responsive.recalc();
                }, 150);
            });

            updateToolbar();
        });

    </script>
}
