@{
    ViewData["Title"] = "Import VCF";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Import VCF</h1>
        <a asp-action="Index" class="crm-btn-tertiary btn-sm"><i class="bi bi-arrow-left" aria-hidden="true"></i> Back to List</a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="crm-form-card">
                <div class="crm-form-card-header">
                    <h4><i class="bi bi-file-earmark-arrow-up" aria-hidden="true"></i> Upload Contacts File</h4>
                </div>
                <div class="crm-form-card-body">
                    <p class="crm-meta mb-3">
                        Select a .vcf file to import contacts. Duplicates (Name, Email, or Phone) will be skipped.
                    </p>
                    <form asp-action="Import" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label for="file" class="form-label">VCF File</label>
                            <input type="file" name="file" id="file" class="form-control" accept=".vcf" required/>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="crm-btn-primary">
                                <i class="fa-solid fa-file-import" aria-hidden="true"></i> Import Contacts
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
