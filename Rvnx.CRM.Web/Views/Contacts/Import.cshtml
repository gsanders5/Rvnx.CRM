@{
    ViewData["Title"] = "Import VCF";
}

<form id="import-form" asp-action="Import" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="crm-details-actions-strip">
        <a asp-controller="Contacts" asp-action="Index" class="crm-btn-tertiary btn-sm">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Contacts
        </a>
        <button type="submit" class="crm-btn-primary btn-sm">
            <i class="bi bi-upload" aria-hidden="true"></i> Import Contacts
        </button>
    </div>

    <section class="crm-edit-masthead crm-fade-in">
        <div class="crm-edit-masthead-photo-placeholder" aria-hidden="true"><i class="bi bi-file-earmark-arrow-up"></i></div>
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 6px;">Import</div>
            <h1 class="crm-edit-masthead-title">Import contacts</h1>
        </div>
    </section>

    <div class="crm-page" style="max-width: 720px;">
        <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

        <div class="crm-card">
            <div class="crm-card-header">
                <h5 class="card-title mb-0"><i class="bi bi-file-earmark" aria-hidden="true"></i> vCard File</h5>
            </div>
            <div class="crm-card-body">
                <div class="crm-field-group">
                    <label for="file">Select a .vcf file to import</label>
                    <input type="file" id="file" name="file" class="crm-input" accept=".vcf" required />
                    <div class="crm-field-help">Select a .vcf file to import contacts. Duplicates (Name, Email, or Phone) will be skipped.</div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
