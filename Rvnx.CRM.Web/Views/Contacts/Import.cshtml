@{
    ViewData["Title"] = "Import VCF";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Import VCF</h1>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Upload Contacts File</h5>
                    <p class="card-text text-muted small">
                        Select a .vcf file to import contacts. Duplicates (Name, Email, or Phone) will be skipped.
                    </p>
                    <form asp-action="Import" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label for="file" class="form-label">VCF File</label>
                            <input type="file" name="file" id="file" class="form-control" accept=".vcf" required/>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-file-import me-2"></i> Import Contacts
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
