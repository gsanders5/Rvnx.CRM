@model Rvnx.CRM.Core.DTOs.Contact.ContactCreateViewModel

@{
    ViewData["Title"] = Model.IsSelfCreate ? "Create Self Contact" : "Create Contact";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-6">
        <form id="contact-form" asp-action="@(Model.IsSelfCreate ? "CreateSelf" : "Create")">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            @if (Model.IsSelfCreate)
            {
                <input type="hidden" asp-for="IsSelfCreate" value="true"/>
            }

            <div class="form-floating mb-3">
                <input asp-for="FirstName" class="form-control" placeholder="FirstName" required autofocus/>
                <label asp-for="FirstName">First Name <span class="text-danger">*</span></label>
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="LastName" class="form-control" placeholder="LastName"/>
                <label asp-for="LastName"></label>
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="MaidenName" class="form-control" placeholder="MaidenName"/>
                <label asp-for="MaidenName"></label>
                <span asp-validation-for="MaidenName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Nickname" class="form-control" placeholder="Nickname"/>
                <label asp-for="Nickname"></label>
                <span asp-validation-for="Nickname" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="Email"/>
                <label asp-for="Email"></label>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Phone" class="form-control" placeholder="Phone"/>
                <label asp-for="Phone"></label>
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Company" class="form-control" placeholder="Company"/>
                <label asp-for="Company"></label>
                <span asp-validation-for="Company" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="JobTitle" class="form-control" placeholder="JobTitle"/>
                <label asp-for="JobTitle"></label>
                <span asp-validation-for="JobTitle" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Birthday" class="form-control" type="date" placeholder="Birthday" id="BirthdayField" />
                <label asp-for="Birthday"></label>
                <span asp-validation-for="Birthday" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check form-switch">
                <input type="checkbox" class="form-check-input" id="BirthdayYearUnknownField" />
                <label class="form-check-label" for="BirthdayYearUnknownField">Year Unknown</label>
            </div>

            <div class="mb-3 form-check form-switch">
                <input asp-for="RemindOnBirthday" class="form-check-input"/>
                <label asp-for="RemindOnBirthday" class="form-check-label"></label>
            </div>

            <div class="mb-3">
                <label asp-for="Pronouns" class="form-label">Pronouns</label>
                <select asp-for="Pronouns" id="pronouns-select" class="form-select">
                    <option value=""></option>
                    @foreach (var option in Model.PronounOptions.Where(o => o != "Other" && o != "Unspecified"))
                    {
                        <option value="@option">@option</option>
                    }
                </select>
                <span asp-validation-for="Pronouns" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Gender" class="form-label">Gender</label>
                <select asp-for="Gender" id="gender-select" class="form-select">
                    <option value=""></option>
                    @foreach (var option in Model.GenderOptions.Where(o => o != "Other" && o != "Unspecified"))
                    {
                        <option value="@option">@option</option>
                    }
                </select>
                <span asp-validation-for="Gender" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Religion" class="form-label">Religion</label>
                <input asp-for="Religion" class="form-control" placeholder="Optional"/>
                <span asp-validation-for="Religion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="HowWeMet" class="form-label">How We Met</label>
                <textarea asp-for="HowWeMet" class="form-control" rows="3" maxlength="1000" placeholder="Describe how you met this person..."></textarea>
                <span asp-validation-for="HowWeMet" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="FirstMetOn" class="form-control" type="date" placeholder="First Met On"/>
                <label asp-for="FirstMetOn"></label>
                <span asp-validation-for="FirstMetOn" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IntroducedByContactId" class="form-label">Introduced By</label>
                <select asp-for="IntroducedByContactId" id="introduced-by-select" class="form-select">
                    <option value=""></option>
                    @foreach (var candidate in Model.IntroducerCandidates)
                    {
                        <option value="@candidate.Id">@candidate.FullName</option>
                    }
                </select>
                <span asp-validation-for="IntroducedByContactId" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check form-switch">
                <input asp-for="IsHidden" class="form-check-input"/>
                <label asp-for="IsHidden" class="form-check-label"></label>
                <div class="form-text">Hidden contacts are excluded from the main list by default.</div>
            </div>

            <div class="mb-3 form-check form-switch">
                <input asp-for="IsDeceased" class="form-check-input" id="IsDeceasedField"/>
                <label asp-for="IsDeceased" class="form-check-label"></label>
                <div class="form-text">Suppresses birthday and anniversary reminders.</div>
            </div>

            <div class="form-floating mb-3" id="DateOfDeathGroup">
                <input asp-for="DateOfDeath" class="form-control" type="date" placeholder="Date of Death"/>
                <label asp-for="DateOfDeath"></label>
                <span asp-validation-for="DateOfDeath" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-start mt-4">
                <button type="submit" class="crm-btn-primary"><i class="bi bi-plus-lg" aria-hidden="true"></i> Create</button>
                <a asp-action="Index" class="crm-btn-tertiary"><i class="bi bi-arrow-left" aria-hidden="true"></i> Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            $('#pronouns-select').select2({ width: '100%', tags: true, placeholder: 'Select or enter pronouns...', allowClear: true });
            $('#gender-select').select2({ width: '100%', tags: true, placeholder: 'Select or enter gender...', allowClear: true });
            $('#introduced-by-select').select2({ width: '100%', placeholder: 'Search for a contact...', allowClear: true });

            const birthdayField = document.getElementById('BirthdayField');
            const birthdayYearUnknownField = document.getElementById('BirthdayYearUnknownField');

            function toggleBirthdayYear() {
                if (birthdayYearUnknownField.checked) {
                    if (birthdayField.value) {
                        const parts = birthdayField.value.split('-');
                        if (parts.length === 3) {
                            birthdayField.value = '0001-' + parts[1] + '-' + parts[2];
                        }
                    }
                } else {
                    if (birthdayField.value) {
                        const parts = birthdayField.value.split('-');
                        if (parts.length === 3 && parts[0] === '0001') {
                            const currentYear = new Date().getFullYear();
                            birthdayField.value = currentYear + '-' + parts[1] + '-' + parts[2];
                        }
                    }
                }
            }

            if (birthdayYearUnknownField) {
                birthdayYearUnknownField.addEventListener('change', toggleBirthdayYear);
                toggleBirthdayYear();
            }

            const isDeceasedField = document.getElementById('IsDeceasedField');
            const dateOfDeathGroup = document.getElementById('DateOfDeathGroup');

            function toggleDateOfDeathVisibility() {
                if (!isDeceasedField || !dateOfDeathGroup) return;
                dateOfDeathGroup.style.display = isDeceasedField.checked ? '' : 'none';
            }

            if (isDeceasedField && dateOfDeathGroup) {
                isDeceasedField.addEventListener('change', toggleDateOfDeathVisibility);
                toggleDateOfDeathVisibility();
            }
        })();
    </script>
}
