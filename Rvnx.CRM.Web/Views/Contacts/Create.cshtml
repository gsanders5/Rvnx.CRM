@model Rvnx.CRM.Core.DTOs.Contact.ContactCreateViewModel
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = Model.IsSelfCreate ? "Create Self Contact" : "Create Contact";
    var pronounOptions = Model.PronounOptions.Where(o => o != "Other" && o != "Unspecified").ToList();
    var genderOptions = Model.GenderOptions.Where(o => o != "Other" && o != "Unspecified").ToList();
}

<form id="contact-form" asp-action="@(Model.IsSelfCreate ? "CreateSelf" : "Create")" data-edit-form>
    @Html.AntiForgeryToken()
    @if (Model.IsSelfCreate)
    {
        <input type="hidden" asp-for="IsSelfCreate" value="true" />
    }

    @* ── Action strip ────────────────────────────────────────────────────── *@
    <div class="crm-details-actions-strip">
        @if (Model.IsSelfCreate)
        {
            <a asp-controller="Home" asp-action="Index" class="crm-btn-tertiary btn-sm">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Home
            </a>
        }
        else
        {
            <a asp-action="Index" class="crm-btn-tertiary btn-sm">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Contacts
            </a>
        }
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="crm-eyebrow crm-unsaved-indicator" id="unsaved-indicator" hidden>
                <i class="bi bi-circle-fill" aria-hidden="true" style="font-size: 6px; vertical-align: middle; margin-right: 4px;"></i>
                Unsaved
            </span>
            <button type="submit" class="crm-btn-primary btn-sm">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                @(Model.IsSelfCreate ? "Create My Contact" : "Create Contact")
            </button>
        </div>
    </div>

    @* ── Editorial masthead ─────────────────────────────────────────────── *@
    <section class="crm-edit-masthead crm-fade-in">
        <div class="crm-edit-masthead-photo-placeholder" aria-hidden="true">
            <i class="bi bi-person-plus"></i>
        </div>
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 6px;">
                @(Model.IsSelfCreate ? "Your profile" : "New contact")
            </div>
            <h1 class="crm-edit-masthead-title" id="create-name-preview">
                <span id="preview-first">@(string.IsNullOrWhiteSpace(Model.FirstName) ? "Add a name" : Model.FirstName)</span>@if (!string.IsNullOrWhiteSpace(Model.LastName))
                {
                    <text> </text><em id="preview-last">@Model.LastName</em>
                }
                else
                {
                    <text> </text><em id="preview-last"></em>
                }
            </h1>
        </div>
    </section>

    @* ── Body ───────────────────────────────────────────────────────────── *@
    <div class="crm-edit-body">

        @* ── Main column ─────────────────────────────────────────────────── *@
        <div class="crm-edit-col-main">

            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            @* ── Identity ───────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-person-lines-fill" aria-hidden="true"></i> Identity</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-form-card-grid">
                        <div class="crm-field-group">
                            <label asp-for="FirstName">First Name *</label>
                            <input asp-for="FirstName" class="crm-input" id="FirstName" required autofocus />
                            <span asp-validation-for="FirstName" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="LastName">Last Name</label>
                            <input asp-for="LastName" class="crm-input" id="LastName" />
                            <span asp-validation-for="LastName" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="MaidenName">Maiden Name</label>
                            <input asp-for="MaidenName" class="crm-input" placeholder="Optional" />
                            <span asp-validation-for="MaidenName" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Nickname">Nickname</label>
                            <input asp-for="Nickname" class="crm-input" placeholder="Optional" />
                            <span asp-validation-for="Nickname" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Company">Company</label>
                            <input asp-for="Company" class="crm-input" />
                            <span asp-validation-for="Company" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="JobTitle">Job Title</label>
                            <input asp-for="JobTitle" class="crm-input" />
                            <span asp-validation-for="JobTitle" class="crm-field-error"></span>
                        </div>
                    </div>
                </div>
            </div>

            @* ── Personal ───────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-people-fill" aria-hidden="true"></i> Personal</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-form-card-grid">
                        <div class="crm-field-group">
                            <label asp-for="Pronouns">Pronouns</label>
                            <select asp-for="Pronouns" id="pronouns-select" class="crm-input"
                                    data-select2 data-select2-tags data-select2-allow-clear
                                    data-select2-placeholder="Select or enter pronouns...">
                                <option value=""></option>
                                @if (!string.IsNullOrEmpty(Model.Pronouns) && !pronounOptions.Contains(Model.Pronouns))
                                {
                                    <option value="@Model.Pronouns">@Model.Pronouns</option>
                                }
                                @foreach (var option in pronounOptions)
                                {
                                    <option value="@option">@option</option>
                                }
                            </select>
                            <span asp-validation-for="Pronouns" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Gender">Gender</label>
                            <select asp-for="Gender" id="gender-select" class="crm-input"
                                    data-select2 data-select2-tags data-select2-allow-clear
                                    data-select2-placeholder="Select or enter gender...">
                                <option value=""></option>
                                @if (!string.IsNullOrEmpty(Model.Gender) && !genderOptions.Contains(Model.Gender))
                                {
                                    <option value="@Model.Gender">@Model.Gender</option>
                                }
                                @foreach (var option in genderOptions)
                                {
                                    <option value="@option">@option</option>
                                }
                            </select>
                            <span asp-validation-for="Gender" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Religion">Religion</label>
                            <input asp-for="Religion" class="crm-input" placeholder="Optional" />
                            <span asp-validation-for="Religion" class="crm-field-error"></span>
                        </div>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Birthday</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-form-card-grid">
                        @await Html.PartialAsync("_FlexibleDateField", new FlexibleDateFieldModel
                        {
                            Name = "Birthday",
                            Label = "Birthday",
                            Value = Model.Birthday is { } birthday ? DateOnly.FromDateTime(birthday) : null
                        })
                        <div class="crm-field-group">
                            <label class="crm-field-label" for="RemindOnBirthday">Remind on Birthday</label>
                            <label class="crm-toggle">
                                <input asp-for="RemindOnBirthday" aria-label="Remind on birthday" />
                                <span class="crm-toggle-track"></span>
                                <span class="crm-toggle-knob"></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            @* ── Quick Contact (Email + Phone) ─────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-envelope" aria-hidden="true"></i> Quick Contact</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-form-card-grid">
                        <div class="crm-field-group">
                            <label asp-for="Email">Email</label>
                            <input asp-for="Email" type="email" class="crm-input" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Phone">Phone</label>
                            <input asp-for="Phone" type="tel" class="crm-input" placeholder="(555) 555-5555" />
                            <span asp-validation-for="Phone" class="crm-field-error"></span>
                        </div>
                    </div>
                    <div class="crm-field-help" style="margin-top: 10px;">
                        These become the primary email and phone. Add more from the contact's page after creating it.
                    </div>
                </div>
            </div>

            @* ── How We Met ─────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-people" aria-hidden="true"></i> How We Met</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-form-card-grid">
                        <div class="crm-field-group">
                            <label asp-for="FirstMetOn">First Met On</label>
                            <input asp-for="FirstMetOn" type="date" class="crm-input" />
                            <span asp-validation-for="FirstMetOn" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="IntroducedByContactId">Introduced By</label>
                            <select asp-for="IntroducedByContactId" id="introduced-by-select" class="crm-input"
                                    data-select2 data-select2-allow-clear
                                    data-select2-placeholder="Search for a contact...">
                                <option value=""></option>
                                @foreach (var candidate in Model.IntroducerCandidates)
                                {
                                    <option value="@candidate.Id">@candidate.FullName</option>
                                }
                            </select>
                            <span asp-validation-for="IntroducedByContactId" class="crm-field-error"></span>
                        </div>
                    </div>
                    <div class="crm-field-group" style="margin-top: 14px;">
                        <label asp-for="HowWeMet">How We Met Story</label>
                        <textarea asp-for="HowWeMet" class="crm-input" maxlength="1000"
                                  placeholder="Describe how you met this person..."
                                  id="how-we-met-field"></textarea>
                        <div class="crm-char-counter">
                            <span id="how-we-met-count">@(Model.HowWeMet?.Length ?? 0)</span> / 1000
                        </div>
                        <span asp-validation-for="HowWeMet" class="crm-field-error"></span>
                    </div>
                </div>
            </div>

            @if (!Model.IsSelfCreate)
            {
                @* ── Settings — hidden on self-create since the controller coerces IsHidden=false
                     and a user can't mark themselves deceased. ─────────────────── *@
                <div class="crm-card">
                    <div class="crm-card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-sliders" aria-hidden="true"></i> Settings</h5>
                    </div>
                    <div class="crm-card-body">
                        <div class="crm-toggle-row">
                            <div>
                                <div class="crm-toggle-row-label">Hidden</div>
                                <div class="crm-toggle-row-desc">Hidden contacts are excluded from the main list by default.</div>
                            </div>
                            <label class="crm-toggle">
                                <input asp-for="IsHidden" aria-label="Hidden" />
                                <span class="crm-toggle-track"></span>
                                <span class="crm-toggle-knob"></span>
                            </label>
                        </div>

                        <div class="crm-toggle-row">
                            <div>
                                <div class="crm-toggle-row-label">Deceased</div>
                                <div class="crm-toggle-row-desc">Suppresses birthday and anniversary reminders.</div>
                            </div>
                            <label class="crm-toggle">
                                <input asp-for="IsDeceased" id="IsDeceasedField" aria-label="Deceased" />
                                <span class="crm-toggle-track"></span>
                                <span class="crm-toggle-knob"></span>
                            </label>
                        </div>

                        <div class="crm-field-group" id="DateOfDeathGroup" style="margin-top: 12px;">
                            <label asp-for="DateOfDeath">Date of Death</label>
                            <input asp-for="DateOfDeath" type="date" class="crm-input" />
                            <span asp-validation-for="DateOfDeath" class="crm-field-error"></span>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ── Side column ─────────────────────────────────────────────────── *@
        <div class="crm-edit-col-side">

            <div class="crm-save-shortcut-card">
                <div class="crm-save-shortcut-title">
                    @(Model.IsSelfCreate ? "Ready to set up your profile?" : "Ready to create?")
                </div>
                <div class="crm-save-shortcut-desc">
                    @(Model.IsSelfCreate
                        ? "Saving creates your self-contact and returns you home."
                        : "Saving creates the contact and returns you to the contacts list.")
                </div>
                <button type="submit" class="crm-btn-primary btn-sm" form="contact-form">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                    @(Model.IsSelfCreate ? "Create My Contact" : "Create Contact")
                </button>
                @if (Model.IsSelfCreate)
                {
                    <a asp-controller="Home" asp-action="Index" class="crm-btn-tertiary btn-sm">
                        <i class="bi bi-arrow-left" aria-hidden="true"></i> Cancel
                    </a>
                }
                else
                {
                    <a asp-action="Index" class="crm-btn-tertiary btn-sm">
                        <i class="bi bi-arrow-left" aria-hidden="true"></i> Cancel
                    </a>
                }
            </div>

            @if (!Model.IsSelfCreate)
            {
                <div class="crm-card">
                    <div class="crm-card-header">
                        <h5 class="card-title mb-0"><i class="bi bi-stars" aria-hidden="true"></i> Next steps</h5>
                    </div>
                    <div class="crm-card-body" style="font-size: 13px; color: var(--crm-text-secondary); line-height: 1.5;">
                        After saving, the contact's Details page lets you add:
                        <ul style="margin: 10px 0 0; padding-left: 20px; color: var(--crm-text-secondary);">
                            <li>Profile photo &amp; additional contact methods</li>
                            <li>Labels &amp; relationships</li>
                            <li>Addresses, important dates, notes</li>
                            <li>Activities, tasks, attachments</li>
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            // ── Live name preview in the masthead ──
            const firstInput = document.getElementById('FirstName');
            const lastInput = document.getElementById('LastName');
            const previewFirst = document.getElementById('preview-first');
            const previewLast = document.getElementById('preview-last');
            function updateNamePreview() {
                const first = (firstInput.value || '').trim();
                const last = (lastInput.value || '').trim();
                previewFirst.textContent = first || 'Add a name';
                previewLast.textContent = last;
            }
            firstInput.addEventListener('input', updateNamePreview);
            lastInput.addEventListener('input', updateNamePreview);

            // ── Deceased toggle reveals/hides Date of Death (non-self-create only) ──
            const isDeceasedField = document.getElementById('IsDeceasedField');
            const dateOfDeathGroup = document.getElementById('DateOfDeathGroup');

            function toggleDateOfDeathVisibility() {
                if (!isDeceasedField || !dateOfDeathGroup) return;
                dateOfDeathGroup.style.display = isDeceasedField.checked ? '' : 'none';
            }

            if (isDeceasedField && dateOfDeathGroup) {
                isDeceasedField.addEventListener('change', toggleDateOfDeathVisibility);
                toggleDateOfDeathVisibility();
            }

            // ── How We Met char counter ──
            const howWeMetField = document.getElementById('how-we-met-field');
            const howWeMetCount = document.getElementById('how-we-met-count');
            if (howWeMetField && howWeMetCount) {
                howWeMetField.addEventListener('input', function () {
                    howWeMetCount.textContent = howWeMetField.value.length;
                });
            }

        })();

        // ── Duplicate name check ──
        (function () {
            const firstNameInput = document.getElementById('FirstName');
            const lastNameInput = document.getElementById('LastName');
            if (!firstNameInput) return;

            let dupWarning = document.createElement('div');
            dupWarning.id = 'dup-warning';
            dupWarning.style.cssText = 'display:none; margin-top: 8px; padding: 8px 12px; background: var(--crm-surface-secondary); border: 1px solid var(--crm-warning); border-radius: 6px; font-size: 0.85rem; color: var(--crm-text-primary);';
            firstNameInput.closest('.crm-card-body').appendChild(dupWarning);

            let debounceTimer;
            function checkDuplicate() {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(async function () {
                    const first = firstNameInput.value.trim();
                    const last = lastNameInput ? lastNameInput.value.trim() : '';
                    if (!first) { dupWarning.style.display = 'none'; return; }
                    try {
                        const params = new URLSearchParams({ firstName: first });
                        if (last) params.set('lastName', last);
                        const resp = await fetch('@Url.Action("CheckDuplicate")?' + params.toString());
                        const matches = await resp.json();
                        if (matches.length > 0) {
                            // Build with DOM methods — contact names are user data and must not hit innerHTML.
                            dupWarning.replaceChildren();
                            const icon = document.createElement('i');
                            icon.className = 'bi bi-exclamation-triangle-fill me-2';
                            icon.setAttribute('aria-hidden', 'true');
                            dupWarning.appendChild(icon);
                            dupWarning.appendChild(document.createTextNode('A contact with this name already exists: '));
                            matches.forEach(function (m, i) {
                                if (i > 0) dupWarning.appendChild(document.createTextNode(', '));
                                const a = document.createElement('a');
                                a.href = '@Url.Action("Details")/' + encodeURIComponent(m.id);
                                a.target = '_blank';
                                a.style.fontWeight = '600';
                                a.textContent = m.name;
                                dupWarning.appendChild(a);
                            });
                            dupWarning.appendChild(document.createTextNode('. You can still save if this is a different person.'));
                            dupWarning.style.display = '';
                        } else {
                            dupWarning.style.display = 'none';
                        }
                    } catch { dupWarning.style.display = 'none'; }
                }, 500);
            }

            firstNameInput.addEventListener('input', checkDuplicate);
            if (lastNameInput) lastNameInput.addEventListener('input', checkDuplicate);
        })();
    </script>
}
