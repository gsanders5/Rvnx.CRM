@using Rvnx.CRM.Core.DTOs.Contact
@using Rvnx.CRM.Core.Enumerations
@using Rvnx.CRM.Core.Constants
@model ContactDetailDto

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@functions {

    public string GetAntiXsrfRequestToken()
    {
        return Antiforgery.GetAndStoreTokens(Context).RequestToken ?? string.Empty;
    }

}

@{
    ViewData["Title"] = "Details";
}

<div class="container">
<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
    <h1 class="mb-0 text-center text-md-start">@Model.FullName</h1>
    <div class="d-flex gap-2 flex-wrap justify-content-center">
        <a asp-action="Export" asp-route-id="@Model.Id" class="btn btn-outline-primary"><i class="fa-solid fa-file-export"></i> Export VCF</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil-square"></i> Edit</a>
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row">
<!-- Main Info -->
<div class="col-md-4">
    <!-- Profile Card -->
    <div class="card mb-4 shadow-sm">
        @if (Model.ProfileImageId.HasValue)
        {
            <img src="@Url.Action("View", "Attachments", new { id = Model.ProfileImageId })" class="card-img-top card-img-profile" alt="Profile Image">
        }
        else
        {
            <div class="card-img-top d-flex align-items-center justify-content-center bg-body-tertiary text-muted" style="height: 300px;">
                <i class="bi bi-person-fill display-1"></i>
            </div>
        }
        <div class="card-header">
            <h5 class="card-title mb-0"><i class="bi bi-person-lines-fill"></i> Primary Info</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                @if (!string.IsNullOrEmpty(Model.Nickname))
                {
                    <dt class="col-sm-4">Nickname</dt>
                    <dd class="col-sm-8">@Model.Nickname</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Company))
                {
                    <dt class="col-sm-4">Company</dt>
                    <dd class="col-sm-8">@Model.Company</dd>
                }

                @if (!string.IsNullOrEmpty(Model.JobTitle))
                {
                    <dt class="col-sm-4">Job Title</dt>
                    <dd class="col-sm-8">@Model.JobTitle</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Pronouns))
                {
                    <dt class="col-sm-4">Pronouns</dt>
                    <dd class="col-sm-8">@Model.Pronouns</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Gender))
                {
                    <dt class="col-sm-4">Gender</dt>
                    <dd class="col-sm-8">@Model.Gender</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Religion))
                {
                    <dt class="col-sm-4">Religion</dt>
                    <dd class="col-sm-8">@Model.Religion</dd>
                }
            </dl>
        </div>
    </div>

    <!-- Additional Contact Info -->
    <div class="card mb-4 border shadow-sm">
        <div class="card-header bg-transparent border-0 pt-3 px-3 d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0 fw-bold"><i class="bi bi-person-badge"></i> Contact Info</h5>
            <a asp-controller="ContactMethods" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="btn btn-sm btn-outline-primary"><i class="bi bi-plus-lg"></i> Add</a>
        </div>
        <div class="card-body px-3 pb-3">
            @if (Model.ContactMethods != null && Model.ContactMethods.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var info in Model.ContactMethods)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <div class="fw-bold">@info.Type @(string.IsNullOrEmpty(info.Label) ? "" : $"({info.Label})")</div>
                                <div class="text-break">
                                    @if (info.Type == ContactMethodType.Email)
                                    {
                                        <a href="mailto:@info.Value">@info.Value</a>
                                    }
                                    else if (info.Type == ContactMethodType.Phone)
                                    {
                                        <a href="tel:@info.Value">@info.Value</a>
                                    }
                                    else if (info.Type == ContactMethodType.Website || info.Value.StartsWith("http"))
                                    {
                                        <a href="@info.Value" target="_blank">@info.Value</a>
                                    }
                                    else
                                    {
                                        @info.Value
                                    }
                                </div>
                            </div>
                            <div class="btn-group btn-group-sm">
                                <button type="button" class="btn btn-outline-secondary btn-copy" data-clipboard-text="@info.Value" title="Copy to clipboard" aria-label="Copy @info.Value to clipboard">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                                <a asp-controller="ContactMethods" asp-action="Edit" asp-route-id="@info.Id" class="btn btn-outline-secondary" title="Edit" aria-label="Edit @info.Type @info.Value">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-controller="ContactMethods" asp-action="Delete" asp-route-id="@info.Id" class="btn btn-outline-danger" title="Delete" aria-label="Delete @info.Type @info.Value">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-person-badge display-6 d-block mb-3 opacity-25"></i>
                    <p class="mb-2">No additional info.</p>
                    <a asp-controller="ContactMethods" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="btn btn-sm btn-primary mt-2"><i class="bi bi-plus-lg"></i> Add Info</a>
                </div>
            }

            @if (Model.Labels != null && Model.Labels.Any())
            {
                <div class="mt-3 pt-3 border-top d-flex gap-1 flex-wrap">
                    @foreach (var label in Model.Labels)
                    {
                        @await Html.PartialAsync("_LabelBadge", label)
                    }
                </div>
            }
        </div>
    </div>

    <!-- Quick Facts -->
    <div class="card mb-4 border shadow-sm">
        <div class="card-header bg-transparent border-0 pt-3 px-3 d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0 fw-bold"><i class="bi bi-lightbulb"></i> Quick Facts</h5>
            <a asp-controller="Facts" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="btn btn-sm btn-outline-primary"><i class="bi bi-plus-lg"></i> Add</a>
        </div>
        <div class="card-body px-3 pb-3">
            @if (Model.Facts != null && Model.Facts.Any())
            {
                var groups = Model.Facts.GroupBy(f => f.Category).OrderBy(g => g.Key);

                foreach (var group in groups)
                {
                    <h6 class="text-primary small fw-bold mt-2 mb-1 border-bottom pb-1">@group.Key</h6>
                    <ul class="list-group list-group-flush mb-2">
                        @foreach (var fact in group)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-1 border-0 bg-transparent">
                                <div class="d-none note-source">@fact.Value</div>
                                <div class="note-render"></div>
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-outline-secondary btn-copy" data-clipboard-text="@fact.Value" title="Copy to clipboard" aria-label="Copy fact to clipboard">
                                        <i class="bi bi-clipboard"></i>
                                    </button>
                                    <a asp-controller="Facts" asp-action="Edit" asp-route-id="@fact.Id" class="btn btn-outline-secondary" title="Edit fact" aria-label="Edit fact">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-controller="Facts" asp-action="Delete" asp-route-id="@fact.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this fact?');">
                                        <button type="submit" class="btn btn-outline-danger" title="Delete fact" aria-label="Delete fact">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                }
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-lightbulb display-6 d-block mb-3 opacity-25"></i>
                    <p class="mb-2">No facts added.</p>
                    <a asp-controller="Facts" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="btn btn-sm btn-primary mt-2"><i class="bi bi-plus-lg"></i> Add Fact</a>
                </div>
            }
        </div>
    </div>

    <!-- Relationships -->
    <div class="card mb-4 border shadow-sm">
        <div class="card-header bg-transparent border-0 pt-3 px-3">
            <h5 class="card-title mb-0 fw-bold"><i class="bi bi-people"></i> Relationships</h5>
        </div>
        <div class="card-body px-3 pb-3">
            @{
                var categoryOrder = new[] { "Romantic", "Family", "Professional", "Social" };
                var alwaysExpanded = new HashSet<string> { "Romantic", "Family" };

                var allRels = (Model.Relationships ?? [])
                    .Select(r => new
                    {
                        Name = r.RelatedEntityName,
                        LinkId = r.RelatedEntityId,
                        IsPartial = r.IsRelatedEntityPartial,
                        Badge = r.RelationshipTypeOppositeName,
                        Category = r.RelationshipTypeCategory,
                        r.Id
                    })
                    .Concat((Model.RelatedTo ?? [])
                        .Select(r => new
                        {
                            Name = r.EntityName,
                            LinkId = r.EntityId,
                            IsPartial = r.IsEntityPartial,
                            Badge = r.RelationshipTypeName,
                            Category = r.RelationshipTypeCategory,
                            r.Id
                        }))
                    .ToList();

                var grouped = allRels
                    .GroupBy(r => r.Category)
                    .OrderBy(g =>
                    {
                        var idx = Array.IndexOf(categoryOrder, g.Key);
                        return idx < 0 ? 99 : idx;
                    })
                    .ToList();
            }

            <div class="d-grid gap-2 mb-3">
                @if (grouped.Any())
                {
                    var accordionId = "relAccordion";
                    <div class="accordion accordion-flush" id="@accordionId">
                        @foreach (var group in grouped)
                        {
                            var collapseId = $"relCollapse_{group.Key.Replace(" ", "")}";
                            var count = group.Count();
                            var expanded = alwaysExpanded.Contains(group.Key) || count <= 5;
                            <div class="accordion-item border rounded p-1 mb-2">
                                <h2 class="accordion-header">
                                    <button class="accordion-button @(expanded ? "" : "collapsed") fw-semibold py-2 bg-body text-body" type="button"
                                            data-mdb-collapse-init data-mdb-toggle="collapse" data-mdb-target="#@collapseId"
                                            aria-expanded="@(expanded ? "true" : "false")" aria-controls="@collapseId">
                                        @group.Key
                                        <span class="badge bg-secondary ms-2 fw-normal">@count</span>
                                    </button>
                                </h2>
                                <div id="@collapseId" class="accordion-collapse collapse @(expanded ? "show" : "")">
                                    <div class="accordion-body px-0 pt-0 pb-2">
                                        <div class="d-grid gap-2 px-3 pt-2">
                                            @foreach (var rel in group)
                                            {
                                                <div class="d-flex justify-content-between align-items-center p-3 rounded border hover-shadow" style="background-color: var(--bs-tertiary-bg);">
                                                    <div class="d-flex align-items-center">
                                                        @if (rel.IsPartial)
                                                        {
                                                            <span class="fw-bold text-muted me-2">@rel.Name</span>
                                                        }
                                                        else
                                                        {
                                                            <a asp-action="Details" asp-route-id="@rel.LinkId" class="text-decoration-none fw-bold text-body me-2">@rel.Name</a>
                                                        }
                                                        <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">@rel.Badge</span>
                                                    </div>
                                                    <div class="d-flex align-items-center">
                                                        @if (rel.IsPartial)
                                                        {
                                                            <div class="d-inline me-2" title="Partial Contact">
                                                                <span class="badge bg-secondary opacity-50">
                                                                    <i class="bi bi-person-fill-exclamation text-white"></i>
                                                                </span>
                                                            </div>
                                                        }
                                                        <a asp-controller="Relationships" asp-action="Edit" asp-route-id="@rel.Id" class="text-secondary me-2" title="Edit relationship">
                                                            <i class="bi bi-pencil-square"></i>
                                                        </a>
                                                        <a asp-controller="Relationships" asp-action="Delete" asp-route-id="@rel.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" class="text-danger" title="Delete relationship">
                                                            <i class="bi bi-trash"></i>
                                                        </a>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-people display-6 d-block mb-3 opacity-25"></i>
                        <p class="mb-2">No relationships found.</p>
                        <a asp-controller="Relationships" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="btn btn-sm btn-primary mt-2"><i class="bi bi-plus-lg"></i> Add Relationship</a>
                    </div>
                }
            </div>

            @if (grouped.Any())
            {
                <div class="text-end">
                    <a asp-controller="Relationships" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="btn btn-primary btn-sm">Add Relationship</a>
                </div>
            }
        </div>
    </div>

    <!-- Pets -->
    <div class="card mb-4 border shadow-sm">
        <div class="card-header bg-transparent border-0 pt-3 px-3 d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0 fw-bold"><i class="bi bi-emoji-smile"></i> Pets</h5>
            <a asp-controller="Pets" asp-action="Create" asp-route-entityId="@Model.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-plus-lg"></i> Add</a>
        </div>
        <div class="card-body px-3 pb-3">
            @if (Model.Pets != null && Model.Pets.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var pet in Model.Pets)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <div class="fw-bold">@pet.Name</div>
                                <small class="text-muted">@pet.Species @(string.IsNullOrEmpty(pet.Breed) ? "" : $"({pet.Breed})")</small>
                            </div>
                            <div class="btn-group btn-group-sm">
                                <a asp-controller="Pets" asp-action="Edit" asp-route-id="@pet.Id" class="btn btn-outline-secondary" title="Edit" aria-label="Edit @pet.Name">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-controller="Pets" asp-action="Delete" asp-route-id="@pet.Id" class="btn btn-outline-danger" title="Delete" aria-label="Delete @pet.Name">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-emoji-smile display-6 d-block mb-3 opacity-25"></i>
                    <p class="mb-2">No pets.</p>
                    <a asp-controller="Pets" asp-action="Create" asp-route-entityId="@Model.Id" class="btn btn-sm btn-primary mt-2"><i class="bi bi-plus-lg"></i> Add Pet</a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Right Column -->
<div class="col-md-8">
    <!-- Important Dates -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0"><i class="bi bi-calendar-event"></i> Important Dates</h5>
            <a asp-controller="SignificantDates" asp-action="Index" asp-route-contactId="@Model.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-gear"></i> Manage Dates</a>
        </div>
        <div class="card-body">
            @if (Model.SignificantDates != null && Model.SignificantDates.Any())
            {
                <ul class="list-group">
                    @foreach (var date in Model.SignificantDates.OrderBy(d => d.EventDate))
                    {
                        <li class="list-group-item">
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <h6 class="mb-1 me-2">@date.Title</h6>
                                <div class="d-flex flex-wrap gap-1 align-items-center justify-content-end">
                                    <span class="badge bg-info text-dark">@date.EventDate.ToShortDateString()</span>

                                    @if (string.Equals(date.Title, SignificantDateTitles.Birthday, StringComparison.OrdinalIgnoreCase))
                                    {
                                        var today = DateTime.Today;
                                        var age = today.Year - date.EventDate.Year;
                                        if (date.EventDate.ToDateTime(TimeOnly.MinValue).Date > today.AddYears(-age)) age--;
                                        <span class="badge bg-secondary">@age years old</span>
                                    }

                                    @if (date.IsActive)
                                    {
                                        <span class="badge bg-success text-dark">Active</span>
                                    }

                                    @if (date.ReminderOffsets != null && date.ReminderOffsets.Any(r => r.IsActive))
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-bell-fill"></i> Reminders</span>
                                    }

                                    <div class="btn-group btn-group-sm">
                                        <a asp-controller="SignificantDates" asp-action="Edit" asp-route-id="@date.Id" class="btn btn-outline-secondary" title="Edit" aria-label="Edit @date.Title">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-controller="SignificantDates" asp-action="Delete" asp-route-id="@date.Id" class="btn btn-outline-danger" title="Delete" aria-label="Delete @date.Title">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(date.Description) && date.Description != date.Title)
                            {
                                <p class="mb-1 text-muted small">@date.Description</p>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-calendar-event display-6 d-block mb-3 opacity-25"></i>
                    <p class="mb-2">No important dates recorded.</p>
                    <a asp-controller="SignificantDates" asp-action="Create" asp-route-contactId="@Model.Id" asp-route-entityType="Person" class="btn btn-sm btn-primary mt-2"><i class="bi bi-plus-lg"></i> Add Date</a>
                </div>
            }
        </div>
    </div>


    <!-- Notes -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0"><i class="bi bi-journal-text"></i> Notes</h5>
            <a asp-controller="Notes" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="btn btn-sm btn-outline-primary"><i class="bi bi-plus-lg"></i> Add</a>
        </div>
        <div class="card-body">
            @if (Model.Notes != null && Model.Notes.Any())
            {
                @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedDate))
                {
                    <div class="card mb-2">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <h6 class="card-subtitle mb-2 text-muted">
                                    @note.Title <small>@note.CreatedDate.ToShortDateString()</small>
                                </h6>
                                <div class="btn-group btn-group-sm">
                                    <a asp-controller="Notes" asp-action="Edit" asp-route-id="@note.Id" class="btn btn-outline-secondary" title="Edit" aria-label="Edit @note.Title">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-controller="Notes" asp-action="Delete" asp-route-id="@note.Id" class="btn btn-outline-danger" title="Delete" aria-label="Delete @note.Title">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="d-none note-source">@note.Value</div>
                            <div class="note-render card-text"></div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-journal-text display-6 d-block mb-3 opacity-25"></i>
                    <p class="mb-2">No notes available.</p>
                    <a asp-controller="Notes" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="btn btn-sm btn-primary mt-2"><i class="bi bi-plus-lg"></i> Add Note</a>
                </div>
            }
        </div>
    </div>

    <!-- Attachments -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0"><i class="bi bi-paperclip"></i> Attachments</h5>
            <button type="button" class="btn btn-sm btn-outline-primary" data-mdb-collapse-init data-mdb-toggle="collapse" data-mdb-target="#uploadAttachmentForm" aria-expanded="false" aria-controls="uploadAttachmentForm">
                <i class="bi bi-plus-lg"></i> Add
            </button>
        </div>
        <div class="card-body">
            <div class="collapse mb-3" id="uploadAttachmentForm">
                <form asp-controller="Attachments" asp-action="Upload" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" method="post" enctype="multipart/form-data" class="border p-3 rounded bg-body-tertiary">
                    <input type="hidden" name="entityId" value="@Model.Id"/>
                    <input type="hidden" name="entityType" value="Person"/>
                    <div class="mb-2">
                        <label for="file" class="form-label small">Select File</label>
                        <input type="file" name="file" class="form-control form-control-sm" required/>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">Upload</button>
                </form>
            </div>

            @if (Model.Attachments != null && Model.Attachments.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var attachment in Model.Attachments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div class="d-flex flex-column overflow-hidden w-100 me-2">
                                @if (!string.IsNullOrEmpty(attachment.ContentType) && attachment.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                                {
                                    <a href="@Url.Action("View", "Attachments", new { id = attachment.Id })" target="_blank" class="mb-2 d-block">
                                        <img src="@Url.Action("View", "Attachments", new { id = attachment.Id })" class="img-fluid rounded border" alt="@attachment.FileName" loading="lazy" style="max-height: 300px; object-fit: contain;"/>
                                    </a>
                                }
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-file-earmark me-2 text-secondary"></i>
                                    <a asp-controller="Attachments" asp-action="Download" asp-route-id="@attachment.Id" class="text-truncate" title="@attachment.FileName">
                                        @attachment.FileName
                                    </a>
                                </div>
                            </div>
                            <div class="btn-group btn-group-sm ms-2 align-self-start">
                                <a asp-controller="Attachments" asp-action="Download" asp-route-id="@attachment.Id" class="btn btn-outline-secondary" title="Download" aria-label="Download @attachment.FileName">
                                    <i class="bi bi-download"></i>
                                </a>
                                @if (!string.IsNullOrEmpty(attachment.ContentType) && attachment.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
                                {
                                    <form method="post" class="d-inline" action="/Attachments/@attachment.Id/SetAsProfilePhoto?returnUrl=@(Context.Request.Path + Context.Request.QueryString)">
                                        <button type="submit" class="btn btn-outline-primary" title="Set as profile photo" aria-label="Set @attachment.FileName as profile photo">
                                            <i class="bi bi-person-circle"></i>
                                        </button>
                                        <input name="__RequestVerificationToken" type="hidden" value="@GetAntiXsrfRequestToken()"/>
                                    </form>
                                }
                                <form asp-controller="Attachments" asp-action="Delete" asp-route-id="@attachment.Id" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" method="post" class="d-inline" onsubmit="return confirm('Are you sure?');">
                                    <button type="submit" class="btn btn-outline-danger" title="Delete" aria-label="Delete @attachment.FileName">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-paperclip display-6 d-block mb-3 opacity-25"></i>
                    <p class="mb-2">No attachments.</p>
                    <button type="button" class="btn btn-sm btn-primary mt-2" data-mdb-collapse-init data-mdb-toggle="collapse" data-mdb-target="#uploadAttachmentForm" aria-expanded="false" aria-controls="uploadAttachmentForm">
                        <i class="bi bi-plus-lg"></i> Add Attachment
                    </button>
                </div>
            }
        </div>
    </div>

</div>
</div>
</div>

@section Scripts {
    <script src="~/js/markdown-renderer.js" asp-append-version="true"></script>
}
