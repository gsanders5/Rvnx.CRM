@using Rvnx.CRM.Core.DTOs.Contact
@using Rvnx.CRM.Core.Enumerations
@using Rvnx.CRM.Core.Constants
@using Rvnx.CRM.Core.Helpers
@model ContactDetailDto

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery

@functions {

    public string GetAntiXsrfRequestToken()
    {
        return Antiforgery.GetAndStoreTokens(Context).RequestToken ?? string.Empty;
    }

}

@{
    ViewData["Title"] = "Details";
}

<div class="container">
<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3 crm-action-bar">
    <div class="d-flex flex-column align-items-center align-items-md-start">
        <h1 class="mb-0 text-center text-md-start">@Model.FullName</h1>
        @if (Model.IsDeceased)
        {
            <span class="crm-badge crm-badge-muted mt-1" title="This contact is marked as deceased">
                <i class="bi bi-flower1 me-1" aria-hidden="true"></i>
                @if (Model.DateOfDeath.HasValue)
                {
                    <text>Deceased on @Model.DateOfDeath.Value.ToString("yyyy-MM-dd")</text>
                }
                else
                {
                    <text>Deceased</text>
                }
            </span>
        }
    </div>

    @* Desktop action buttons *@
    <div class="d-none d-md-flex gap-2 flex-wrap justify-content-center crm-action-bar-full">
        <a asp-controller="Merge" asp-action="Index" asp-route-primaryId="@Model.Id" class="crm-btn-secondary btn-sm"><i class="bi bi-diagram-3" aria-hidden="true"></i> Merge</a>
        <a asp-action="Export" asp-route-id="@Model.Id" class="crm-btn-secondary btn-sm"><i class="fa-solid fa-file-export" aria-hidden="true"></i> Export VCF</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="crm-btn-primary btn-sm"><i class="bi bi-pencil-square" aria-hidden="true"></i> Edit</a>
        <a asp-action="Index" class="crm-btn-tertiary btn-sm"><i class="bi bi-arrow-left" aria-hidden="true"></i> Back</a>
    </div>

    @* Mobile action dropdown *@
    <div class="d-flex d-md-none gap-2 crm-action-bar-mobile">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="crm-btn-primary btn-sm"><i class="bi bi-pencil-square" aria-hidden="true"></i> Edit</a>
        <div class="dropdown">
            <button class="crm-btn-secondary btn-sm dropdown-toggle" type="button" data-mdb-dropdown-init data-mdb-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-three-dots-vertical" aria-hidden="true"></i> Actions
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" asp-controller="Merge" asp-action="Index" asp-route-primaryId="@Model.Id"><i class="bi bi-diagram-3 me-2" aria-hidden="true"></i>Merge</a></li>
                <li><a class="dropdown-item" asp-action="Export" asp-route-id="@Model.Id"><i class="fa-solid fa-file-export me-2" aria-hidden="true"></i>Export VCF</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" asp-action="Index"><i class="bi bi-arrow-left me-2" aria-hidden="true"></i>Back to Contacts</a></li>
            </ul>
        </div>
    </div>
</div>

<div class="row">
<!-- Left Column -->
<div class="col-md-4">
    <!-- Profile Card -->
    <div class="crm-card">
        @if (Model.ProfileImageId.HasValue)
        {
            <img src="@Url.Action("Thumbnail", "Attachments", new { id = Model.ProfileImageId, maxWidth = 400 })" class="crm-profile-image w-100" alt="Profile photo of @Model.FullName" loading="lazy" style="border-radius: var(--crm-radius-md) var(--crm-radius-md) 0 0;">
        }
        else
        {
            <div class="crm-profile-placeholder" role="img" aria-label="Default profile placeholder">
                <i class="bi bi-person-fill display-1" aria-hidden="true"></i>
            </div>
        }
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-person-lines-fill" aria-hidden="true"></i> <span class="crm-section-label">Primary Info</span></h5>
        </div>
        <div class="crm-card-body">
            <dl class="row mb-0" style="font-size: 0.875rem; line-height: 1.5;">
                @if (!string.IsNullOrEmpty(Model.MaidenName))
                {
                    <dt class="col-sm-4" style="color: var(--crm-text-secondary);">Maiden Name</dt>
                    <dd class="col-sm-8">@Model.MaidenName</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Nickname))
                {
                    <dt class="col-sm-4" style="color: var(--crm-text-secondary);">Nickname</dt>
                    <dd class="col-sm-8">@Model.Nickname</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Company))
                {
                    <dt class="col-sm-4" style="color: var(--crm-text-secondary);">Company</dt>
                    <dd class="col-sm-8">@Model.Company</dd>
                }

                @if (!string.IsNullOrEmpty(Model.JobTitle))
                {
                    <dt class="col-sm-4" style="color: var(--crm-text-secondary);">Job Title</dt>
                    <dd class="col-sm-8">@Model.JobTitle</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Pronouns))
                {
                    <dt class="col-sm-4" style="color: var(--crm-text-secondary);">Pronouns</dt>
                    <dd class="col-sm-8">@Model.Pronouns</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Gender))
                {
                    <dt class="col-sm-4" style="color: var(--crm-text-secondary);">Gender</dt>
                    <dd class="col-sm-8">@Model.Gender</dd>
                }

                @if (!string.IsNullOrEmpty(Model.Religion))
                {
                    <dt class="col-sm-4" style="color: var(--crm-text-secondary);">Religion</dt>
                    <dd class="col-sm-8">@Model.Religion</dd>
                }
            </dl>
        </div>
    </div>

    <!-- Contact Info -->
    <div class="crm-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-person-badge" aria-hidden="true"></i> Contact Info</h5>
            <a asp-controller="ContactMethods" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="crm-btn-secondary btn-sm" aria-label="Add Contact Info"><i class="bi bi-plus-lg" aria-hidden="true"></i> Add</a>
        </div>
        <div class="crm-card-body">
            @if (Model.ContactMethods != null && Model.ContactMethods.Any())
            {
                @foreach (var info in Model.ContactMethods)
                {
                    <div class="crm-list-item d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-semibold" style="font-size: 0.875rem;">@info.Type @(string.IsNullOrEmpty(info.Label) ? "" : $"({info.Label})")</div>
                            <div class="text-break" style="font-size: 0.875rem;">
                                @if (info.Type == ContactMethodType.Email)
                                {
                                    <a href="mailto:@info.Value" style="color: var(--crm-brand);">@info.Value</a>
                                }
                                else if (info.Type == ContactMethodType.Phone)
                                {
                                    <a href="@PhoneNumberNormalizer.FormatForTelUri(info.Value)" style="color: var(--crm-brand);">@PhoneNumberNormalizer.FormatForDisplay(info.Value)</a>
                                }
                                else if (info.Type == ContactMethodType.Website || info.Value.StartsWith("http"))
                                {
                                    <a href="@info.Value" target="_blank" style="color: var(--crm-brand);">@info.Value</a>
                                }
                                else
                                {
                                    @info.Value
                                }
                            </div>
                        </div>
                        <div class="crm-icon-actions">
                            <button type="button" class="crm-icon-btn icon-copy btn-copy" data-clipboard-text="@info.Value" title="Copy to clipboard" aria-label="Copy @info.Value to clipboard">
                                <i class="bi bi-clipboard" aria-hidden="true"></i>
                            </button>
                            <a asp-controller="ContactMethods" asp-action="Edit" asp-route-id="@info.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @info.Type @info.Value">
                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                            </a>
                            <button type="button" class="crm-icon-btn icon-danger"
                                    data-confirm-action="@Url.Action("Delete", "ContactMethods", new { id = info.Id })"
                                    data-confirm-title="Delete Contact Method"
                                    data-confirm-body="Are you sure you want to delete @info.Type (@info.Value)?"
                                    data-confirm-reload
                                    title="Delete" aria-label="Delete @info.Type @info.Value">
                                <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="crm-empty py-2">
                    <i class="bi bi-person-badge" aria-hidden="true"></i>
                    <span>Add emails, phone numbers, or websites.</span>
                </div>
            }

            <!-- Addresses -->
            <div class="mt-3 pt-3" style="border-top: 1px solid var(--crm-border-subtle);">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="crm-section-label mb-0"><i class="bi bi-geo-alt me-1" aria-hidden="true"></i> ADDRESSES</h6>
                    <a asp-controller="Addresses" asp-action="Create" asp-route-entityId="@Model.Id" class="crm-btn-secondary btn-sm" style="padding: 0.125rem 0.5rem;" aria-label="Add Address"><i class="bi bi-plus-lg" aria-hidden="true"></i></a>
                </div>
                @if (Model.Addresses != null && Model.Addresses.Any())
                {
                    @foreach (var address in Model.Addresses)
                    {
                        <div class="crm-list-item d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-semibold" style="font-size: 0.875rem;">@address.AddressType</div>
                                <div class="text-break" style="font-size: 0.875rem; color: var(--crm-text-secondary);">
                                    @address.Line1<br/>
                                    @if (!string.IsNullOrWhiteSpace(address.Line2))
                                    {
                                        @address.Line2<br/>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(address.City) || !string.IsNullOrWhiteSpace(address.State) || !string.IsNullOrWhiteSpace(address.Zip))
                                    {
                                        var cityStateZip = string.Join(", ",
                                            new[] { address.City, address.State }.Where(s => !string.IsNullOrWhiteSpace(s)));
                                        if (!string.IsNullOrWhiteSpace(address.Zip))
                                        {
                                            cityStateZip = string.IsNullOrEmpty(cityStateZip) ? address.Zip : $"{cityStateZip} {address.Zip}";
                                        }
                                        @cityStateZip<br/>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(address.Country))
                                    {
                                        @address.Country
                                    }
                                </div>
                            </div>
                            <div class="crm-icon-actions">
                                <a asp-controller="Addresses" asp-action="Edit" asp-route-id="@address.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @address.AddressType address">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                </a>
                                <button type="button" class="crm-icon-btn icon-danger"
                                        data-confirm-action="@Url.Action("Delete", "Addresses", new { id = address.Id })"
                                        data-confirm-title="Delete Address"
                                        data-confirm-body="Are you sure you want to delete this @address.AddressType address?"
                                        data-confirm-reload
                                        title="Delete" aria-label="Delete @address.AddressType address">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="crm-meta mb-0">No addresses on file.</p>
                }
            </div>

            @if (Model.Labels != null && Model.Labels.Any())
            {
                <div class="mt-3 pt-3 d-flex gap-1 flex-wrap" style="border-top: 1px solid var(--crm-border-subtle);">
                    @foreach (var label in Model.Labels)
                    {
                        @await Html.PartialAsync("_LabelBadge", label)
                    }
                </div>
            }
        </div>
    </div>

    <!-- Quick Facts -->
    <div class="crm-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-lightbulb" aria-hidden="true"></i> Quick Facts</h5>
            <a asp-controller="Facts" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="crm-btn-secondary btn-sm" aria-label="Add Quick Fact"><i class="bi bi-plus-lg" aria-hidden="true"></i> Add</a>
        </div>
        <div class="crm-card-body">
            @if (Model.Facts != null && Model.Facts.Any())
            {
                var groups = Model.Facts.GroupBy(f => f.Category).OrderBy(g => g.Key);

                foreach (var group in groups)
                {
                    <div class="crm-fact-category">@group.Key</div>
                    @foreach (var fact in group)
                    {
                        <div class="crm-list-item d-flex justify-content-between align-items-center py-1">
                            <div>
                                <div class="d-none note-source">@fact.Value</div>
                                <div class="note-render" style="font-size: 0.875rem;"></div>
                            </div>
                            <div class="crm-icon-actions">
                                <button type="button" class="crm-icon-btn icon-copy btn-copy" data-clipboard-text="@fact.Value" title="Copy to clipboard" aria-label="Copy fact to clipboard">
                                    <i class="bi bi-clipboard" aria-hidden="true"></i>
                                </button>
                                <a asp-controller="Facts" asp-action="Edit" asp-route-id="@fact.Id" class="crm-icon-btn icon-edit" title="Edit fact" aria-label="Edit fact">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                </a>
                                <button type="button" class="crm-icon-btn icon-danger"
                                        data-confirm-action="@Url.Action("Delete", "Facts", new { id = fact.Id })"
                                        data-confirm-title="Delete Fact"
                                        data-confirm-body="Are you sure you want to delete this fact?"
                                        data-confirm-reload
                                        title="Delete fact" aria-label="Delete fact">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
            }
            else
            {
                <div class="crm-empty py-2">
                    <i class="bi bi-lightbulb" aria-hidden="true"></i>
                    <span>Store memorable details and key info.</span>
                </div>
            }
        </div>
    </div>

    <!-- Relationships -->
    <div class="crm-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-people" aria-hidden="true"></i> Relationships</h5>
        </div>
        <div class="crm-card-body">
            @{
                var categoryOrder = new[] { "Romantic", "Family", "Professional", "Social" };
                var alwaysExpanded = new HashSet<string> { "Romantic" };

                var allRels = (Model.Relationships ?? [])
                    .Select(r => new
                    {
                        Name = r.RelatedEntityName,
                        LinkId = r.RelatedEntityId,
                        IsPartial = r.IsRelatedEntityPartial,
                        Badge = r.RelationshipTypeOppositeName,
                        Category = r.RelationshipTypeCategory,
                        r.Id
                    })
                    .Concat((Model.RelatedTo ?? [])
                        .Select(r => new
                        {
                            Name = r.EntityName,
                            LinkId = r.EntityId,
                            IsPartial = r.IsEntityPartial,
                            Badge = r.RelationshipTypeName,
                            Category = r.RelationshipTypeCategory,
                            r.Id
                        }))
                    .ToList();

                var grouped = allRels
                    .GroupBy(r => r.Category)
                    .OrderBy(g =>
                    {
                        var idx = Array.IndexOf(categoryOrder, g.Key);
                        return idx < 0 ? 99 : idx;
                    })
                    .ToList();
            }

            @if (grouped.Any())
            {
                var accordionId = "relAccordion";
                <div class="accordion accordion-flush" id="@accordionId">
                    @foreach (var group in grouped)
                    {
                        var collapseId = $"relCollapse_{group.Key.Replace(" ", "")}";
                        var count = group.Count();
                        var expanded = alwaysExpanded.Contains(group.Key);
                        <div class="accordion-item border rounded mb-2" style="border-color: var(--crm-border-subtle) !important;">
                            <h2 class="accordion-header">
                                <button class="accordion-button @(expanded ? "" : "collapsed") fw-semibold py-2" type="button"
                                        style="background: var(--crm-surface-elevated); color: var(--crm-text-primary);"
                                        data-mdb-collapse-init data-mdb-toggle="collapse" data-mdb-target="#@collapseId"
                                        aria-expanded="@(expanded ? "true" : "false")" aria-controls="@collapseId">
                                    @group.Key
                                    <span class="crm-badge crm-badge-muted ms-2">@count</span>
                                </button>
                            </h2>
                            <div id="@collapseId" class="accordion-collapse collapse @(expanded ? "show" : "")">
                                <div class="accordion-body px-2 pt-0 pb-2">
                                    @foreach (var rel in group)
                                    {
                                        <div class="crm-relationship-row">
                                            <div class="d-flex align-items-center">
                                                @if (rel.IsPartial)
                                                {
                                                    <span class="fw-semibold me-2" style="color: var(--crm-text-tertiary);">@rel.Name</span>
                                                }
                                                else
                                                {
                                                    <a asp-action="Details" asp-route-id="@rel.LinkId" class="text-decoration-none fw-semibold me-2" style="color: var(--crm-text-primary);">@rel.Name</a>
                                                }
                                                <span class="crm-role-badge">@rel.Badge</span>
                                            </div>
                                            <div class="crm-icon-actions">
                                                @if (rel.IsPartial)
                                                {
                                                    <span class="crm-badge crm-badge-muted me-1" title="Partial Contact">
                                                        <i class="bi bi-person-fill-exclamation" aria-hidden="true"></i>
                                                    </span>
                                                }
                                                <a asp-controller="Relationships" asp-action="Edit" asp-route-id="@rel.Id" class="crm-icon-btn icon-edit" title="Edit relationship" aria-label="Edit relationship with @rel.Name">
                                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                                </a>
                                                <button type="button" class="crm-icon-btn icon-danger"
                                                        data-confirm-action="@Url.Action("Delete", "Relationships", new { id = rel.Id })"
                                                        data-confirm-title="Delete Relationship"
                                                        data-confirm-body="Are you sure you want to delete the relationship with @rel.Name?"
                                                        data-confirm-reload
                                                        title="Delete relationship" aria-label="Delete relationship with @rel.Name">
                                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="crm-empty py-2">
                    <i class="bi bi-people" aria-hidden="true"></i>
                    <span>Map connections to family, friends, and colleagues.</span>
                </div>
            }
            <div class="text-end mt-2">
                <a asp-controller="Relationships" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="crm-btn-secondary btn-sm" aria-label="Add Relationship"><i class="bi bi-plus-lg" aria-hidden="true"></i> Add Relationship</a>
            </div>
        </div>
    </div>

    <!-- Pets -->
    <div class="crm-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-emoji-smile" aria-hidden="true"></i> Pets</h5>
            <a asp-controller="Pets" asp-action="Create" asp-route-entityId="@Model.Id" class="crm-btn-secondary btn-sm" aria-label="Add Pet"><i class="bi bi-plus-lg" aria-hidden="true"></i> Add</a>
        </div>
        <div class="crm-card-body">
            @if (Model.Pets != null && Model.Pets.Any())
            {
                @foreach (var pet in Model.Pets)
                {
                    <div class="crm-list-item d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fw-semibold" style="font-size: 0.875rem;">@pet.Name</div>
                            <small class="crm-meta">@pet.Species @(string.IsNullOrEmpty(pet.Breed) ? "" : $"({pet.Breed})")</small>
                        </div>
                        <div class="crm-icon-actions">
                            <a asp-controller="Pets" asp-action="Edit" asp-route-id="@pet.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @pet.Name">
                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                            </a>
                            <button type="button" class="crm-icon-btn icon-danger"
                                    data-confirm-action="@Url.Action("Delete", "Pets", new { id = pet.Id })"
                                    data-confirm-title="Delete Pet"
                                    data-confirm-body="Are you sure you want to delete @pet.Name?"
                                    data-confirm-reload
                                    title="Delete" aria-label="Delete @pet.Name">
                                <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="crm-empty py-2">
                    <i class="bi bi-emoji-smile" aria-hidden="true"></i>
                    <span>Track their furry (or scaly) companions.</span>
                </div>
            }
        </div>
    </div>
</div>

<!-- Right Column -->
<div class="col-md-8">
    <!-- Important Dates -->
    <div class="crm-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-calendar-event" aria-hidden="true"></i> Important Dates</h5>
            <a asp-controller="SignificantDates" asp-action="Index" asp-route-contactId="@Model.Id" class="crm-btn-secondary btn-sm"><i class="bi bi-gear" aria-hidden="true"></i> Manage Dates</a>
        </div>
        <div class="crm-card-body">
            @if (Model.SignificantDates != null && Model.SignificantDates.Any())
            {
                @foreach (var date in Model.SignificantDates.OrderBy(d => d.EventDate))
                {
                    <div class="crm-list-item d-flex w-100 justify-content-between align-items-center">
                        <h6 class="mb-0 me-2 fw-semibold" style="font-size: 0.875rem;">@date.Title</h6>
                        <div class="d-flex flex-wrap gap-1 align-items-center justify-content-end">
                            <span class="crm-date-badge crm-date-badge-date">@(date.EventDate.Year == 1 ? date.EventDate.ToString("M/d") : date.EventDate.ToShortDateString())</span>

                            @if (string.Equals(date.Title, SignificantDateTitles.Birthday, StringComparison.OrdinalIgnoreCase))
                            {
                                @if (date.EventDate.Year != 1)
                                {
                                    var today = DateTime.Today;
                                    var age = today.Year - date.EventDate.Year;
                                    if (date.EventDate.ToDateTime(TimeOnly.MinValue).Date > today.AddYears(-age)) age--;
                                    <span class="crm-date-badge crm-date-badge-age">@age years old</span>
                                }
                            }

                            @if (date.IsActive)
                            {
                                <span class="crm-date-badge crm-date-badge-active">Active</span>
                            }

                            @if (date.ReminderOffsets != null && date.ReminderOffsets.Any(r => r.IsActive))
                            {
                                <span class="crm-date-badge crm-date-badge-reminder"><i class="bi bi-bell-fill me-1" aria-hidden="true"></i>Reminders</span>
                            }

                            <div class="crm-icon-actions ms-1">
                                <a asp-controller="SignificantDates" asp-action="Edit" asp-route-id="@date.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @date.Title">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                </a>
                                <button type="button" class="crm-icon-btn icon-danger"
                                        data-confirm-action="@Url.Action("Delete", "SignificantDates", new { id = date.Id })"
                                        data-confirm-title="Delete Important Date"
                                        data-confirm-body="Are you sure you want to delete @(date.Title)?"
                                        data-confirm-reload
                                        title="Delete" aria-label="Delete @date.Title">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(date.Description) && date.Description != date.Title)
                    {
                        <p class="mb-1 crm-meta" style="margin-left: 0.75rem;">@date.Description</p>
                    }
                }
            }
            else
            {
                <div class="crm-empty py-2">
                    <i class="bi bi-calendar-event" aria-hidden="true"></i>
                    <span>Record birthdays, anniversaries, and milestones.</span>
                </div>
            }
        </div>
    </div>

    <!-- Notes -->
    <div class="crm-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-journal-text" aria-hidden="true"></i> Notes</h5>
            <a asp-controller="Notes" asp-action="Create" asp-route-entityId="@Model.Id" asp-route-entityType="Person" class="crm-btn-secondary btn-sm" aria-label="Add Note"><i class="bi bi-plus-lg" aria-hidden="true"></i> Add</a>
        </div>
        <div class="crm-card-body">
            @if (Model.Notes != null && Model.Notes.Any())
            {
                @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedDate))
                {
                    <div class="mb-2 p-3" style="background: var(--crm-surface-secondary); border-radius: var(--crm-radius-sm); border: 1px solid var(--crm-border-subtle);">
                        <div class="d-flex justify-content-between">
                            <h6 class="mb-2" style="font-size: 0.875rem; color: var(--crm-text-secondary);">
                                @note.Title <span class="crm-meta">@note.CreatedDate.ToShortDateString()</span>
                            </h6>
                            <div class="crm-icon-actions">
                                <a asp-controller="Notes" asp-action="Edit" asp-route-id="@note.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @note.Title">
                                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                </a>
                                <button type="button" class="crm-icon-btn icon-danger"
                                        data-confirm-action="@Url.Action("Delete", "Notes", new { id = note.Id })"
                                        data-confirm-title="Delete Note"
                                        data-confirm-body="Are you sure you want to delete &quot;@note.Title&quot;?"
                                        data-confirm-reload
                                        title="Delete" aria-label="Delete @note.Title">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>
                        <div class="d-none note-source">@note.Value</div>
                        <div class="note-render" style="font-size: 0.875rem;"></div>
                    </div>
                }
            }
            else
            {
                <div class="crm-empty py-2">
                    <i class="bi bi-journal-text" aria-hidden="true"></i>
                    <span>Capture thoughts or conversation highlights.</span>
                </div>
            }
        </div>
    </div>

    <!-- Activities -->
    <div class="crm-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-calendar-check" aria-hidden="true"></i> Activities</h5>
            <div class="d-flex gap-1 flex-wrap align-items-center">
                @foreach (var option in ActivityTypeSuggestions.QuickLog)
                {
                    <form method="post" asp-controller="Activities" asp-action="QuickLog">
                        <input type="hidden" name="contactId" value="@Model.Id"/>
                        <input type="hidden" name="activityType" value="@option.Type"/>
                        <button type="submit" class="crm-btn-secondary btn-sm" title="Log @option.Label today">
                            <i class="@option.Icon" aria-hidden="true"></i> @option.Label
                        </button>
                    </form>
                }
                <a asp-controller="Activities" asp-action="Create" asp-route-entityId="@Model.Id" class="crm-btn-secondary btn-sm" aria-label="Add Activity">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i> Add
                </a>
            </div>
        </div>
        <div class="crm-card-body">
            @if (Model.Activities != null && Model.Activities.Any())
            {
                var sortedActivities = Model.Activities.OrderByDescending(a => a.ActivityDate).ToList();
                <div id="activities-list">
                    @foreach (var activity in sortedActivities)
                    {
                        <div class="activity-item mb-2 p-3" style="background: var(--crm-surface-secondary); border-radius: var(--crm-radius-sm); border: 1px solid var(--crm-border-subtle);">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h6 class="mb-1" style="font-size: 0.875rem;">
                                        @activity.Title
                                        @if (!string.IsNullOrEmpty(activity.ActivityType))
                                        {
                                            <span class="crm-role-badge ms-1">@activity.ActivityType</span>
                                        }
                                    </h6>
                                    <div class="crm-meta">
                                        <i class="bi bi-calendar3" aria-hidden="true"></i> @activity.ActivityDate.ToShortDateString()
                                        @if (!string.IsNullOrEmpty(activity.Location))
                                        {
                                            <span class="ms-2"><i class="bi bi-geo-alt" aria-hidden="true"></i> @activity.Location</span>
                                        }
                                    </div>
                                    @if (activity.ContactNames.Any())
                                    {
                                        <div class="crm-meta mt-1">
                                            <i class="bi bi-people" aria-hidden="true"></i>
                                            with @for (int ci = 0; ci < activity.ContactNames.Count; ci++)
                                            {
                                                if (ci > 0) { <text>, </text> }
                                                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@activity.ContactIds[ci]">@activity.ContactNames[ci]</a>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="crm-icon-actions align-self-start">
                                    <a asp-controller="Activities" asp-action="Edit" asp-route-id="@activity.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @activity.Title">
                                        <i class="bi bi-pencil-square" aria-hidden="true"></i>
                                    </a>
                                    <button type="button" class="crm-icon-btn icon-danger"
                                            data-confirm-action="@Url.Action("Delete", "Activities", new { id = activity.Id })"
                                            data-confirm-title="Delete Activity"
                                            data-confirm-body="Are you sure you want to delete &quot;@activity.Title&quot;?"
                                            data-confirm-reload
                                            title="Delete" aria-label="Delete @activity.Title">
                                        <i class="bi bi-trash" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(activity.Description))
                            {
                                <div class="d-none note-source">@activity.Description</div>
                                <div class="note-render mt-2" style="font-size: 0.875rem;"></div>
                            }
                        </div>
                    }
                </div>
                if (sortedActivities.Count > 5)
                {
                    <div id="activities-pagination" class="d-flex justify-content-between align-items-center mt-2">
                        <button type="button" id="activities-prev" class="crm-btn-tertiary btn-sm" disabled>
                            <i class="bi bi-chevron-left" aria-hidden="true"></i> Previous
                        </button>
                        <span id="activities-page-info" class="text-muted small"></span>
                        <button type="button" id="activities-next" class="crm-btn-tertiary btn-sm">
                            Next <i class="bi bi-chevron-right" aria-hidden="true"></i>
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="crm-empty py-2">
                    <i class="bi bi-calendar-check" aria-hidden="true"></i>
                    <span>Log meetings, calls, and shared experiences.</span>
                </div>
            }
        </div>
    </div>

    <!-- Tasks / Follow-ups -->
    <div class="crm-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-check2-square" aria-hidden="true"></i> Tasks / Follow-ups</h5>
            <a asp-controller="ContactTasks" asp-action="Create" asp-route-entityId="@Model.Id" class="crm-btn-secondary btn-sm" aria-label="Add Task">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add
            </a>
        </div>
        <div class="crm-card-body">
            @if (Model.ContactTasks != null && Model.ContactTasks.Any())
            {
                var today = DateOnly.FromDateTime(DateTime.Today);
                var incomplete = Model.ContactTasks.Where(t => !t.IsCompleted).OrderBy(t => t.DueDate);
                var completed = Model.ContactTasks.Where(t => t.IsCompleted).OrderByDescending(t => t.CompletedDate);

                @foreach (var task in incomplete.Concat(completed))
                {
                    bool isOverdue = !task.IsCompleted && task.DueDate < today;
                    <div class="crm-list-item d-flex justify-content-between align-items-start">
                        <div class="d-flex align-items-start gap-2">
                            <form asp-controller="ContactTasks" asp-action="ToggleComplete" asp-route-id="@task.Id" method="post" class="mt-1">
                                <button type="submit" class="btn btn-sm p-0 border-0" title="@(task.IsCompleted ? "Mark incomplete" : "Mark complete")">
                                    <i class="bi @(task.IsCompleted ? "bi-check-circle-fill" : "bi-circle") fs-5" style="color: @(task.IsCompleted ? "var(--crm-success)" : "var(--crm-text-tertiary)");" aria-hidden="true"></i>
                                </button>
                            </form>
                            <div>
                                <div class="@(task.IsCompleted ? "text-decoration-line-through" : "")" style="font-size: 0.875rem; color: @(task.IsCompleted ? "var(--crm-text-tertiary)" : "var(--crm-text-primary)");">
                                    @task.Title
                                </div>
                                <div class="crm-meta" style="@(isOverdue ? "color: var(--crm-danger);" : "")">
                                    <i class="bi bi-calendar3" aria-hidden="true"></i> @task.DueDate.ToString("MMM d, yyyy")
                                    @if (isOverdue)
                                    {
                                        <span class="crm-badge crm-badge-danger ms-1">Overdue</span>
                                    }
                                </div>
                                @if (task.IsCompleted && task.CompletedDate.HasValue)
                                {
                                    <div class="crm-meta">
                                        Completed @task.CompletedDate.Value.ToString("MMM d, yyyy")
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="crm-icon-actions">
                            <a asp-controller="ContactTasks" asp-action="Edit" asp-route-id="@task.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @task.Title">
                                <i class="bi bi-pencil-square" aria-hidden="true"></i>
                            </a>
                            <button type="button" class="crm-icon-btn icon-danger"
                                    data-confirm-action="@Url.Action("Delete", "ContactTasks", new { id = task.Id })"
                                    data-confirm-title="Delete Task"
                                    data-confirm-body="Are you sure you want to delete &quot;@task.Title&quot;?"
                                    data-confirm-reload
                                    title="Delete" aria-label="Delete @task.Title">
                                <i class="bi bi-trash" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="crm-empty py-2">
                    <i class="bi bi-check2-square" aria-hidden="true"></i>
                    <span>Plan follow-ups and reminders for this contact.</span>
                </div>
            }
        </div>
    </div>

    <!-- Attachments -->
    <div class="crm-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-paperclip" aria-hidden="true"></i> Attachments</h5>
            <button type="button" class="crm-btn-secondary btn-sm" data-mdb-collapse-init data-mdb-toggle="collapse" data-mdb-target="#uploadAttachmentForm" aria-expanded="false" aria-controls="uploadAttachmentForm" aria-label="Add Attachment">
                <i class="bi bi-plus-lg" aria-hidden="true"></i> Add
            </button>
        </div>
        <div class="crm-card-body">
            <div class="collapse mb-3" id="uploadAttachmentForm" style="transition: height var(--crm-transition-expand) ease;">
                <form asp-controller="Attachments" asp-action="Upload" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" method="post" enctype="multipart/form-data" class="p-3" style="background: var(--crm-surface-secondary); border-radius: var(--crm-radius-sm); border: 1px solid var(--crm-border-subtle);">
                    <input type="hidden" name="entityId" value="@Model.Id"/>
                    <input type="hidden" name="entityType" value="Person"/>
                    <div class="mb-2">
                        <label for="file" class="form-label crm-meta">Select File</label>
                        <input type="file" name="file" class="form-control form-control-sm" required/>
                    </div>
                    <button type="submit" class="crm-btn-primary btn-sm" aria-label="Upload Attachment"><i class="bi bi-upload" aria-hidden="true"></i> Upload</button>
                </form>
            </div>

            @if (Model.Attachments != null && Model.Attachments.Any())
            {
                <div class="row masonry-grid" data-masonry='{"percentPosition": true }'>
                    @foreach (var attachment in Model.Attachments)
                    {
                        var isImage = !string.IsNullOrEmpty(attachment.ContentType) && attachment.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
                        var ext = System.IO.Path.GetExtension(attachment.FileName)?.ToLowerInvariant() ?? "";
                        var iconClass = "bi-file-earmark";

                        if (!isImage)
                        {
                            switch (ext)
                            {
                                case ".pdf": iconClass = "bi-filetype-pdf"; break;
                                case ".doc":
                                case ".docx": iconClass = "bi-filetype-docx"; break;
                                case ".xls":
                                case ".xlsx": iconClass = "bi-filetype-xlsx"; break;
                                case ".ppt":
                                case ".pptx": iconClass = "bi-filetype-pptx"; break;
                                case ".txt": iconClass = "bi-filetype-txt"; break;
                                case ".zip":
                                case ".rar":
                                case ".7z": iconClass = "bi-file-zip"; break;
                                case ".csv": iconClass = "bi-filetype-csv"; break;
                                case ".xml": iconClass = "bi-filetype-xml"; break;
                                case ".json": iconClass = "bi-filetype-json"; break;
                                case ".exe":
                                case ".dll": iconClass = "bi-filetype-exe"; break;
                            }
                        }

                        var iconColor = ext switch
                        {
                            ".pdf" => "var(--crm-danger)",
                            ".doc" or ".docx" => "var(--crm-brand)",
                            ".xls" or ".xlsx" or ".csv" => "var(--crm-success)",
                            ".ppt" or ".pptx" => "var(--crm-warning)",
                            ".exe" or ".dll" => "var(--crm-danger)",
                            _ => "var(--crm-text-tertiary)"
                        };

                        <div class="col-12 col-sm-6 col-md-4 mb-3 masonry-item">
                            <div class="attachment-card overflow-hidden position-relative" style="background: var(--crm-surface-elevated); border: 1px solid var(--crm-border-subtle);">
                                @if (isImage)
                                {
                                    <div class="attachment-preview-container d-flex align-items-center justify-content-center cursor-pointer" style="height: 200px; background: var(--crm-surface-primary);" data-preview-url="@Url.Action("View", "Attachments", new { id = attachment.Id })" data-filename="@attachment.FileName">
                                        <img src="@Url.Action("Thumbnail", "Attachments", new { id = attachment.Id, maxWidth = 400 })" class="img-fluid w-100 h-100" alt="@attachment.FileName" loading="lazy" style="object-fit: cover;" />
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center p-4" style="height: 200px; background: var(--crm-surface-secondary); border-bottom: 1px solid var(--crm-border-subtle);">
                                        <i class="bi @iconClass" style="font-size: 4rem; color: @iconColor;" aria-hidden="true"></i>
                                    </div>
                                }

                                <div class="p-2 position-relative">
                                    <div class="attachment-filename d-flex align-items-center">
                                        <i class="bi @(isImage ? "bi-image" : iconClass) me-2" style="font-size: 0.875rem; color: var(--crm-text-tertiary);" aria-hidden="true"></i>
                                        <a asp-controller="Attachments" asp-action="Download" asp-route-id="@attachment.Id" class="text-truncate text-decoration-none flex-grow-1" style="font-size: 0.875rem; color: var(--crm-text-primary);" title="@attachment.FileName" aria-label="Download @attachment.FileName">
                                            @attachment.FileName
                                        </a>
                                    </div>

                                    <div class="attachment-actions btn-group w-100">
                                        <a asp-controller="Attachments" asp-action="Download" asp-route-id="@attachment.Id" class="crm-btn-secondary btn-sm" style="flex: 1; justify-content: center;" title="Download" aria-label="Download @attachment.FileName">
                                            <i class="bi bi-download" aria-hidden="true"></i>
                                        </a>
                                        @if (isImage)
                                        {
                                            <form method="post" class="d-inline flex-grow-1" action="/Attachments/@attachment.Id/SetAsProfilePhoto?returnUrl=@(Context.Request.Path + Context.Request.QueryString)">
                                                <button type="submit" class="crm-btn-secondary btn-sm w-100" title="Set as profile photo" aria-label="Set @attachment.FileName as profile photo">
                                                    <i class="bi bi-person-circle" aria-hidden="true"></i>
                                                </button>
                                                <input name="__RequestVerificationToken" type="hidden" value="@GetAntiXsrfRequestToken()"/>
                                            </form>
                                        }
                                        <button type="button" class="crm-btn-danger btn-sm flex-grow-1"
                                                data-confirm-action="@Url.Action("Delete", "Attachments", new { id = attachment.Id, returnUrl = Context.Request.Path + Context.Request.QueryString })"
                                                data-confirm-title="Delete Attachment"
                                                data-confirm-body="Are you sure you want to delete @attachment.FileName?"
                                                data-confirm-reload
                                                title="Delete" aria-label="Delete @attachment.FileName">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="crm-empty py-2">
                    <i class="bi bi-paperclip" aria-hidden="true"></i>
                    <span>Attach photos, documents, or files.</span>
                </div>
            }
        </div>
    </div>

    @if (Model.ImmichPersonId.HasValue || Model.ImmichTagId.HasValue)
    {
        <div id="immich-mount"
             data-contact-id="@Model.Id"
             data-immich-person-id="@Model.ImmichPersonId"
             data-immich-person-name="@Model.ImmichPersonName"
             data-immich-tag-id="@Model.ImmichTagId"
             data-immich-tag-value="@Model.ImmichTagValue"></div>
    }

    <!-- Social Media Embeds -->
    <partial name="_SocialMediaEmbeds" model="Model" />

</div>
</div>
</div>

<!-- Fullscreen Media Lightbox Container -->
<div id="media-lightbox">
    <div class="lightbox-toolbar">
        <a id="lightbox-open-original" href="#" target="_blank" title="Open Original" aria-label="Open original image in new tab">
            <i class="bi bi-box-arrow-up-right" aria-hidden="true"></i>
        </a>
        <button id="lightbox-close" title="Close" aria-label="Close lightbox">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
        </button>
    </div>
    <img id="media-lightbox-img" src="" alt="Preview">
    <div id="lightbox-title" class="lightbox-title"></div>
</div>

@section Scripts {
    <script src="~/js/markdown-renderer.js" asp-append-version="true"></script>
    <!-- Masonry & ImagesLoaded for gallery layout -->
    <script src="https://cdn.jsdelivr.net/npm/imagesloaded@5.0.0/imagesloaded.pkgd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/masonry-layout@4.2.2/dist/masonry.pkgd.min.js" integrity="sha384-GNFwBvfVxBkLMJpYMOABq3c+d3KnQxudP/mGPkzpZSTYykLBNsZEnG2D9G/X/+7D" crossorigin="anonymous" async></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const lightbox = document.getElementById('media-lightbox');
            const lightboxImg = document.getElementById('media-lightbox-img');
            const lightboxTitle = document.getElementById('lightbox-title');
            const lightboxOpenOriginal = document.getElementById('lightbox-open-original');
            const lightboxCloseBtn = document.getElementById('lightbox-close');

            function openLightbox(url, filename) {
                lightboxImg.src = url;
                lightboxTitle.textContent = filename;
                lightboxOpenOriginal.href = url;
                lightbox.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            function closeLightbox() {
                lightbox.classList.remove('active');
                lightboxImg.src = '';
                document.body.style.overflow = '';
            }

            document.addEventListener('click', function (e) {
                const container = e.target.closest('.attachment-preview-container[data-preview-url]');
                if (!container) return;
                if (e.target.closest('a') || e.target.closest('button')) return;
                openLightbox(container.getAttribute('data-preview-url'), container.getAttribute('data-filename'));
            });

            lightboxCloseBtn.addEventListener('click', closeLightbox);

            lightbox.addEventListener('click', function(e) {
                if (e.target === lightbox) {
                    closeLightbox();
                }
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && lightbox.classList.contains('active')) {
                    closeLightbox();
                }
            });

            function initMasonry(grid) {
                if (!grid || !window.Masonry || !window.imagesLoaded) return;
                imagesLoaded(grid, function () {
                    new Masonry(grid, { itemSelector: '.masonry-item', percentPosition: true });
                });
            }

            document.querySelectorAll('.masonry-grid').forEach(initMasonry);

            const immichMount = document.getElementById('immich-mount');
            if (immichMount) {
                const params = new URLSearchParams();
                params.set('contactId', immichMount.getAttribute('data-contact-id'));
                const personId = immichMount.getAttribute('data-immich-person-id');
                const personName = immichMount.getAttribute('data-immich-person-name');
                const tagId = immichMount.getAttribute('data-immich-tag-id');
                const tagValue = immichMount.getAttribute('data-immich-tag-value');
                if (personId) params.set('personId', personId);
                if (personName) params.set('personName', personName);
                if (tagId) params.set('tagId', tagId);
                if (tagValue) params.set('tagValue', tagValue);

                fetch('/Immich/Gallery?' + params.toString(), { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.text() : ''; })
                    .then(function (html) {
                        if (!html.trim()) return;
                        immichMount.innerHTML = html;
                        initMasonry(immichMount.querySelector('.masonry-grid'));
                    })
                    .catch(function () { /* swallow — mount stays empty */ });
            }

            const activityItems = document.querySelectorAll('.activity-item');
            const prevBtn = document.getElementById('activities-prev');
            const nextBtn = document.getElementById('activities-next');
            const pageInfo = document.getElementById('activities-page-info');
            const pageSize = 5;
            let currentPage = 0;

            if (activityItems.length > pageSize && prevBtn && nextBtn) {
                const totalPages = Math.ceil(activityItems.length / pageSize);

                function showPage(page) {
                    activityItems.forEach((item, i) => {
                        item.style.display = (i >= page * pageSize && i < (page + 1) * pageSize) ? '' : 'none';
                    });
                    prevBtn.disabled = page === 0;
                    nextBtn.disabled = page === totalPages - 1;
                    pageInfo.textContent = `${page * pageSize + 1}–${Math.min((page + 1) * pageSize, activityItems.length)} of ${activityItems.length}`;
                }

                prevBtn.addEventListener('click', () => { currentPage--; showPage(currentPage); });
                nextBtn.addEventListener('click', () => { currentPage++; showPage(currentPage); });
                showPage(0);
            }
        });
    </script>
}
