@model Rvnx.CRM.Core.Models.Contact.Contact

@{
    ViewData["Title"] = "Details";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@Model.FullName</h1>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>

    <div class="row">
        <!-- Main Info -->
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">Contact Info</h5>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Nickname</dt>
                        <dd class="col-sm-8">@Model.Nickname</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8"><a href="mailto:@Model.Email">@Model.Email</a></dd>

                        <dt class="col-sm-4">Phone</dt>
                        <dd class="col-sm-8"><a href="tel:@Model.Phone">@Model.Phone</a></dd>

                        <dt class="col-sm-4">Company</dt>
                        <dd class="col-sm-8">@Model.Company</dd>

                        <dt class="col-sm-4">Job Title</dt>
                        <dd class="col-sm-8">@Model.JobTitle</dd>

                        <dt class="col-sm-4">Birthday</dt>
                        <dd class="col-sm-8">@(Model.Birthday?.ToShortDateString() ?? "N/A")</dd>
                    </dl>
                </div>
            </div>

            <!-- Relationships -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Relationships</h5>
                    <a asp-controller="Relationships" asp-action="Create" asp-route-personId="@Model.Id" class="btn btn-sm btn-outline-primary">Add Relationship</a>
                </div>
                <ul class="list-group list-group-flush">
                    @if ((Model.Relationships != null && Model.Relationships.Any()) || (Model.RelatedTo != null && Model.RelatedTo.Any()))
                    {
                        @if (Model.Relationships != null)
                        {
                            foreach (var rel in Model.Relationships)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@rel.RelationshipType?.OppositeName:</strong>
                                        <a asp-action="Details" asp-route-id="@rel.RelatedPersonId">
                                            @rel.RelatedPerson?.FullName
                                        </a>
                                    </div>
                                    <div class="btn-group btn-group-sm">
                                         <a asp-controller="Relationships" asp-action="Edit" asp-route-id="@rel.Id" class="btn btn-outline-secondary">Edit</a>
                                         <a asp-controller="Relationships" asp-action="Delete" asp-route-id="@rel.Id" class="btn btn-outline-danger">Del</a>
                                    </div>
                                </li>
                            }
                        }
                        @if (Model.RelatedTo != null)
                        {
                            foreach (var rel in Model.RelatedTo)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@rel.RelationshipType?.Name:</strong>
                                        <a asp-action="Details" asp-route-id="@rel.PersonId">
                                            @rel.Person?.FullName
                                        </a>
                                    </div>
                                    <div class="btn-group btn-group-sm">
                                         <a asp-controller="Relationships" asp-action="Edit" asp-route-id="@rel.Id" class="btn btn-outline-secondary">Edit</a>
                                         <a asp-controller="Relationships" asp-action="Delete" asp-route-id="@rel.Id" class="btn btn-outline-danger">Del</a>
                                    </div>
                                </li>
                            }
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-muted">No relationships found.</li>
                    }
                </ul>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-md-8">

            <!-- Reminders -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Reminders</h5>
                    <a asp-controller="Reminders" asp-action="Create" asp-route-personId="@Model.Id" class="btn btn-sm btn-outline-primary">Add Reminder</a>
                </div>
                <div class="card-body">
                    @if (Model.Reminders != null && Model.Reminders.Any())
                    {
                        <ul class="list-group">
                            @foreach (var reminder in Model.Reminders.OrderBy(r => r.DueDate))
                            {
                                <li class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@reminder.Title</h6>
                                        <div>
                                            <small class="@(reminder.DueDate < DateTime.Now ? "text-danger" : "text-muted")">
                                                @reminder.DueDate.ToShortDateString()
                                            </small>
                                            <div class="btn-group btn-group-sm ml-2">
                                                <a asp-controller="Reminders" asp-action="Edit" asp-route-id="@reminder.Id" class="btn btn-outline-secondary">Edit</a>
                                                <a asp-controller="Reminders" asp-action="Delete" asp-route-id="@reminder.Id" class="btn btn-outline-danger">Del</a>
                                            </div>
                                        </div>
                                    </div>
                                    <p class="mb-1">@reminder.Description</p>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No reminders set.</p>
                    }
                </div>
            </div>

            <!-- Notes -->
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Notes</h5>
                    <a asp-controller="Notes" asp-action="Create" asp-route-personId="@Model.Id" class="btn btn-sm btn-outline-primary">Add Note</a>
                </div>
                <div class="card-body">
                    @if (Model.Notes != null && Model.Notes.Any())
                    {
                        @foreach (var note in Model.Notes.OrderByDescending(n => n.CreatedDate))
                        {
                            <div class="card mb-2">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <h6 class="card-subtitle mb-2 text-muted">@note.Title <small>@note.CreatedDate.ToShortDateString()</small></h6>
                                        <div class="btn-group btn-group-sm">
                                            <a asp-controller="Notes" asp-action="Edit" asp-route-id="@note.Id" class="btn btn-outline-secondary">Edit</a>
                                            <a asp-controller="Notes" asp-action="Delete" asp-route-id="@note.Id" class="btn btn-outline-danger">Del</a>
                                        </div>
                                    </div>
                                    <p class="card-text">@note.Value</p>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No notes available.</p>
                    }
                </div>
            </div>

        </div>
    </div>
</div>
