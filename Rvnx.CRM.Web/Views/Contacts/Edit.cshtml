@model Rvnx.CRM.Core.DTOs.Contact.ContactEditViewModel

@{
    ViewData["Title"] = "Edit Contact";
}

<h1>Edit Contact</h1>

<div class="row">
    <div class="col-md-6">
        <form id="contact-form" asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id"/>
            <input type="hidden" asp-for="ProfileImageId"/>

            <div class="form-floating mb-3">
                <input asp-for="FirstName" class="form-control" placeholder="FirstName" required autofocus/>
                <label asp-for="FirstName">First Name <span class="text-danger">*</span></label>
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="LastName" class="form-control" placeholder="LastName"/>
                <label asp-for="LastName"></label>
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="MaidenName" class="form-control" placeholder="MaidenName"/>
                <label asp-for="MaidenName"></label>
                <span asp-validation-for="MaidenName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Nickname" class="form-control" placeholder="Nickname"/>
                <label asp-for="Nickname"></label>
                <span asp-validation-for="Nickname" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="Email"/>
                <label asp-for="Email"></label>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Phone" class="form-control" placeholder="Phone"/>
                <label asp-for="Phone"></label>
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Company" class="form-control" placeholder="Company"/>
                <label asp-for="Company"></label>
                <span asp-validation-for="Company" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="JobTitle" class="form-control" placeholder="JobTitle"/>
                <label asp-for="JobTitle"></label>
                <span asp-validation-for="JobTitle" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Birthday" class="form-control" type="date" placeholder="Birthday"/>
                <label asp-for="Birthday"></label>
                <span asp-validation-for="Birthday" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check form-switch">
                <input asp-for="RemindOnBirthday" class="form-check-input"/>
                <label asp-for="RemindOnBirthday" class="form-check-label"></label>
            </div>

            <div class="mb-3">
                <label asp-for="Pronouns" class="form-label">Pronouns</label>
                <select id="pronouns-select" class="form-select">
                    @foreach (var option in Model.PronounOptions)
                    {
                        <option value="@option">@option</option>
                    }
                </select>
                <div id="pronouns-custom" class="mt-2" style="display:none;">
                    <input asp-for="Pronouns" class="form-control" placeholder="Enter pronouns"/>
                    <span asp-validation-for="Pronouns" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Gender" class="form-label">Gender</label>
                <select id="gender-select" class="form-select">
                    @foreach (var option in Model.GenderOptions)
                    {
                        <option value="@option">@option</option>
                    }
                </select>
                <div id="gender-custom" class="mt-2" style="display:none;">
                    <input asp-for="Gender" class="form-control" placeholder="Enter gender"/>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Religion" class="form-label">Religion</label>
                <input asp-for="Religion" class="form-control" placeholder="Optional"/>
                <span asp-validation-for="Religion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label for="profileImage" class="form-label">Profile Image</label>
                @if (Model.ProfileImageId.HasValue)
                {
                    <div class="d-flex align-items-center mb-2">
                        <img src="@Url.Action("View", "Attachments", new { id = Model.ProfileImageId })" class="rounded me-2" alt="Current Profile" style="width: 50px; height: 50px; object-fit: cover;"/>
                        <button type="submit" asp-action="UnsetPhoto" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to remove the profile photo?');">
                            <i class="bi bi-x-circle"></i> Unset Photo
                        </button>
                    </div>
                }
                <input type="file" name="profileImage" class="form-control" accept="image/*" data-preview-target="#new-profile-image-preview"/>
                <div class="mt-2">
                    <img id="new-profile-image-preview" src="" class="img-fluid rounded border d-none" alt="New Profile Image Preview" style="max-height: 200px; object-fit: contain;"/>
                </div>
            </div>

            <div class="mb-3 form-check form-switch">
                <input asp-for="IsHidden" class="form-check-input"/>
                <label asp-for="IsHidden" class="form-check-label"></label>
                <div class="form-text">Hidden contacts are excluded from the main list by default.</div>
            </div>

            <div class="d-grid gap-2 d-md-flex justify-content-md-start mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Save</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary"><i class="bi bi-arrow-left me-2"></i>Back to Contact</a>
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title text-primary"><i class="bi bi-tags"></i> Manage Labels</h5>
                <hr/>
                <h6 class="mb-3">Assigned Labels</h6>
                @if (Model.AssignedLabelIds != null && Model.AllLabels != null)
                {
                    var assignedLabels = Model.AllLabels.Where(l => Model.AssignedLabelIds.Contains(l.Id)).ToList();
                    var unassignedLabels = Model.AllLabels.Where(l => !Model.AssignedLabelIds.Contains(l.Id)).ToList();

                    if (assignedLabels.Any())
                    {
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            @foreach (var label in assignedLabels)
                            {
                                <div class="d-inline-flex align-items-center border rounded p-1">
                                    <div class="ps-1">
                                        @await Html.PartialAsync("_LabelBadge", label)
                                    </div>
                                    <form asp-action="RemoveLabel" asp-route-contactId="@Model.Id" asp-route-labelId="@label.Id" method="post" class="d-inline ms-1">
                                        <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Remove label @label.Name" aria-label="Remove label @label.Name">
                                            <i class="bi bi-x-circle-fill" aria-hidden="true"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted small mb-4">No labels assigned.</p>
                    }

                    <h6 class="mb-3">Add Label</h6>
                    if (unassignedLabels.Any())
                    {
                        <form asp-action="AssignLabel" method="post" class="d-flex flex-wrap gap-2">
                            <input type="hidden" name="contactId" value="@Model.Id"/>
                            <select name="labelId" class="form-select form-select-sm flex-grow-1" style="min-width: 150px;">
                                <option value="">Select a label...</option>
                                @foreach (var label in unassignedLabels)
                                {
                                    <option value="@label.Id">@label.Name</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-plus"></i> Add</button>
                        </form>
                    }
                    else if (!Model.AllLabels.Any())
                    {
                        <p class="text-muted small">No labels exist yet. <a asp-controller="Labels" asp-action="Create">Create one first.</a></p>
                    }
                    else
                    {
                        <p class="text-muted small">All available labels have been assigned.</p>
                    }

                    <div class="mt-4 pt-3 border-top">
                        <a asp-controller="Labels" asp-action="Index" class="small text-decoration-none"><i class="bi bi-gear me-1"></i>Manage all labels</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        (function () {
            function initReveal(selectId, customId) {
                const select = document.getElementById(selectId);
                const custom = document.getElementById(customId);
                const input = custom.querySelector('input');
                const knownOptions = Array.from(select.options).map(o => o.value);
                const currentValue = input.value;

                if (!currentValue || currentValue === 'Unspecified') {
                    select.value = 'Unspecified';
                    custom.style.display = 'none';
                } else if (knownOptions.includes(currentValue)) {
                    select.value = currentValue;
                    custom.style.display = 'none';
                } else {
                    select.value = 'Other';
                    custom.style.display = '';
                }

                select.addEventListener('change', function () {
                    if (this.value === 'Other') {
                        custom.style.display = '';
                        input.focus();
                    } else {
                        custom.style.display = 'none';
                        input.value = this.value === 'Unspecified' ? '' : this.value;
                    }
                });
            }

            initReveal('pronouns-select', 'pronouns-custom');
            initReveal('gender-select', 'gender-custom');
        })();
    </script>
}
