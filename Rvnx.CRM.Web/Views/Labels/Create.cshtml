@model Rvnx.CRM.Core.DTOs.Contact.LabelFormDto
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Create Label";
}

<form id="label-form" asp-action="Create" data-edit-form method="post">
    @Html.AntiForgeryToken()

    @await Html.PartialAsync("_EditFormHeader", new EditFormHeaderModel
    {
        BackUrl = Url.Action("Index")!,
        BackText = "Back to Labels",
        Icon = "bi-tag",
        Eyebrow = "Adding label",
        Title = "Create a label"
    })

    <div class="crm-edit-body">
        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-tag" aria-hidden="true"></i> Details</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-field-group">
                        <label asp-for="Name">Name *</label>
                        <input asp-for="Name" class="crm-input" required autofocus />
                        <span asp-validation-for="Name" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Color">Badge Color</label>
                        <div class="d-flex align-items-center gap-3">
                            <input asp-for="Color" type="color" class="form-control form-control-color border-0 p-0" style="width: 4rem; height: 3rem; cursor: pointer;" title="Choose badge color" value="@(Model.Color ?? "#4CAF50")" />
                            <small class="text-muted">Select a background color. Text color adjusts automatically.</small>
                        </div>
                        <span asp-validation-for="Color" class="crm-field-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
            {
                FormId = "label-form",
                CancelUrl = Url.Action("Index")!
            })
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
