@model IEnumerable<Rvnx.CRM.Core.DTOs.Contact.LabelDto>

@{
    ViewData["Title"] = "Labels";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <h2 class="mb-0">Labels</h2>
    <a asp-action="Create" class="crm-btn-primary">
        <i class="bi bi-plus-lg"></i> Create Label
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 my-5">
        <i class="bi bi-tags display-1 opacity-25 mb-3" style="color: var(--crm-text-tertiary);"></i>
        <h3 class="h4 mt-3" style="color: var(--crm-text-secondary);">No Labels Found</h3>
        <p class="mb-4" style="color: var(--crm-text-tertiary);">Create your first label to organize contacts.</p>
    </div>
}
else
{
    <div class="crm-card" style="margin-bottom: 0;">
        <div class="crm-card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="">
                        <tr>
                            <th>Label</th>
                            <th class="text-end" style="width: 200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var label in Model)
                        {
                            <tr>
                                <td>
                                    <h5 class="mb-0">
                                        @await Html.PartialAsync("_LabelBadge", label)
                                    </h5>
                                </td>
                                <td class="text-end">
                                    <div class="crm-icon-actions">
                                        <a asp-action="Edit" asp-route-id="@label.Id" class="crm-icon-btn icon-edit" title="Edit" aria-label="Edit @label.Name">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@label.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this label?');">
                                            <button type="submit" class="crm-icon-btn icon-danger" title="Delete" aria-label="Delete @label.Name">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
