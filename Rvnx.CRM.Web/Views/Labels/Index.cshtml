@model IEnumerable<Rvnx.CRM.Core.DTOs.Contact.LabelDto>

@{
    ViewData["Title"] = "Labels";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <h2 class="mb-0">Labels</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Create Label
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 my-5">
        <i class="bi bi-tags display-1 text-muted opacity-25 mb-3"></i>
        <h3 class="h4 text-secondary mt-3">No Labels Found</h3>
        <p class="text-muted mb-4">Create your first label to organize contacts.</p>
        <a asp-action="Create" class="btn btn-primary btn-lg px-4">
            <i class="bi bi-plus-lg me-2"></i>Create Label
        </a>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="">
                        <tr>
                            <th>Label</th>
                            <th class="text-end" style="width: 200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var label in Model)
                        {
                            <tr>
                                <td>
                                    <h5 class="mb-0">
                                        @await Html.PartialAsync("_LabelBadge", label)
                                    </h5>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@label.Id" class="btn btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@label.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this label?');">
                                            <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
