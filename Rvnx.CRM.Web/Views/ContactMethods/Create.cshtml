@model Rvnx.CRM.Core.DTOs.Contact.ContactMethodFormDto
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Add Contact Info";
}

<form id="contact-method-form" asp-action="Create" data-edit-form>
    @Html.AntiForgeryToken()
    <input asp-for="ContactId" type="hidden" />

    @await Html.PartialAsync("_EditFormHeader", new EditFormHeaderModel
    {
        BackUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!,
        Icon = "bi-person-badge",
        Eyebrow = "Adding contact method",
        Title = "New contact method"
    })

    <div class="crm-edit-body">
        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-person-badge" aria-hidden="true"></i> Details</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-field-group">
                        <label asp-for="Type">Type</label>
                        <select asp-for="Type" asp-items="Html.GetEnumSelectList<Rvnx.CRM.Core.Enumerations.ContactMethodType>()" class="crm-input" id="Type" data-select2 autofocus></select>
                        <span asp-validation-for="Type" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Value">Value</label>
                        <input asp-for="Value" class="crm-input" id="Value" />
                        <span asp-validation-for="Value" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Label">Label</label>
                        <input asp-for="Label" class="crm-input" id="Label" />
                        <span asp-validation-for="Label" class="crm-field-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
            {
                FormId = "contact-method-form",
                CancelUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!
            })
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
