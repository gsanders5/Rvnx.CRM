@model Rvnx.CRM.Core.Models.Contact.ContactMethod

@{
    ViewData["Title"] = "Add Contact Info";
}

<h1>Add Contact Info</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EntityId" />
            <input type="hidden" asp-for="EntityType" />

            <div class="form-floating mb-3">
                <select asp-for="Type" asp-items="Html.GetEnumSelectList<Rvnx.CRM.Core.Enumerations.ContactMethodType>()" class="form-select"></select>
                <label asp-for="Type"></label>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Value" class="form-control" placeholder="Value" />
                <label asp-for="Value"></label>
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
    <input asp-for="Label" class="form-control" placeholder="e.g. Work, Personal"/>
    <label asp-for="Label"></label>
    <span asp-validation-for="Label" class="text-danger"></span>
</div>
            <div class="form-group mt-3">
                <input type="submit" value="Add" class="btn btn-primary" />
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
