@model Rvnx.CRM.Core.DTOs.Contact.ContactMethodFormDto

@{
    ViewData["Title"] = "Add Contact Info";
}

<h1>Add Contact Info</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EntityId"/>
            <input type="hidden" asp-for="EntityType"/>

            <div class="form-floating mb-3">
                <select asp-for="Type" asp-items="Html.GetEnumSelectList<Rvnx.CRM.Core.Enumerations.ContactMethodType>()" class="form-select" id="Type" autofocus></select>
                <label asp-for="Type">Type</label>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Value" class="form-control" id="Value" placeholder=" "/>
                <label asp-for="Value">Value</label>
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Label" class="form-control" id="Label" placeholder=" "/>
                <label asp-for="Label">Label</label>
                <span asp-validation-for="Label" class="text-danger"></span>
            </div>
            <div class="d-grid gap-2 d-md-flex mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg me-2" aria-hidden="true"></i>Add</button>
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary"><i class="bi bi-x-lg me-2" aria-hidden="true"></i>Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
