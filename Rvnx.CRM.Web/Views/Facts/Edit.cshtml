@model Rvnx.CRM.Core.DTOs.Contact.FactFormDto

@{
    ViewData["Title"] = "Edit Fact";
}

<h1>Edit Fact</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id"/>
            <input type="hidden" asp-for="ContactId"/>

            <div class="form-floating mb-3">
                <input asp-for="Category" class="form-control" id="Category" placeholder=" "/>
                <label asp-for="Category">Category</label>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Value" class="form-label">Value</label>
                <textarea asp-for="Value" id="Value" placeholder="Enter value..."></textarea>
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>
            <div class="d-grid gap-2 d-md-flex mt-4">
                <button type="submit" class="crm-btn-primary"><i class="bi bi-save" aria-hidden="true"></i>Save</button>
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.ContactId" class="crm-btn-tertiary"><i class="bi bi-x-lg" aria-hidden="true"></i>Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @{ ViewData["EasyMDEElementId"] = "Value"; ViewData["EasyMDEMinHeight"] = "150px"; }
    @{ await Html.RenderPartialAsync("_EasyMDEScripts"); }
}
