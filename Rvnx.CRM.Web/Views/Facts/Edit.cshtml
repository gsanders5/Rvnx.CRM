@model Rvnx.CRM.Core.Models.Contact.Fact

@{
    ViewData["Title"] = "Edit Fact";
}

<h1>Edit Fact</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="EntityId" />
            <input type="hidden" asp-for="EntityType" />

            <div class="form-floating mb-3">
    <input asp-for="Category" class="form-control"  placeholder="Category"/>
    <label asp-for="Category"></label>
    <span asp-validation-for="Category" class="text-danger"></span>
</div>
            <div class="form-floating mb-3">
    <textarea asp-for="Value" class="form-control" rows="3" placeholder="Value"></textarea>
    <label asp-for="Value"></label>
    <span asp-validation-for="Value" class="text-danger"></span>
</div>
            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
