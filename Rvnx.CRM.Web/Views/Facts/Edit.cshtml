@model Rvnx.CRM.Core.DTOs.Contact.FactFormDto

@{
    ViewData["Title"] = "Edit Fact";
}

<form id="fact-form" asp-action="Edit" data-edit-form>
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="ContactId" type="hidden" />

    <div class="crm-details-actions-strip">
        <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.ContactId" class="crm-btn-tertiary btn-sm">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Contact
        </a>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="crm-eyebrow crm-unsaved-indicator" id="unsaved-indicator" hidden>
                <i class="bi bi-circle-fill" aria-hidden="true" style="font-size: 6px; vertical-align: middle; margin-right: 4px;"></i>
                Unsaved
            </span>
            <button type="submit" class="crm-btn-primary btn-sm">
                <i class="bi bi-save" aria-hidden="true"></i> Save
            </button>
        </div>
    </div>

    <section class="crm-edit-masthead crm-fade-in">
        <div class="crm-edit-masthead-photo-placeholder" aria-hidden="true">
            <i class="bi bi-lightbulb"></i>
        </div>
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 6px;">Editing fact</div>
            <h1 class="crm-edit-masthead-title">@(string.IsNullOrWhiteSpace(Model.Category) ? "Fact details" : Model.Category)</h1>
        </div>
    </section>

    <div class="crm-edit-body">
        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-lightbulb" aria-hidden="true"></i> Details</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-field-group">
                        <label asp-for="Category">Category</label>
                        <input asp-for="Category" class="crm-input" id="Category" />
                        <span asp-validation-for="Category" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Value">Value</label>
                        <textarea asp-for="Value" class="crm-input" id="Value" placeholder="Enter value..."></textarea>
                        <span asp-validation-for="Value" class="crm-field-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            <div class="crm-save-shortcut-card">
                <div class="crm-save-shortcut-title">Ready to save?</div>
                <div class="crm-save-shortcut-desc">Changes are applied immediately.</div>
                <button type="submit" class="crm-btn-primary btn-sm" form="fact-form">
                    <i class="bi bi-save" aria-hidden="true"></i> Save
                </button>
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.ContactId" class="crm-btn-tertiary btn-sm">
                    <i class="bi bi-arrow-left" aria-hidden="true"></i> Cancel
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @{ ViewData["EasyMDEElementId"] = "Value"; ViewData["EasyMDEMinHeight"] = "150px"; }
    @{ await Html.RenderPartialAsync("_EasyMDEScripts"); }
}
