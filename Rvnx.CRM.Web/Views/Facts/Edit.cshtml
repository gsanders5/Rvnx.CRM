@model Rvnx.CRM.Core.DTOs.Contact.FactFormDto

@{
    ViewData["Title"] = "Edit Fact";
}

<h1>Edit Fact</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id"/>
            <input type="hidden" asp-for="EntityId"/>
            <input type="hidden" asp-for="EntityType"/>

            <div class="form-floating mb-3">
                <input asp-for="Category" class="form-control" id="Category" placeholder=" "/>
                <label asp-for="Category">Category</label>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <textarea asp-for="Value" class="form-control" style="height: 100px" id="Value" placeholder=" "></textarea>
                <label asp-for="Value">Value</label>
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>
            <div class="d-grid gap-2 d-md-flex mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2" aria-hidden="true"></i>Save</button>
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary"><i class="bi bi-x-lg me-2" aria-hidden="true"></i>Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
