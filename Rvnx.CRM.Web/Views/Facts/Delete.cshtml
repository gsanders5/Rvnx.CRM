@model Rvnx.CRM.Core.Models.Contact.Fact

@{
    ViewData["Title"] = "Delete Fact";
}

<div class="crm-details-actions-strip">
    <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.ContactId" class="crm-btn-tertiary btn-sm">
        <i class="bi bi-arrow-left" aria-hidden="true"></i> Cancel
    </a>
</div>

<section class="crm-edit-masthead crm-fade-in">
    <div class="crm-edit-masthead-photo-placeholder is-danger" aria-hidden="true">
        <i class="bi bi-trash"></i>
    </div>
    <div>
        <div class="crm-eyebrow is-danger" style="margin-bottom: 6px;">Confirm delete</div>
        <h1 class="crm-edit-masthead-title">
            Delete @(string.IsNullOrWhiteSpace(Model.Value) ? "fact" : Model.Value)?
        </h1>
    </div>
</section>

<div class="crm-page">
    <div class="crm-card crm-delete-card" style="max-width: 720px;">
        <div class="crm-card-body">
            <p class="crm-subtle" style="margin-bottom: 16px;">
                This will permanently delete this fact. This action cannot be undone.
            </p>

            <dl class="crm-deflist">
                <div class="crm-deflist-row">
                    <dt>@Html.DisplayNameFor(model => model.Category)</dt>
                    <dd>@Html.DisplayFor(model => model.Category)</dd>
                </div>
                <div class="crm-deflist-row">
                    <dt>@Html.DisplayNameFor(model => model.Value)</dt>
                    <dd>@Html.DisplayFor(model => model.Value)</dd>
                </div>
            </dl>

            <form asp-action="Delete" method="post" class="d-flex gap-2" style="margin-top: 18px; flex-wrap: wrap;">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <button type="submit" class="crm-btn-danger">
                    <i class="bi bi-trash" aria-hidden="true"></i> Delete
                </button>
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.ContactId" class="crm-btn-tertiary">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>
