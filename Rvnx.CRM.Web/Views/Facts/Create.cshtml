@model Rvnx.CRM.Core.DTOs.Contact.FactFormDto
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Add Fact";
}

<form id="fact-form" asp-action="Create" data-edit-form>
    @Html.AntiForgeryToken()
    <input asp-for="ContactId" type="hidden" />

    @await Html.PartialAsync("_EditFormHeader", new EditFormHeaderModel
    {
        BackUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!,
        Icon = "bi-lightbulb",
        Eyebrow = "Adding fact",
        Title = "New fact"
    })

    <div class="crm-edit-body">
        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-lightbulb" aria-hidden="true"></i> Details</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-field-group">
                        <label asp-for="Category">Category</label>
                        <input asp-for="Category" class="crm-input" id="Category" autofocus />
                        <span asp-validation-for="Category" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Value">Value</label>
                        <textarea asp-for="Value" class="crm-input" id="Value" placeholder="Enter value..."></textarea>
                        <span asp-validation-for="Value" class="crm-field-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
            {
                FormId = "fact-form",
                CancelUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!
            })
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @{ ViewData["EasyMDEElementId"] = "Value"; ViewData["EasyMDEMinHeight"] = "150px"; }
    @{ await Html.RenderPartialAsync("_EasyMDEScripts"); }
}
