@model Rvnx.CRM.Core.Models.Contact.Fact

@{
    ViewData["Title"] = "Add Fact";
}

<h1>Add Fact</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EntityId" />
            <input type="hidden" asp-for="EntityType" />

            <div class="mb-3">
                <label asp-for="Category" class="form-label"></label>
                <input asp-for="Category" class="form-control" placeholder="e.g. Hobbies, Food Preferences" />
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Value" class="form-label"></label>
                <textarea asp-for="Value" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>
            <div class="form-group mt-3">
                <input type="submit" value="Add" class="btn btn-primary" />
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
