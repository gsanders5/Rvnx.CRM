@model Rvnx.CRM.Core.DTOs.Base.NoteFormViewModel
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Edit Note";
}

<form id="note-form" asp-action="Edit" data-edit-form>
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="ContactId" type="hidden" />
    <input asp-for="ContactName" type="hidden" />
    <input asp-for="IsFavorite" type="hidden" />

    @await Html.PartialAsync("_EditFormHeader", new EditFormHeaderModel
    {
        BackUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!,
        Icon = "bi-journal-text",
        Eyebrow = "Editing note",
        Title = $"for {Model.ContactName}"
    })

    <div class="crm-edit-body">
        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-journal-text" aria-hidden="true"></i> Details</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-field-group">
                        <label asp-for="Title">Title</label>
                        <input asp-for="Title" class="crm-input" id="Title" />
                        <span asp-validation-for="Title" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Value">Value</label>
                        <textarea asp-for="Value" class="crm-input" id="Value" placeholder="Enter note content..."></textarea>
                        <span asp-validation-for="Value" class="crm-field-error"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
            {
                FormId = "note-form",
                CancelUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!
            })
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @{ ViewData["EasyMDEElementId"] = "Value"; ViewData["EasyMDEMinHeight"] = "300px"; }
    @{ await Html.RenderPartialAsync("_EasyMDEScripts"); }
}
