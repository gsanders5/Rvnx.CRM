@model Rvnx.CRM.Core.DTOs.Common.NoteFormDto

@{
    ViewData["Title"] = "Add Note";
    var entityId = ViewData["EntityId"] as Guid?;
    var entityType = ViewData["EntityType"] as string;
    var entityName = ViewData["EntityName"] as string;
}

<h1>Add Note for @entityName</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EntityId" value="@entityId" />
            <input type="hidden" asp-for="EntityType" value="@entityType" />

            <div class="form-floating mb-3">
    <input asp-for="Title" class="form-control"  placeholder="Title"/>
    <label asp-for="Title"></label>
    <span asp-validation-for="Title" class="text-danger"></span>
</div>

            <div class="form-floating mb-3">
    <textarea asp-for="Value" class="form-control" style="height: 150px" placeholder="Note Content"></textarea>
    <label asp-for="Value">Note Content</label>
    <span asp-validation-for="Value" class="text-danger"></span>
</div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Note</button>
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@entityId" class="btn btn-secondary"><i class="bi bi-x-lg"></i> Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
