@model Rvnx.CRM.Web.ViewModels.Calendar.CalendarIndexViewModel
@{
    ViewData["Title"] = "Calendar";

    DateTime initialDate;
    if (!DateTime.TryParse(Model.InitialDate, out initialDate))
    {
        initialDate = DateTime.Today;
    }
}

<div class="crm-page">

    <div class="crm-masthead crm-fade-in">
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 8px;">Calendar</div>
            <h1 class="crm-masthead-title">
                @initialDate.ToString("MMMM") <em>@initialDate.ToString("yyyy")</em>
            </h1>
        </div>
    </div>

    <div class="crm-calendar-legend crm-fade-in crm-delay-1">
        <span class="crm-eyebrow">Legend</span>
        <span class="crm-calendar-legend-item">
            <span class="crm-calendar-legend-swatch" style="background: #e67e22;"></span>
            Birthday
        </span>
        <span class="crm-calendar-legend-item">
            <span class="crm-calendar-legend-swatch" style="background: #3498db;"></span>
            Significant Date
        </span>
        <span class="crm-calendar-legend-item">
            <span class="crm-calendar-legend-swatch" style="background: #2ecc71;"></span>
            Task
        </span>
    </div>

    <div class="crm-card crm-fade-in crm-delay-2">
        <div class="crm-card-body">
            <div id="calendar"></div>
        </div>
    </div>

</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const calendar = new FullCalendar.Calendar(document.getElementById('calendar'), {
                initialView: 'dayGridMonth',
                initialDate: '@Model.InitialDate',
                height: 'auto',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,listMonth'
                },
                buttonText: {
                    today: 'Today',
                    month: 'Month',
                    list: 'List'
                },
                events: '@Url.Action("Events", "Calendar")',
                eventDisplay: 'block',
                eventClick: function (info) {
                    if (info.event.url) {
                        info.jsEvent.preventDefault();
                        window.location.href = info.event.url;
                    }
                },
                eventDidMount: function (info) {
                    info.el.title = info.event.title;
                },
                noEventsText: 'No upcoming events'
            });

            calendar.render();

            // Re-render if user toggles dark/light mode so FullCalendar
            // picks up any theme variable changes.
            const observer = new MutationObserver(() => calendar.render());
            observer.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ['data-mdb-theme']
            });
        });
    </script>
    <style>
        /* ── Shared ── */
        .fc .fc-toolbar-title {
            font-family: 'Newsreader', 'Source Serif Pro', Georgia, serif;
            font-size: 1.4rem;
            font-weight: 400;
            letter-spacing: -0.01em;
        }

        .fc-event {
            cursor: pointer;
            border-radius: 4px;
            padding: 1px 4px;
        }

        .fc .fc-button {
            font-family: inherit;
            text-transform: none;
            font-size: 0.8rem;
        }

        /* ── Light mode ── */
        :root {
            --fc-border-color: var(--crm-border);
            --fc-page-bg-color: var(--crm-surface-elevated);
            --fc-neutral-bg-color: var(--crm-surface-secondary);
            --fc-today-bg-color: var(--crm-brand-subtle);
            --fc-button-bg-color: var(--crm-surface-elevated);
            --fc-button-border-color: var(--crm-border);
            --fc-button-text-color: var(--crm-text-primary);
            --fc-button-hover-bg-color: var(--crm-surface-secondary);
            --fc-button-hover-border-color: var(--crm-border);
            --fc-button-active-bg-color: var(--crm-brand);
            --fc-button-active-border-color: var(--crm-brand);
            --fc-event-text-color: #fff;
        }

        /* ── Dark mode ── */
        [data-mdb-theme="dark"] {
            --fc-border-color: var(--crm-border);
            --fc-page-bg-color: var(--crm-surface-elevated);
            --fc-neutral-bg-color: var(--crm-surface-secondary);
            --fc-today-bg-color: var(--crm-brand-subtle);
            --fc-button-bg-color: var(--crm-surface-secondary);
            --fc-button-border-color: var(--crm-border);
            --fc-button-text-color: var(--crm-text-primary);
            --fc-button-hover-bg-color: rgba(255, 255, 255, 0.06);
            --fc-button-hover-border-color: var(--crm-border);
            --fc-button-active-bg-color: var(--crm-brand);
            --fc-button-active-border-color: var(--crm-brand);
            --fc-event-text-color: #fff;
            --fc-list-event-hover-bg-color: rgba(255, 255, 255, 0.04);
        }

            [data-mdb-theme="dark"] .fc-col-header-cell-cushion,
            [data-mdb-theme="dark"] .fc-daygrid-day-number {
                color: var(--crm-text-secondary);
            }

            [data-mdb-theme="dark"] .fc-day-other .fc-daygrid-day-number {
                color: var(--crm-text-tertiary);
            }

            [data-mdb-theme="dark"] .fc .fc-toolbar-title {
                color: var(--crm-text-primary);
            }
    </style>
}
