@using Rvnx.CRM.Core.Models.Base
@model List<Person>

@{
    ViewData["Title"] = "Home Page - CRM System";
}

<div class="text-center">
    <h1 class="display-4">Rvnx CRM System</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>People (@Model.Count)</h2>
            <form asp-action="SeedTestData" method="post" class="d-inline">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-database-add"></i> Add Test Data
                </button>
            </form>
        </div>

        @if (Model.Count == 0)
        {
            <div class="alert alert-info">
                <h4>No people found</h4>
                <p>Click "Add Test Data" to add some sample people to test the system.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var person in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@person.FirstName @person.LastName</strong>
                                    <br />
                                    <small class="text-muted">ID: @person.Id.ToString()[..8]...</small>
                                </td>
                                <td>
                                    <small>
                                        @person.CreatedDate.ToString("MM/dd/yyyy")
                                        <br />
                                        <span class="text-muted">by @person.CreatedBy</span>
                                    </small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>