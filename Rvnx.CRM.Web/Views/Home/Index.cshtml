@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Dashboard.DashboardDto

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-4 py-4">

    @* ── Top row: Upcoming Events (left) + Recently Modified (right) ── *@
    <div class="row g-3 mb-3">

        @* Upcoming Events *@
        <div class="col-12 col-lg-6">
            <div class="crm-card h-100">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-calendar-event" aria-hidden="true"></i> Upcoming Events</h5>
                </div>
                <div class="crm-card-body">
                    @if (Model.UpcomingEvents.Any())
                    {
                        @foreach (var evt in Model.UpcomingEvents)
                        {
                            <a href="@(evt.RelatedEntityId.HasValue ? Url.Action("Details", "Contacts", new { id = evt.RelatedEntityId }) : "#")"
                               class="crm-event-row mb-1">
                                <div class="crm-event-icon">
                                    @if (evt.Type == SignificantDateTitles.Birthday)
                                    {
                                        <i class="bi bi-gift-fill" aria-hidden="true"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-alarm-fill" aria-hidden="true"></i>
                                    }
                                </div>
                                <div class="flex-grow-1 min-width-0">
                                    <div class="fw-semibold text-truncate" style="color: var(--crm-text-primary);">@evt.RelatedEntityName</div>
                                    <div class="crm-meta">@evt.Title</div>
                                </div>
                                <div class="text-end flex-shrink-0">
                                    @{
                                        var urgencyClass = "urgency-medium";
                                        var timeText = evt.TimeUntil;
                                        if (timeText.Contains("1 week") || timeText.Contains("days") || timeText.Contains("Tomorrow") || timeText.Contains("Today"))
                                        {
                                            urgencyClass = "urgency-high";
                                        }
                                        else if (timeText.Contains("month") || (int.TryParse(timeText.Split(' ')[0], out var weeks) && weeks > 6))
                                        {
                                            urgencyClass = "urgency-low";
                                        }
                                    }
                                    <span class="crm-event-time @urgencyClass">@evt.TimeUntil</span>
                                    <div class="crm-meta mt-1">@evt.Date.ToShortDateString()</div>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="crm-empty py-2">
                            <i class="bi bi-calendar-x" aria-hidden="true"></i>
                            <span class="">No upcoming events to look forward to.</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Recently Modified *@
        <div class="col-12 col-lg-6">
            <div class="crm-card h-100">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-clock-history" aria-hidden="true"></i> Recently Modified</h5>
                </div>
                <div class="crm-card-body">
                    @if (Model.RecentContacts.Any())
                    {
                        @foreach (var contact in Model.RecentContacts)
                        {
                            <a asp-controller="Contacts" asp-action="Details" asp-route-id="@contact.Id"
                               class="crm-contact-row mb-1">
                                @if (contact.ProfileImageId.HasValue)
                                {
                                    <img src="@Url.Action("Thumbnail", "Attachments", new { id = contact.ProfileImageId, maxWidth = 80, maxHeight = 80 })"
                                         class="crm-avatar" width="40" height="40"
                                         alt="@contact.FullName" loading="lazy" />
                                }
                                else
                                {
                                    <div class="crm-avatar-placeholder">
                                        <i class="bi bi-person-fill" aria-hidden="true"></i>
                                    </div>
                                }
                                <div class="flex-grow-1 min-width-0">
                                    <div class="fw-semibold text-truncate" style="color: var(--crm-text-primary);">
                                        @contact.FullName
                                        @if (contact.IsNew)
                                        {
                                            <span class="crm-badge crm-badge-success badge-new ms-2" style="font-size: 0.65rem;">New</span>
                                        }
                                    </div>
                                    <div class="crm-meta">
                                        Changed @contact.LastChangedDate.ToShortDateString()
                                    </div>
                                </div>
                                <i class="bi bi-chevron-right crm-chevron" aria-hidden="true"></i>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="crm-empty py-2">
                            <i class="bi bi-person-x" aria-hidden="true"></i>
                            <span class="">No contacts yet — start building your network.</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Network Graph ── *@
    <div class="crm-card" id="network-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-diagram-3" aria-hidden="true"></i> Your Network</h5>
            <button id="fullscreen-btn" class="crm-btn-secondary btn-sm" title="Toggle Fullscreen" aria-label="Toggle Fullscreen">
                <i class="bi bi-arrows-fullscreen" aria-hidden="true"></i>
            </button>
        </div>
        <div class="crm-card-body p-0 position-relative">
            <div id="network-graph" class="crm-network-container" style="width: 100%; height: 500px; background-color: var(--crm-surface-secondary); overflow: hidden;"></div>
            <div class="position-absolute bottom-0 end-0 mb-3 me-3 d-flex flex-column gap-1" style="z-index: 10;">
                <button id="zoom-in-btn" class="crm-btn-secondary btn-sm" title="Zoom In" aria-label="Zoom In" style="padding: 0.375rem;">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                </button>
                <button id="zoom-out-btn" class="crm-btn-secondary btn-sm" title="Zoom Out" aria-label="Zoom Out" style="padding: 0.375rem;">
                    <i class="bi bi-dash-lg" aria-hidden="true"></i>
                </button>
                <button id="reset-zoom-btn" class="crm-btn-secondary btn-sm" title="Reset View" aria-label="Reset View" style="padding: 0.375rem;">
                    <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                </button>
            </div>
        </div>
    </div>

    @* ── Stats Row ── *@
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="crm-card crm-stat-card">
                <div class="crm-card-body py-2">
                    <div class="stat-value" style="color: var(--crm-brand);">@Model.Stats.TotalContacts</div>
                    <div class="stat-label"><i class="bi bi-people-fill me-1" aria-hidden="true"></i>Total Contacts</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="crm-card crm-stat-card">
                <div class="crm-card-body py-2">
                    <div class="stat-value" style="color: var(--crm-success);">@Model.Stats.ContactsWithRelationships</div>
                    <div class="stat-label"><i class="bi bi-diagram-3-fill me-1" aria-hidden="true"></i>In Your Network</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="crm-card crm-stat-card">
                <div class="crm-card-body py-2">
                    <div class="stat-value" style="color: var(--crm-warning);">@Model.Stats.ContactsWithBirthday</div>
                    <div class="stat-label"><i class="bi bi-gift-fill me-1" aria-hidden="true"></i>Birthdays Tracked</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="crm-card crm-stat-card">
                <div class="crm-card-body py-2">
                    <div class="stat-value" style="color: var(--crm-text-tertiary);">@Model.Stats.ContactsHidden</div>
                    <div class="stat-label"><i class="bi bi-eye-slash-fill me-1" aria-hidden="true"></i>Hidden</div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    @{
        var scriptNonce = Context.Items["csp-nonce"] as string ?? string.Empty;
    }
    <script src="~/js/network-graph.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const nodes = @Json.Serialize(Model.GraphNodes);
            const links = @Json.Serialize(Model.GraphLinks);
            initializeNetworkGraph(nodes, links);
        });
    </script>
}
