@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Dashboard.DashboardDto

@{
    ViewData["Title"] = "Dashboard";

    DateTime now = DateTime.Now;
    string greeting;
    if (now.Hour < 5) { greeting = "evening"; }
    else if (now.Hour < 12) { greeting = "morning"; }
    else if (now.Hour < 17) { greeting = "afternoon"; }
    else { greeting = "evening"; }
    int birthdayCount = Model.UpcomingEvents.Count(e => e.Type == SignificantDateTitles.Birthday);

    // Pull the first token of the signed-in user's name (same source the sidebar uses)
    // so the greeting reads "Good afternoon, Elena." instead of "Good afternoon.".
    string? firstName = null;
    if (User.Identity?.IsAuthenticated == true && !string.IsNullOrWhiteSpace(User.Identity.Name))
    {
        firstName = User.Identity.Name.Split(' ', '@')[0];
    }
}

<div class="crm-page">

    @* ── Editorial masthead ───────────────────────────────────────────── *@
    <div class="crm-masthead crm-fade-in">
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 8px;">@now.ToString("dddd · MMMM d, yyyy")</div>
            <h1 class="crm-masthead-title crm-masthead-title-lg">
                @if (!string.IsNullOrEmpty(firstName))
                {
                    <text>Good @greeting, <em>@firstName.</em></text>
                }
                else
                {
                    <text>Good @greeting<em>.</em></text>
                }
            </h1>
        </div>
        <div style="text-align: right;">
            <div class="crm-eyebrow" style="margin-bottom: 6px;">Next 30 days</div>
            <div class="crm-masthead-subtitle">
                <em>@Model.UpcomingEvents.Count @(Model.UpcomingEvents.Count == 1 ? "event" : "events")</em>@if (birthdayCount > 0)
                {
                    <span>, including <em>@birthdayCount @(birthdayCount == 1 ? "birthday" : "birthdays")</em></span>
                }<span>.</span>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-3">

        @* ── Upcoming Events ───────────────────────────────────────────── *@
        <div class="col-12 col-lg-7">
            <div class="crm-card crm-fade-in crm-delay-1 h-100">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-calendar-event" aria-hidden="true"></i> Upcoming Events</h5>
                    <a class="crm-btn-tertiary btn-sm" asp-controller="Calendar" asp-action="Index">
                        See calendar <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    </a>
                </div>
                <div class="crm-card-body" style="padding: 8px 22px 18px;">
                    @if (Model.UpcomingEvents.Any())
                    {
                        @foreach (var evt in Model.UpcomingEvents)
                        {
                            var isBirthday = evt.Type == SignificantDateTitles.Birthday;
                            var timeText = evt.TimeUntil ?? "";
                            var urgencyClass = "is-later";
                            if (timeText.Contains("Today", StringComparison.OrdinalIgnoreCase) ||
                                timeText.Contains("Tomorrow", StringComparison.OrdinalIgnoreCase))
                            {
                                urgencyClass = "is-today";
                            }
                            else if (timeText.Contains("day", StringComparison.OrdinalIgnoreCase) ||
                                     timeText.Contains("week", StringComparison.OrdinalIgnoreCase))
                            {
                                urgencyClass = "is-soon";
                            }
                            var isSoon = urgencyClass != "is-later";
                            var href = evt.RelatedContactId.HasValue
                                ? Url.Action("Details", "Contacts", new { id = evt.RelatedContactId })
                                : "#";
                            <a href="@href" class="crm-event-editorial">
                                <div class="crm-date-pill @(isSoon ? "is-soon" : "")">
                                    <div class="crm-date-pill-month">@evt.Date.ToString("MMM")</div>
                                    <div class="crm-date-pill-day">@evt.Date.Day</div>
                                </div>
                                <div style="min-width: 0;">
                                    <div class="crm-event-editorial-title">
                                        <i class="bi @(isBirthday ? "bi-gift-fill" : "bi-alarm-fill")" aria-hidden="true"></i>
                                        <span class="crm-event-editorial-who">@evt.RelatedContactName</span>
                                    </div>
                                    <div class="crm-event-editorial-body">
                                        @evt.Title@if (!string.IsNullOrWhiteSpace(evt.Description))
                                        {
                                            <span class="crm-muted"> — @evt.Description</span>
                                        }
                                    </div>
                                </div>
                                <span class="crm-event-urgency @urgencyClass">@evt.TimeUntil</span>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="crm-empty py-2">
                            <i class="bi bi-calendar-x" aria-hidden="true"></i>
                            <span>No upcoming events to look forward to.</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Recently Modified ─────────────────────────────────────────── *@
        <div class="col-12 col-lg-5">
            <div class="crm-card crm-fade-in crm-delay-2 h-100">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-clock-history" aria-hidden="true"></i> Recently Modified</h5>
                    <span class="crm-eyebrow">LAST @Model.RecentContacts.Count CHANGES</span>
                </div>
                <div class="crm-card-body" style="padding: 8px 22px 18px;">
                    @if (Model.RecentContacts.Any())
                    {
                        @foreach (var contact in Model.RecentContacts)
                        {
                            <a asp-controller="Contacts" asp-action="Details" asp-route-id="@contact.Id" class="crm-recent-row">
                                @if (contact.ProfileImageId.HasValue)
                                {
                                    <img src="@Url.Action("Thumbnail", "Attachments", new { id = contact.ProfileImageId, maxWidth = 80, maxHeight = 80 })"
                                         class="crm-avatar" width="40" height="40"
                                         alt="@contact.FullName" loading="lazy" />
                                }
                                else
                                {
                                    <div class="crm-avatar-placeholder">
                                        <i class="bi bi-person-fill" aria-hidden="true"></i>
                                    </div>
                                }
                                <div style="flex: 1; min-width: 0;">
                                    <div class="text-truncate" style="display: flex; align-items: center; gap: 8px;">
                                        <span class="crm-recent-row-name">@contact.FullName</span>
                                        @if (contact.IsNew)
                                        {
                                            <span class="crm-badge crm-badge-new" style="font-size: 0.65rem;">NEW</span>
                                        }
                                    </div>
                                    <div class="crm-recent-row-meta">
                                        CHANGED @contact.LastChangedDate.ToString("MMM d").ToUpperInvariant()
                                    </div>
                                </div>
                                <i class="bi bi-chevron-right" aria-hidden="true" style="color: var(--crm-text-tertiary); font-size: 12px;"></i>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="crm-empty py-2">
                            <i class="bi bi-person-x" aria-hidden="true"></i>
                            <span>No contacts yet — start building your network.</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Open Tasks ────────────────────────────────────────────────────── *@
    @if (Model.OpenTasks.Any())
    {
        <div class="crm-card crm-fade-in crm-delay-3" style="margin-bottom: 1rem;">
            <div class="crm-card-header">
                <h5 class="card-title mb-0"><i class="bi bi-check2-square" aria-hidden="true"></i> Open Tasks</h5>
                <a class="crm-btn-tertiary btn-sm" asp-controller="Calendar" asp-action="Index">
                    See calendar <i class="bi bi-arrow-right" aria-hidden="true"></i>
                </a>
            </div>
            <div class="crm-card-body" style="padding: 8px 22px 18px;">
                @foreach (var task in Model.OpenTasks)
                {
                    <a asp-controller="Contacts" asp-action="Details" asp-route-id="@task.ContactId" class="crm-recent-row">
                        <div class="crm-avatar-placeholder" style="@(task.IsOverdue ? "color: var(--crm-danger);" : "")">
                            <i class="bi @(task.IsOverdue ? "bi-exclamation-circle-fill" : "bi-check2-square")" aria-hidden="true"></i>
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <div class="text-truncate crm-recent-row-name">@task.Title</div>
                            <div class="crm-recent-row-meta">
                                @task.ContactName ·
                                @if (task.IsOverdue)
                                {
                                    <span style="color: var(--crm-danger);">@task.DaysOverdue day@(task.DaysOverdue == 1 ? "" : "s") overdue</span>
                                }
                                else
                                {
                                    <span>due @task.DueDate.ToString("MMM d")</span>
                                }
                            </div>
                        </div>
                        <i class="bi bi-chevron-right" aria-hidden="true" style="color: var(--crm-text-tertiary); font-size: 12px;"></i>
                    </a>
                }
            </div>
        </div>
    }

    @* ── Stats Strip ───────────────────────────────────────────────────── *@
    <div class="crm-card crm-fade-in crm-delay-3" style="margin-bottom: 1rem;">
        <div class="crm-stats-strip">
            <div class="crm-stats-strip-cell">
                <div class="crm-stats-strip-value is-accent">@Model.Stats.TotalContacts</div>
                <div class="crm-stats-strip-label"><i class="bi bi-people-fill" aria-hidden="true"></i> Total Contacts</div>
            </div>
            <div class="crm-stats-strip-cell">
                <div class="crm-stats-strip-value">@Model.Stats.ContactsWithRelationships</div>
                <div class="crm-stats-strip-label"><i class="bi bi-diagram-3-fill" aria-hidden="true"></i> In Your Network</div>
            </div>
            <div class="crm-stats-strip-cell">
                <div class="crm-stats-strip-value">@Model.Stats.ContactsWithBirthday</div>
                <div class="crm-stats-strip-label"><i class="bi bi-gift-fill" aria-hidden="true"></i> Birthdays Tracked</div>
            </div>
            <div class="crm-stats-strip-cell">
                <div class="crm-stats-strip-value">@Model.Stats.ContactsHidden</div>
                <div class="crm-stats-strip-label"><i class="bi bi-eye-slash-fill" aria-hidden="true"></i> Hidden</div>
            </div>
        </div>
    </div>

    @* ── Network Graph ─────────────────────────────────────────────────── *@
    <div class="crm-card crm-fade-in crm-delay-4" id="network-card">
        <div class="crm-card-header">
            <h5 class="card-title mb-0"><i class="bi bi-diagram-3" aria-hidden="true"></i> Your Network</h5>
            <button id="fullscreen-btn" class="crm-btn-tertiary btn-sm" title="Toggle Fullscreen" aria-label="Toggle Fullscreen">
                <i class="bi bi-arrows-fullscreen" aria-hidden="true"></i>
            </button>
        </div>
        <div class="crm-card-body p-0 position-relative">
            <div id="network-graph" class="crm-network-container" style="width: 100%; height: 500px; background-color: var(--crm-surface-secondary); overflow: hidden;"></div>
            <div class="position-absolute bottom-0 end-0 mb-3 me-3 d-flex flex-column gap-1" style="z-index: 10;">
                <button id="zoom-in-btn" class="crm-btn-tertiary btn-sm" title="Zoom In" aria-label="Zoom In" style="padding: 0.375rem;">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                </button>
                <button id="zoom-out-btn" class="crm-btn-tertiary btn-sm" title="Zoom Out" aria-label="Zoom Out" style="padding: 0.375rem;">
                    <i class="bi bi-dash-lg" aria-hidden="true"></i>
                </button>
                <button id="reset-zoom-btn" class="crm-btn-tertiary btn-sm" title="Reset View" aria-label="Reset View" style="padding: 0.375rem;">
                    <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                </button>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/network-graph.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const nodes = @Json.Serialize(Model.GraphNodes);
            const links = @Json.Serialize(Model.GraphLinks);
            initializeNetworkGraph(nodes, links);
        });
    </script>
}
