@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Dashboard.DashboardDto

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-4 py-4">

    @* ── Top row: Upcoming Events (left) + Recently Added/Modified (right) ── *@
    <div class="row g-4 mb-4">

        @* Upcoming Events *@
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100 border-primary border-opacity-25" style="border-width: 2px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h2 class="text-primary font-weight-bold mb-0">Upcoming Events</h2>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (Model.UpcomingEvents.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var evt in Model.UpcomingEvents)
                            {
                                <a href="@(evt.RelatedEntityId.HasValue? Url.Action("Details", "Contacts", new { id = evt.RelatedEntityId }) : "#")"
                                   class="list-group-item list-group-item-action d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center rounded mb-2 border hover-shadow gap-2"
                                   style="background-color: var(--bs-body-bg);">
                                    <div class="d-flex align-items-center w-100">
                                        <div class="p-3 rounded shadow-sm me-3 text-primary bg-primary bg-opacity-10 flex-shrink-0">
                                            @if (evt.Type == SignificantDateTitles.Birthday)
                                            {
                                                <i class="bi bi-gift-fill fs-5" aria-hidden="true"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-alarm-fill fs-5" aria-hidden="true"></i>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-bold text-body">@evt.RelatedEntityName</div>
                                            <div class="small text-muted">@evt.Title</div>
                                        </div>
                                    </div>
                                    <div class="text-end align-self-end align-self-sm-center flex-shrink-0">
                                        <div class="fw-bold text-primary">@evt.TimeUntil</div>
                                        <div class="small text-muted">@evt.Date.ToShortDateString()</div>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-calendar-x display-6 d-block mb-3 opacity-25"></i>
                            <p class="mb-3">No upcoming events.</p>
                            <a asp-controller="Calendar" asp-action="Index" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-calendar-event me-1"></i> View Calendar
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Recently Added / Modified *@
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100 border-primary border-opacity-25" style="border-width: 2px;">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h2 class="text-primary font-weight-bold mb-0">Recently Modified</h2>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (Model.RecentContacts.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var contact in Model.RecentContacts)
                            {
                                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@contact.Id"
                                   class="list-group-item list-group-item-action d-flex align-items-center rounded mb-2 border hover-shadow gap-3"
                                   style="background-color: var(--bs-body-bg);">
                                    @* Avatar *@
                                    <div class="flex-shrink-0" style="width:40px;height:40px;">
                                        @if (contact.ProfileImageId.HasValue)
                                        {
                                            <img src="@Url.Action("Thumbnail", "Attachments", new { id = contact.ProfileImageId, maxWidth = 80, maxHeight = 80 })"
                                                 class="rounded-circle" width="40" height="40"
                                                 style="object-fit:cover;" alt="@contact.FullName" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center w-100 h-100">
                                                <i class="bi bi-person-fill" aria-hidden="true"></i>
                                            </div>
                                        }
                                    </div>
                                    @* Name + badge *@
                                    <div class="flex-grow-1 min-width-0">
                                        <div class="fw-bold text-body text-truncate">
                                            @contact.FullName
                                            @if (contact.IsNew)
                                            {
                                                <span class="badge bg-success ms-2 fs-0" style="font-size:0.65rem;">New</span>
                                            }
                                        </div>
                                        <div class="small text-muted">
                                            Changed @contact.LastChangedDate.ToShortDateString()
                                        </div>
                                    </div>
                                    <i class="bi bi-chevron-right text-muted flex-shrink-0" aria-hidden="true"></i>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-person-x display-6 d-block mb-3 opacity-25"></i>
                            <p class="mb-3">No contacts yet.</p>
                            <a asp-controller="Contacts" asp-action="Create" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-plus-lg me-1"></i> Add Contact
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Network Graph ── *@
    <div class="card shadow-sm mb-4 border-primary border-opacity-25" style="border-width: 2px;" id="network-card">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
            <h2 class="text-primary font-weight-bold mb-0">Your Network</h2>
            <button id="fullscreen-btn" class="btn btn-outline-primary btn-sm" title="Toggle Fullscreen" aria-label="Toggle Fullscreen">
                <i class="bi bi-arrows-fullscreen" aria-hidden="true"></i>
            </button>
        </div>
        <div class="card-body p-0 position-relative">
            <div id="network-graph" style="width: 100%; height: 500px; background-color: var(--bs-body-bg); overflow: hidden;"></div>
            <div class="position-absolute bottom-0 end-0 mb-3 me-3 btn-group-vertical shadow-sm" style="z-index: 10;">
                <button id="zoom-in-btn" class="btn btn-light border" title="Zoom In" aria-label="Zoom In">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                </button>
                <button id="zoom-out-btn" class="btn btn-light border" title="Zoom Out" aria-label="Zoom Out">
                    <i class="bi bi-dash-lg" aria-hidden="true"></i>
                </button>
                <button id="reset-zoom-btn" class="btn btn-light border" title="Reset View" aria-label="Reset View">
                    <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                </button>
            </div>
        </div>
    </div>

    @* ── Stats / At-a-Glance Row ── *@
    <div class="row g-4 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-primary border-opacity-25 text-center py-3" style="border-width: 2px;">
                <div class="card-body py-2">
                    <div class="display-6 fw-bold text-primary">@Model.Stats.TotalContacts</div>
                    <div class="small text-muted mt-1"><i class="bi bi-people-fill me-1" aria-hidden="true"></i>Total Contacts</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-success border-opacity-25 text-center py-3" style="border-width: 2px;">
                <div class="card-body py-2">
                    <div class="display-6 fw-bold text-success">@Model.Stats.ContactsWithRelationships</div>
                    <div class="small text-muted mt-1"><i class="bi bi-diagram-3-fill me-1" aria-hidden="true"></i>In Your Network</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-warning border-opacity-25 text-center py-3" style="border-width: 2px;">
                <div class="card-body py-2">
                    <div class="display-6 fw-bold text-warning">@Model.Stats.ContactsWithBirthday</div>
                    <div class="small text-muted mt-1"><i class="bi bi-gift-fill me-1" aria-hidden="true"></i>Birthdays Tracked</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm border-secondary border-opacity-25 text-center py-3" style="border-width: 2px;">
                <div class="card-body py-2">
                    <div class="display-6 fw-bold text-secondary">@Model.Stats.ContactsHidden</div>
                    <div class="small text-muted mt-1"><i class="bi bi-eye-slash-fill me-1" aria-hidden="true"></i>Hidden</div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    @{
        var scriptNonce = Context.Items["csp-nonce"] as string ?? string.Empty;
    }
    <script src="~/js/network-graph.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const nodes = @Json.Serialize(Model.GraphNodes);
            const links = @Json.Serialize(Model.GraphLinks);
            initializeNetworkGraph(nodes, links);
        });
    </script>
}
