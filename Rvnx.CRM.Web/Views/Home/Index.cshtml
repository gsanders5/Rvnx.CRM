@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Dashboard.DashboardDto

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-4 py-4">
    <!-- Upcoming Events Section -->
    <div class="card shadow-sm mb-4 border-primary border-opacity-25" style="border-width: 2px;">
        <div class="card-header bg-transparent border-0 pt-4 px-4 position-relative overflow-hidden">
            <h2 class="text-primary font-weight-bold mb-0 position-relative z-1">Upcoming Events</h2>
        </div>
        <div class="card-body px-4 pb-4 position-relative z-1">
            @if (Model.UpcomingEvents.Any())
            {
                <div class="list-group list-group-flush">
                    @foreach (var evt in Model.UpcomingEvents)
                    {
                        <a href="@(evt.RelatedEntityId.HasValue ? Url.Action("Details", "Contacts", new { id = evt.RelatedEntityId }) : "#")" class="list-group-item list-group-item-action d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center rounded mb-2 border hover-shadow gap-2" style="background-color: var(--bs-body-bg);">
                            <div class="d-flex align-items-center w-100">
                                <div class="p-3 rounded shadow-sm me-3 text-primary bg-primary bg-opacity-10 flex-shrink-0">
                                    @if (evt.Type == SignificantDateTitles.Birthday)
                                    {
                                        <i class="bi bi-gift-fill fs-5"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-alarm-fill fs-5"></i>
                                    }
                                </div>
                                <div>
                                    <div class="fw-bold text-body">@evt.RelatedEntityName</div>
                                    <div class="small text-muted">@evt.Title</div>
                                </div>
                            </div>
                            <div class="text-end align-self-end align-self-sm-center flex-shrink-0">
                                <div class="fw-bold text-primary">@evt.TimeUntil</div>
                                <div class="small text-muted">@evt.Date.ToShortDateString()</div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="text-muted text-center py-4">
                    No upcoming events.
                </div>
            }
        </div>
    </div>

    <!-- Your Network Graph Section -->
    <div class="card shadow-sm mb-4 border-primary border-opacity-25" style="border-width: 2px;" id="network-card">
        <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
            <h2 class="text-primary font-weight-bold mb-0">Your Network</h2>
            <button id="fullscreen-btn" class="btn btn-outline-primary btn-sm" title="Toggle Fullscreen" aria-label="Toggle Fullscreen">
                <i class="bi bi-arrows-fullscreen"></i>
            </button>
        </div>
        <div class="card-body p-0 position-relative">
            <div id="network-graph" style="width: 100%; height: 500px; background-color: var(--bs-body-bg); overflow: hidden;"></div>
            <div class="position-absolute bottom-0 end-0 mb-3 me-3 btn-group-vertical shadow-sm" style="z-index: 10;">
                <button id="zoom-in-btn" class="btn btn-light border" title="Zoom In" aria-label="Zoom In"><i class="bi bi-plus-lg"></i></button>
                <button id="zoom-out-btn" class="btn btn-light border" title="Zoom Out" aria-label="Zoom Out"><i class="bi bi-dash-lg"></i></button>
                <button id="reset-zoom-btn" class="btn btn-light border" title="Reset View" aria-label="Reset View"><i class="bi bi-arrow-counterclockwise"></i></button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/network-graph.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const nodes = @Json.Serialize(Model.GraphNodes);
            const links = @Json.Serialize(Model.GraphLinks);
            initializeNetworkGraph(nodes, links);
        });
    </script>
}
