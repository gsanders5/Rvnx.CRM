@model Rvnx.CRM.Web.ViewModels.DebugOperations.MergeAccountsViewModel

@{
    ViewData["Title"] = "Merge Accounts";
}

<div class="container mt-5">
    <h2 class="mb-4">Merge Accounts</h2>

    @if (TempData["Message"] != null)
    {
        <div class="crm-alert crm-alert-success">
            @TempData["Message"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="crm-alert crm-alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="crm-card">
        <div class="crm-card-body">
            <p>
                Select two users to merge. All data from the smaller group (or the second user if tied) will be moved to the larger group.
                The empty group will be deleted. <strong>This action is irreversible.</strong>
            </p>

            <form asp-action="MergeAccounts" method="post">
                <div class="mb-3">
                    <label for="user1Id" class="form-label">User 1 (Target/Source)</label>
                    <select id="user1Id" name="user1Id" class="form-select" required>
                        <option value="">Select User 1</option>
                        @foreach (var user in Model.Users)
                        {
                            <option value="@user.Id">@user.Name (@user.GroupName - @user.GroupMemberCount members)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label for="user2Id" class="form-label">User 2 (Target/Source)</label>
                    <select id="user2Id" name="user2Id" class="form-select" required>
                        <option value="">Select User 2</option>
                        @foreach (var user in Model.Users)
                        {
                            <option value="@user.Id">@user.Name (@user.GroupName - @user.GroupMemberCount members)</option>
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label for="confirmation" class="form-label">Confirmation</label>
                    <input type="text" id="confirmation" name="confirmation" class="form-control" placeholder="Type 'MERGE' to confirm" required />
                </div>

                <button type="submit" class="crm-btn-danger" data-mdb-ripple-init>Merge Accounts</button>
                <a asp-action="Index" class="crm-btn-tertiary" data-mdb-ripple-init>Back to Debug Operations</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#user1Id').select2({ width: '100%' });
            $('#user2Id').select2({ width: '100%' });
        });
    </script>
}
