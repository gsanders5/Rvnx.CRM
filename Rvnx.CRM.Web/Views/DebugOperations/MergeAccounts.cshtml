@model Rvnx.CRM.Web.ViewModels.DebugOperations.MergeAccountsViewModel

@{
    ViewData["Title"] = "Merge Accounts";
}

<form id="merge-accounts-form" asp-action="MergeAccounts" method="post">
    @Html.AntiForgeryToken()

    @* ── Action strip ────────────────────────────────────────────────────── *@
    <div class="crm-details-actions-strip">
        <a asp-controller="UserSettings" asp-action="Index" class="crm-btn-tertiary btn-sm">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back
        </a>
        <button type="submit" class="crm-btn-primary btn-sm">
            <i class="bi bi-diagram-3" aria-hidden="true"></i> Merge
        </button>
    </div>

    @* ── Editorial masthead ─────────────────────────────────────────────── *@
    <section class="crm-edit-masthead crm-fade-in">
        <div class="crm-edit-masthead-photo-placeholder" aria-hidden="true" style="color: var(--crm-warning);">
            <i class="bi bi-tools"></i>
        </div>
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 6px;">Debug operations</div>
            <h1 class="crm-edit-masthead-title">Merge accounts</h1>
        </div>
    </section>

    @* ── Body ───────────────────────────────────────────────────────────── *@
    <div class="crm-edit-body">

        @* ── Main column ─────────────────────────────────────────────────── *@
        <div class="crm-edit-col-main">

            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-people" aria-hidden="true"></i> Accounts</h5>
                </div>
                <div class="crm-card-body">
                    <p style="color: var(--crm-text-secondary); margin-bottom: 18px;">
                        Select two users to merge. All data from the smaller group (or the second user if tied) will be moved to the larger group.
                        The empty group will be deleted. <strong>This action is irreversible.</strong>
                    </p>

                    <div class="crm-form-card-grid">
                        <div class="crm-field-group">
                            <label for="user1Id">User 1 (Target/Source)</label>
                            <select id="user1Id" name="user1Id" class="crm-input" required>
                                <option value="">Select User 1</option>
                                @foreach (var user in Model.Users)
                                {
                                    <option value="@user.Id">@user.Name (@user.GroupName - @user.GroupMemberCount members)</option>
                                }
                            </select>
                            <span class="crm-field-error"></span>
                        </div>

                        <div class="crm-field-group">
                            <label for="user2Id">User 2 (Target/Source)</label>
                            <select id="user2Id" name="user2Id" class="crm-input" required>
                                <option value="">Select User 2</option>
                                @foreach (var user in Model.Users)
                                {
                                    <option value="@user.Id">@user.Name (@user.GroupName - @user.GroupMemberCount members)</option>
                                }
                            </select>
                            <span class="crm-field-error"></span>
                        </div>
                    </div>

                    <div class="crm-field-group" style="margin-top: 14px;">
                        <label for="confirmation">Confirmation</label>
                        <input type="text" id="confirmation" name="confirmation" class="crm-input" placeholder="Type 'MERGE' to confirm" required />
                        <span class="crm-field-error"></span>
                    </div>
                </div>
            </div>
        </div>

        @* ── Side column ─────────────────────────────────────────────────── *@
        <div class="crm-edit-col-side">
            <div class="crm-save-shortcut-card">
                <div class="crm-save-shortcut-title">Merge accounts</div>
                <div class="crm-save-shortcut-desc">This operation cannot be undone. Confirm both account IDs before submitting.</div>
                <button type="submit" class="crm-btn-primary btn-sm" form="merge-accounts-form">
                    <i class="bi bi-diagram-3" aria-hidden="true"></i> Merge
                </button>
                <a asp-controller="UserSettings" asp-action="Index" class="crm-btn-tertiary btn-sm">
                    <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Settings
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#user1Id').select2({ width: '100%' });
            $('#user2Id').select2({ width: '100%' });
        });
    </script>
}
