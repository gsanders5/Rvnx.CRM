@{
    ViewData["Title"] = "Debug Operations";
}

<div class="container">
    <h1 class="mb-4">Debug Operations</h1>

    @if (TempData["Message"] != null)
    {
        <div class="crm-alert crm-alert-info" role="alert">
            @TempData["Message"]
        </div>
    }

    <div class="crm-card mb-4">
        <div class="crm-card-header">
            <h5 class="mb-0">Database Operations</h5>
        </div>
        <div class="crm-card-body">
            <p>Populate the database with sample data.</p>

            <div class="d-flex gap-2">
                <form asp-action="SeedTestData" method="post">
                    <button type="submit" class="crm-btn-primary">
                        <i class="bi bi-database-add"></i> Add Test Contacts
                    </button>
                </form>

                <form asp-action="AddRandomRelationships" method="post">
                    <button type="submit" class="crm-btn-secondary">
                        <i class="bi bi-people-fill"></i> Add Random Relationships
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="crm-card mb-4">
        <div class="crm-card-header">
            <h5 class="mb-0">Account Management</h5>
        </div>
        <div class="crm-card-body">
            <p>Combine two user accounts into a single shared group.</p>
            <a asp-action="MergeAccounts" class="crm-btn-secondary">
                <i class="bi bi-person-fill-gear"></i> Merge Accounts (Admin Only)
            </a>
        </div>
    </div>

    <div class="crm-card" style="border-color: rgba(239, 71, 111, 0.3);">
        <div class="crm-card-header" style="background-color: rgba(239, 71, 111, 0.08); color: var(--crm-danger);">
            <h5 class="mb-0">Danger Zone</h5>
        </div>
        <div class="crm-card-body">
            <p style="color: var(--crm-danger);">Warning: This will delete all data!</p>
            <form asp-action="ResetDatabase" method="post">
                <button type="submit" class="crm-btn-danger" onclick="return confirm('Are you sure you want to delete everything?');">
                    <i class="bi bi-trash"></i> Reset Database
                </button>
            </form>
        </div>
    </div>
</div>
