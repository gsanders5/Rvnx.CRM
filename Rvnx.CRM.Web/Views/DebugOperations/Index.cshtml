@{
    ViewData["Title"] = "Debug Operations";
}

<div class="container">
    <h1 class="mb-4">Debug Operations</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header">
            Database Operations
        </div>
        <div class="card-body">
            <h5 class="card-title">Seed Data</h5>
            <p class="card-text">Populate the database with sample data.</p>

            <div class="d-flex gap-2">
                <form asp-action="SeedTestData" method="post">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-database-add" aria-hidden="true"></i> Add Test Contacts
                    </button>
                </form>

                <form asp-action="AddRandomRelationships" method="post">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-people-fill" aria-hidden="true"></i> Add Random Relationships
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            Account Management
        </div>
        <div class="card-body">
            <h5 class="card-title">Merge Accounts</h5>
            <p class="card-text">Combine two user accounts into a single shared group.</p>
            <a asp-action="MergeAccounts" class="btn btn-warning">
                <i class="bi bi-person-fill-gear" aria-hidden="true"></i> Merge Accounts (Admin Only)
            </a>
        </div>
    </div>

    <div class="card border-danger">
        <div class="card-header bg-danger text-white">
            Danger Zone
        </div>
        <div class="card-body">
            <h5 class="card-title">Reset Database</h5>
            <p class="card-text text-danger">Warning: This will delete all data!</p>
            <form asp-action="ResetDatabase" method="post">
                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete everything?');">
                    <i class="bi bi-trash" aria-hidden="true"></i> Reset Database
                </button>
            </form>
        </div>
    </div>
</div>
