@model Rvnx.CRM.Web.ViewModels.GroupSettings.GroupSettingsViewModel
@{
    ViewData["Title"] = "Group Settings";
}

<div class="crm-page">

    <div class="crm-masthead crm-fade-in">
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 8px;">Your group</div>
            <h1 class="crm-masthead-title">Group Settings</h1>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-9 col-md-10">

            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="crm-alert crm-alert-success mb-4" role="alert">@Model.StatusMessage</div>
            }

            @* ── Immich integration ──────────────────────────────────────── *@
            <section id="immich" class="crm-card crm-fade-in crm-delay-1 mb-4">
                <div class="crm-card-header" style="display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap;">
                    <h5 class="card-title mb-0"><i class="bi bi-images" aria-hidden="true"></i> Immich Photos</h5>
                    @if (Model.HasImmichSettings)
                    {
                        <span class="badge @(Model.Immich!.Enabled ? "bg-success" : "bg-secondary")">
                            @(Model.Immich.Enabled ? "Enabled" : "Disabled")
                        </span>
                    }
                </div>
                <div class="crm-card-body">
                    <p style="color: var(--crm-text-secondary);">
                        Connect a self-hosted <a href="https://immich.app" target="_blank" rel="noopener noreferrer">Immich</a>
                        photo server. The connection is shared by everyone in your group — all members see the same
                        Immich people, tags, and photos.
                    </p>

                    <div asp-validation-summary="ModelOnly" class="crm-alert crm-alert-danger" role="alert"></div>

                    <form asp-controller="GroupSettings" asp-action="SaveImmich" method="post" class="d-flex flex-column gap-3" style="max-width: 560px;">
                        @Html.AntiForgeryToken()

                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="immichEnabled"
                                   asp-for="ImmichForm.Enabled" />
                            <label class="form-check-label" for="immichEnabled">Enable Immich integration</label>
                        </div>

                        <div class="crm-field-group">
                            <label asp-for="ImmichForm.BaseUrl">Server URL <span style="color: var(--crm-danger);">*</span></label>
                            <input asp-for="ImmichForm.BaseUrl" class="crm-input" type="url"
                                   placeholder="https://immich.example.com/api" />
                            <span asp-validation-for="ImmichForm.BaseUrl" class="crm-field-error"></span>
                            <small class="crm-field-help" style="color: var(--crm-text-tertiary);">
                                Include the <code>/api</code> suffix.
                            </small>
                        </div>

                        <div class="crm-field-group">
                            <label asp-for="ImmichForm.ApiKey">
                                API Key
                                @if (!Model.HasImmichSettings)
                                {
                                    <span style="color: var(--crm-danger);">*</span>
                                }
                            </label>
                            <input asp-for="ImmichForm.ApiKey" class="crm-input" type="password" autocomplete="off"
                                   placeholder="@(Model.HasImmichSettings ? $"Current key: {Model.Immich!.ApiKeyHint} — leave blank to keep" : "Paste your Immich API key")" />
                            <span asp-validation-for="ImmichForm.ApiKey" class="crm-field-error"></span>
                            <small class="crm-field-help" style="color: var(--crm-text-tertiary);">
                                Create one in Immich under Account Settings &rarr; API Keys. The key is stored
                                server-side and never shown again@(Model.HasImmichSettings ? "; leave blank to keep the current key" : "").
                            </small>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <button type="submit" class="crm-btn-primary btn-sm">
                                <i class="bi bi-check-lg" aria-hidden="true"></i> Save
                            </button>
                            @if (Model.HasImmichSettings)
                            {
                                <button type="button" class="crm-btn-danger btn-sm"
                                        data-confirm-action="@Url.Action("DeleteImmich", "GroupSettings")"
                                        data-confirm-title="Remove Immich Settings"
                                        data-confirm-body="Remove the Immich server connection and stored API key for your whole group? Photo galleries will disappear for every group member."
                                        data-confirm-btn-label="Remove"
                                        data-confirm-btn-icon="bi-trash">
                                    <i class="bi bi-trash" aria-hidden="true"></i> Remove connection
                                </button>
                            }
                        </div>
                    </form>
                </div>
            </section>
        </div>
    </div>
</div>
