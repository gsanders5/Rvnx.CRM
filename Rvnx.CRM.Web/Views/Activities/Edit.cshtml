@model Rvnx.CRM.Core.DTOs.Contact.ActivityFormDto

@{
    ViewData["Title"] = "Edit Activity";
}

<h1>Edit Activity</h1>

<div class="row">
    <div class="col-12">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id"/>
            <input type="hidden" asp-for="EntityId"/>

            <div class="form-floating mb-3">
                <input asp-for="Title" class="form-control" id="Title" placeholder=" " required autofocus/>
                <label asp-for="Title">Title <span class="text-danger">*</span></label>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="ActivityDate" class="form-control" type="date" id="ActivityDate" placeholder=" " required/>
                <label asp-for="ActivityDate">Date <span class="text-danger">*</span></label>
                <span asp-validation-for="ActivityDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ActivityType" class="form-label">Type</label>
                <select asp-for="ActivityType" id="ActivityType" class="form-select">
                    <option value="">Select or type a custom type...</option>
                    @foreach (var type in Rvnx.CRM.Core.Constants.ActivityTypeSuggestions.All)
                    {
                        <option value="@type" selected="@(Model.ActivityType == type)">@type</option>
                    }
                    @if (!string.IsNullOrEmpty(Model.ActivityType) && !Rvnx.CRM.Core.Constants.ActivityTypeSuggestions.All.Contains(Model.ActivityType))
                    {
                        <option value="@Model.ActivityType" selected>@Model.ActivityType</option>
                    }
                </select>
                <span asp-validation-for="ActivityType" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Location" class="form-control" id="Location" placeholder=" "/>
                <label asp-for="Location">Location</label>
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" id="Description" placeholder="Notes about this activity..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Contacts</label>
                <select name="ContactIds" id="ContactIds" class="form-select" multiple>
                    @foreach (var item in (MultiSelectList)ViewBag.ContactsList)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>

            <div class="d-grid gap-2 d-md-flex mt-4">
                <button type="submit" class="crm-btn-primary"><i class="bi bi-save" aria-hidden="true"></i>Save</button>
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="crm-btn-tertiary"><i class="bi bi-arrow-left" aria-hidden="true"></i>Back to Contact</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @{ await Html.RenderPartialAsync("_EasyMDEScripts"); }
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            $('#ActivityType').select2({ width: '100%', tags: true, placeholder: 'Select or type a custom type...', allowClear: true });
            $('#ContactIds').select2({ width: '100%', placeholder: 'Select contacts...' });
        });
    </script>
}
