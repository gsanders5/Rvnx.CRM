@model Rvnx.CRM.Core.DTOs.Contact.ActivityFormDto
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Edit Activity";
}

<form id="activity-form" asp-action="Edit" data-edit-form>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ContactId" />

    @await Html.PartialAsync("_EditFormHeader", new EditFormHeaderModel
    {
        BackUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!,
        Icon = "bi-calendar-check",
        Eyebrow = "Editing activity",
        Title = string.IsNullOrWhiteSpace(Model.Title) ? "Activity" : Model.Title
    })

    @* ── Body ───────────────────────────────────────────────────────────── *@
    <div class="crm-edit-body">

        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            @* ── Activity ──────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-calendar-check" aria-hidden="true"></i> Activity</h5>
                </div>
                <div class="crm-card-body">

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Details</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Title">Title *</label>
                        <input asp-for="Title" class="crm-input" id="Title" required autofocus />
                        <span asp-validation-for="Title" class="crm-field-error"></span>
                    </div>

                    <div class="crm-form-card-grid">
                        <div class="crm-field-group">
                            <label asp-for="ActivityDate">Date *</label>
                            <input asp-for="ActivityDate" class="crm-input" type="date" id="ActivityDate" required />
                            <span asp-validation-for="ActivityDate" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="ActivityType">Type</label>
                            <select asp-for="ActivityType" id="ActivityType" class="crm-input">
                                <option value="">Select or type a custom type...</option>
                                @foreach (var type in Rvnx.CRM.Core.Constants.ActivityTypeSuggestions.All)
                                {
                                    <option value="@type" selected="@(Model.ActivityType == type)">@type</option>
                                }
                                @if (!string.IsNullOrEmpty(Model.ActivityType) && !Rvnx.CRM.Core.Constants.ActivityTypeSuggestions.All.Contains(Model.ActivityType))
                                {
                                    <option value="@Model.ActivityType" selected>@Model.ActivityType</option>
                                }
                            </select>
                            <span asp-validation-for="ActivityType" class="crm-field-error"></span>
                        </div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Location">Location</label>
                        <input asp-for="Location" class="crm-input" id="Location" />
                        <span asp-validation-for="Location" class="crm-field-error"></span>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description" id="Description" placeholder="Notes about this activity..."></textarea>
                        <span asp-validation-for="Description" class="crm-field-error"></span>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Contacts</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-field-group">
                        <label for="ContactIds">Contacts</label>
                        <select name="ContactIds" id="ContactIds" class="crm-input" multiple>
                            @foreach (var item in (MultiSelectList)ViewBag.ContactsList)
                            {
                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
            {
                FormId = "activity-form",
                CancelUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!
            })
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    @{ await Html.RenderPartialAsync("_EasyMDEScripts"); }
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            $('#ActivityType').select2({ width: '100%', tags: true, placeholder: 'Select or type a custom type...', allowClear: true });
            $('#ContactIds').select2({ width: '100%', placeholder: 'Select contacts...' });
        });
    </script>
}
