@model Rvnx.CRM.Web.Controllers.ApiTokenCreateViewModel

@{
    ViewData["Title"] = "Generate API Token";
}

<div class="container mt-4">
    <h2>Generate New API Token</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Token Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., Postman Testing" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                            <div class="form-text">A descriptive name to identify what this token is used for.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ExpiresAt" class="form-label fw-bold">Expiration Date (Optional)</label>
                            <input asp-for="ExpiresAt" class="form-control" type="date" />
                            <span asp-validation-for="ExpiresAt" class="text-danger"></span>
                            <div class="form-text">Leave blank for a token that never expires.</div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Generate Token</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card bg-light border-0">
                <div class="card-body">
                    <h5 class="card-title text-primary"><i class="fas fa-shield-alt me-2"></i> Security Best Practices</h5>
                    <ul class="text-muted mt-3 mb-0">
                        <li class="mb-2"><strong>Never share</strong> your API tokens. They carry the same permissions as your user account.</li>
                        <li class="mb-2"><strong>Do not commit</strong> tokens to source control (e.g., GitHub, GitLab). Use environment variables or secrets managers instead.</li>
                        <li class="mb-2"><strong>Set expirations</strong> when possible to limit the lifespan of a compromised token.</li>
                        <li><strong>Revoke immediately</strong> if you suspect a token has been exposed.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}