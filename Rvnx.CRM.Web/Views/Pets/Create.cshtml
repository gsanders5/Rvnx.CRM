@model Rvnx.CRM.Core.DTOs.Pet.PetFormDto

@{
    ViewData["Title"] = "Add Pet";
}

<h1>Add Pet</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EntityId" />

            <div class="form-floating mb-3">
    <input asp-for="Name" class="form-control"  placeholder="Name"/>
    <label asp-for="Name"></label>
    <span asp-validation-for="Name" class="text-danger"></span>
</div>

            <div class="form-floating mb-3">
    <input asp-for="Species" class="form-control"  placeholder="Species"/>
    <label asp-for="Species"></label>
    <span asp-validation-for="Species" class="text-danger"></span>
</div>

            <div class="form-floating mb-3">
    <input asp-for="Breed" class="form-control"  placeholder="Breed"/>
    <label asp-for="Breed"></label>
    <span asp-validation-for="Breed" class="text-danger"></span>
</div>

            <div class="form-floating mb-3">
    <input asp-for="Birthday" class="form-control" type="date"  placeholder="Birthday"/>
    <label asp-for="Birthday"></label>
    <span asp-validation-for="Birthday" class="text-danger"></span>
</div>

            <div class="form-floating mb-3">
    <textarea asp-for="Notes" class="form-control" placeholder="Notes"></textarea>
    <label asp-for="Notes"></label>
    <span asp-validation-for="Notes" class="text-danger"></span>
</div>

            <div class="form-group mt-3">
                <input type="submit" value="Add Pet" class="btn btn-primary" />
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary">Back to Contact</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
