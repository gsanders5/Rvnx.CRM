@model Rvnx.CRM.Core.DTOs.Contact.PetFormDto
@using Rvnx.CRM.Web.ViewModels.Shared

@{
    ViewData["Title"] = "Add Pet";
}

<form id="pet-form" asp-action="Create" data-edit-form>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ContactId" />

    @await Html.PartialAsync("_EditFormHeader", new EditFormHeaderModel
    {
        BackUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!,
        SaveText = "Add Pet",
        SaveIcon = "bi-plus-lg",
        Icon = "bi-emoji-smile",
        Eyebrow = "Adding pet",
        Title = "New Pet"
    })

    @* ── Body ───────────────────────────────────────────────────────────── *@
    <div class="crm-edit-body">

        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            @* ── Details ───────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-emoji-smile" aria-hidden="true"></i> Pet Details</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-form-card-grid">
                        <div class="crm-field-group">
                            <label asp-for="Name">Name *</label>
                            <input asp-for="Name" class="crm-input" id="Name" required autofocus />
                            <span asp-validation-for="Name" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Birthday">Birthday</label>
                            <input asp-for="Birthday" class="crm-input" type="date" id="Birthday" />
                            <span asp-validation-for="Birthday" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Species">Species</label>
                            <input asp-for="Species" class="crm-input" id="Species" />
                            <span asp-validation-for="Species" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Breed">Breed</label>
                            <input asp-for="Breed" class="crm-input" id="Breed" />
                            <span asp-validation-for="Breed" class="crm-field-error"></span>
                        </div>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Notes</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Notes">Notes</label>
                        <textarea asp-for="Notes" class="crm-input" style="height: 100px" id="Notes"></textarea>
                        <span asp-validation-for="Notes" class="crm-field-error"></span>
                    </div>
                </div>
            </div>

            @* ── Owners ────────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-people" aria-hidden="true"></i> Owners</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-field-group">
                        <label for="ContactIds">Owners</label>
                        <select name="ContactIds" id="ContactIds" class="crm-input" multiple
                                data-select2 data-select2-placeholder="Select owners...">
                            @foreach (var item in (MultiSelectList)ViewBag.ContactsList)
                            {
                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            @await Html.PartialAsync("_SaveShortcutCard", new SaveShortcutCardModel
            {
                FormId = "pet-form",
                CancelUrl = Url.Action("Details", "Contacts", new { id = Model.ContactId })!,
                SaveText = "Add Pet",
                SaveIcon = "bi-plus-lg"
            })
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
