@model Rvnx.CRM.Core.DTOs.Contact.PetDto

@{
    ViewData["Title"] = "Delete Pet";
}

<h1>Delete Pet</h1>

<h3>Are you sure you want to delete this pet?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Species</dt>
        <dd class="col-sm-10">@Model.Species</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id"/>
        <div class="d-grid gap-2 d-md-flex mt-4">
            <button type="submit" class="crm-btn-danger"><i class="bi bi-trash"></i>Delete</button>
            <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="crm-btn-tertiary"><i class="bi bi-x-lg"></i>Cancel</a>
        </div>
    </form>
</div>
