@model Rvnx.CRM.Core.DTOs.Pet.PetDto

@{
    ViewData["Title"] = "Delete Pet";
}

<h1>Delete Pet</h1>

<h3>Are you sure you want to delete this pet?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Species</dt>
        <dd class="col-sm-10">@Model.Species</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary">Cancel</a>
    </form>
</div>
