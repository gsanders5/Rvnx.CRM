@model Rvnx.CRM.Core.DTOs.Contact.PetFormDto

@{
    ViewData["Title"] = "Edit Pet";
}

<form id="pet-form" asp-action="Edit" data-edit-form>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ContactId" />

    @* ── Action strip ────────────────────────────────────────────────────── *@
    <div class="crm-details-actions-strip">
        <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.ContactId" class="crm-btn-tertiary btn-sm">
            <i class="bi bi-arrow-left" aria-hidden="true"></i> Back to Contact
        </a>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <span class="crm-eyebrow crm-unsaved-indicator" id="unsaved-indicator" hidden>
                <i class="bi bi-circle-fill" aria-hidden="true" style="font-size: 6px; vertical-align: middle; margin-right: 4px;"></i>
                Unsaved
            </span>
            <button type="submit" class="crm-btn-primary btn-sm">
                <i class="bi bi-save" aria-hidden="true"></i> Save
            </button>
        </div>
    </div>

    @* ── Editorial masthead ─────────────────────────────────────────────── *@
    <section class="crm-edit-masthead crm-fade-in">
        <div class="crm-edit-masthead-photo-placeholder" aria-hidden="true">
            <i class="bi bi-emoji-smile"></i>
        </div>
        <div>
            <div class="crm-eyebrow" style="margin-bottom: 6px;">Editing pet</div>
            <h1 class="crm-edit-masthead-title">
                @if (!string.IsNullOrWhiteSpace(Model.Name))
                {
                    @Model.Name
                }
                else
                {
                    <text>Pet</text>
                }
            </h1>
        </div>
    </section>

    @* ── Body ───────────────────────────────────────────────────────────── *@
    <div class="crm-edit-body">

        <div class="crm-edit-col-main">
            <div asp-validation-summary="ModelOnly" class="crm-field-error"></div>

            @* ── Details ───────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-emoji-smile" aria-hidden="true"></i> Pet Details</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-form-card-grid">
                        <div class="crm-field-group">
                            <label asp-for="Name">Name *</label>
                            <input asp-for="Name" class="crm-input" id="Name" required />
                            <span asp-validation-for="Name" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Birthday">Birthday</label>
                            <input asp-for="Birthday" class="crm-input" type="date" id="Birthday" />
                            <span asp-validation-for="Birthday" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Species">Species</label>
                            <input asp-for="Species" class="crm-input" id="Species" />
                            <span asp-validation-for="Species" class="crm-field-error"></span>
                        </div>
                        <div class="crm-field-group">
                            <label asp-for="Breed">Breed</label>
                            <input asp-for="Breed" class="crm-input" id="Breed" />
                            <span asp-validation-for="Breed" class="crm-field-error"></span>
                        </div>
                    </div>

                    <div class="crm-form-divider">
                        <div class="crm-form-divider-line"></div>
                        <span class="crm-eyebrow">Notes</span>
                        <div class="crm-form-divider-line"></div>
                    </div>

                    <div class="crm-field-group">
                        <label asp-for="Notes">Notes</label>
                        <textarea asp-for="Notes" class="crm-input" style="height: 100px" id="Notes"></textarea>
                        <span asp-validation-for="Notes" class="crm-field-error"></span>
                    </div>
                </div>
            </div>

            @* ── Owners ────────────────────────────────────────────────── *@
            <div class="crm-card">
                <div class="crm-card-header">
                    <h5 class="card-title mb-0"><i class="bi bi-people" aria-hidden="true"></i> Owners</h5>
                </div>
                <div class="crm-card-body">
                    <div class="crm-field-group">
                        <label for="ContactIds">Owners</label>
                        <select name="ContactIds" id="ContactIds" class="crm-input" multiple>
                            @foreach (var item in (MultiSelectList)ViewBag.ContactsList)
                            {
                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="crm-edit-col-side">
            <div class="crm-save-shortcut-card">
                <div class="crm-save-shortcut-title">Ready to save?</div>
                <div class="crm-save-shortcut-desc">Changes are applied immediately.</div>
                <button type="submit" class="crm-btn-primary btn-sm" form="pet-form">
                    <i class="bi bi-save" aria-hidden="true"></i> Save
                </button>
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.ContactId" class="crm-btn-tertiary btn-sm">
                    <i class="bi bi-arrow-left" aria-hidden="true"></i> Cancel
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $(document).ready(function () {
            $('#ContactIds').select2({ width: '100%', placeholder: 'Select owners...' });
        });
    </script>
}
