@model Rvnx.CRM.Core.DTOs.Contact.PetFormDto

@{
    ViewData["Title"] = "Edit Pet";
}

<h1>Edit Pet</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id"/>
            <input type="hidden" asp-for="EntityId"/>

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" id="Name" placeholder=" " required/>
                <label asp-for="Name">Name <span class="text-danger">*</span></label>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Species" class="form-control" id="Species" placeholder=" "/>
                <label asp-for="Species">Species</label>
                <span asp-validation-for="Species" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Breed" class="form-control" id="Breed" placeholder=" "/>
                <label asp-for="Breed">Breed</label>
                <span asp-validation-for="Breed" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Birthday" class="form-control" type="date" id="Birthday" placeholder=" "/>
                <label asp-for="Birthday">Birthday</label>
                <span asp-validation-for="Birthday" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="Notes" class="form-control" style="height: 100px" id="Notes" placeholder=" "></textarea>
                <label asp-for="Notes">Notes</label>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Owners</label>
                <select name="ContactIds" id="ContactIds" class="form-select" multiple>
                    @foreach (var item in (MultiSelectList)ViewBag.ContactsList)
                    {
                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                    }
                </select>
            </div>

            <div class="d-grid gap-2 d-md-flex mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Save</button>
                <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary"><i class="bi bi-arrow-left me-2"></i>Back to Contact</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        $(document).ready(function () {
            $('#ContactIds').select2({ width: '100%', placeholder: 'Select owners...' });
        });
    </script>
}
