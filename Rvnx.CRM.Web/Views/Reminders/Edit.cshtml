@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Common.ReminderDto

@{
    ViewData["Title"] = "Edit Reminder";
    var entityName = ViewData["EntityName"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <form asp-action="Edit" id="eventForm" onsubmit="prepareFrequency()">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="EntityId" />
            <input type="hidden" asp-for="EntityType" />
            <input type="hidden" asp-for="CreatedDate" />
            <input type="hidden" asp-for="CreatedBy" />
            <input type="hidden" asp-for="UserId" />

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-body-tertiary border-bottom p-3 rounded-top-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Reminder for @entityName</h4>
                </div>

                <div class="card-body p-4">

                    <!-- Title -->
                    <div class="form-floating mb-3">
    <input asp-for="Title" class="form-control form-control-lg"  placeholder="Title"/>
    <label asp-for="Title"></label>
    <span asp-validation-for="Title" class="text-danger"></span>
</div>

                    <!-- Date -->
                    <div class="form-floating mb-3">
    <input asp-for="DueDate" class="form-control" type="date" onchange="updateSummary()"  placeholder="DueDate"/>
    <label asp-for="DueDate"></label>
    <span asp-validation-for="DueDate" class="text-danger"></span>
</div>

                    <!-- Description -->
                    <div class="form-floating mb-4">
                        <textarea asp-for="Description" class="form-control" style="height: 100px" placeholder="Enter optional details..."></textarea>
                        <label asp-for="Description"></label>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <hr class="my-4">

                    <!-- Reminder Duration Partial -->
                    <partial name="_ReminderDurationPartial" model="Model" />

                    <div class="form-check mb-3 mt-4">
                        <input class="form-check-input" type="checkbox" asp-for="IsCompleted" id="IsCompleted">
                        <label class="form-check-label" for="IsCompleted">
                            @Html.DisplayNameFor(model => model.IsCompleted)
                        </label>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <input type="submit" value="Save" class="btn btn-primary btn-lg" />
                        @if (Model.EntityType == EntityTypes.Person)
                        {
                             <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId" class="btn btn-secondary">Cancel</a>
                        }
                        else
                        {
                            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                        }
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
