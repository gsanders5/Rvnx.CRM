@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Dates.ReminderDeleteViewModel

@{
    ViewData["Title"] = "Delete Reminder";
}

<h1>Delete Reminder</h1>

<h3>Are you sure you want to delete this reminder?</h3>
<div>
    <h4>Reminder</h4>
    <hr/>
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DueDate)
        </dt>
        <dd class="col-sm-10">
            @Model.DueDate.ToShortDateString()
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id"/>
        <input type="submit" value="Delete" class="btn btn-danger"/> |
        <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.EntityId">Cancel</a>
    </form>
</div>
