@model Rvnx.CRM.Core.Models.Dates.Reminder

@{
    ViewData["Title"] = "Delete Reminder";
}

<h1>Delete Reminder</h1>

<h3>Are you sure you want to delete this reminder?</h3>
<div>
    <h4>Reminder</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DueDate)
        </dt>
        <dd class = "col-sm-10">
            @Model.DueDate.ToShortDateString() @Model.DueDate.ToShortTimeString()
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.IsCompleted)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.IsCompleted)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-controller="Contacts" asp-action="Details" asp-route-id="@Model.PersonId">Cancel</a>
    </form>
</div>
