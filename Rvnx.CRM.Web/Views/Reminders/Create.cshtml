@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Common.ReminderDto

@{
    ViewData["Title"] = "Add Reminder";
    var entityId = ViewData["EntityId"] as Guid?;
    var entityType = ViewData["EntityType"] as string;
    var entityName = ViewData["EntityName"] as string;
}

<h1>Add Reminder for @entityName</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EntityId" value="@entityId" />
            <input type="hidden" asp-for="EntityType" value="@entityType" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DueDate" class="form-label"></label>
                <input asp-for="DueDate" class="form-control" type="date" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" asp-for="RemindMe" />
                <label class="form-check-label" asp-for="RemindMe"></label>
            </div>

            <div class="mb-3">
                <label asp-for="EventFrequency" class="form-label"></label>
                <input asp-for="EventFrequency" class="form-control" type="text" placeholder="d.hh:mm:ss" />
                <span asp-validation-for="EventFrequency" class="text-danger"></span>
                <div class="form-text">TimeSpan format: d.hh:mm:ss (e.g., 365.00:00:00 for one year)</div>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save Reminder" class="btn btn-primary" />
                @if (entityType == EntityTypes.Person)
                {
                     <a asp-controller="Contacts" asp-action="Details" asp-route-id="@entityId" class="btn btn-secondary">Cancel</a>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
