@using Rvnx.CRM.Core.Constants
@model Rvnx.CRM.Core.DTOs.Common.ReminderDto

@{
    ViewData["Title"] = "Add Reminder";
    var entityId = ViewData["EntityId"] as Guid?;
    var entityType = ViewData["EntityType"] as string;
    var entityName = ViewData["EntityName"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <form asp-action="Create" id="eventForm" onsubmit="prepareFrequency()">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EntityId" value="@entityId" />
            <input type="hidden" asp-for="EntityType" value="@entityType" />

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-white border-bottom p-3 rounded-top-3">
                    <h4 class="mb-0"><i class="bi bi-calendar-plus me-2 text-primary"></i>Add Reminder for @entityName</h4>
                </div>

                <div class="card-body p-4">

                    <!-- Title -->
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold"></label>
                        <input asp-for="Title" class="form-control form-control-lg" placeholder="e.g. Contract Renewal" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <!-- Date -->
                    <div class="mb-3">
                        <label asp-for="DueDate" class="form-label fw-bold">Date of Event</label>
                        <input asp-for="DueDate" class="form-control" type="date" onchange="updateSummary()" />
                        <span asp-validation-for="DueDate" class="text-danger"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter optional details..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <hr class="my-4">

                    <!-- Reminder Duration Partial -->
                    <partial name="_ReminderDurationPartial" model="Model" />

                    <div class="d-grid gap-2 mt-4">
                        <input type="submit" value="Save Reminder" class="btn btn-primary btn-lg" />
                        @if (entityType == EntityTypes.Person)
                        {
                             <a asp-controller="Contacts" asp-action="Details" asp-route-id="@entityId" class="btn btn-secondary">Cancel</a>
                        }
                        else
                        {
                            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                        }
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
